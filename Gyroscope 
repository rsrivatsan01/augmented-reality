## Updated `ARTextRenderer.java` — Replaces billboard with surface-locked quad
```java
package com.yourapp;

import android.content.Context;
import android.graphics.Bitmap;
import android.graphics.Rect;
import android.graphics.RectF;
import android.opengl.GLES20;
import android.opengl.GLSurfaceView;
import android.opengl.GLUtils;
import android.opengl.Matrix;
import android.util.Log;

import com.google.ar.core.Camera;
import com.google.ar.core.Frame;
import com.google.ar.core.Plane;
import com.google.ar.core.Session;
import com.google.ar.core.TrackingState;

import java.util.ArrayList;
import java.util.List;

import javax.microedition.khronos.egl.EGLConfig;
import javax.microedition.khronos.opengles.GL10;

public class ARTextRenderer implements GLSurfaceView.Renderer {

    private static final String TAG = "ARTextRenderer";

    private final Context context;
    private Session arSession;

    private final BackgroundRenderer backgroundRenderer = new BackgroundRenderer();
    private LockedQuadRenderer quadRenderer; // replaces billboard renderer

    // Per-block data
    private static class BlockData {
        SurfacePinner.PinnedAnchor pinnedAnchor;
        int[]   textureId    = new int[1];
        float   widthMeters;
        float   heightMeters;
        float   fadeAlpha    = 0f;
        int     stableFrames = 0;
        boolean frozen       = false;
        float   lockProgress = 0f;
        String  translated;  // keep for debug
    }

    private final List<BlockData>  blocks       = new ArrayList<>();
    private final List<BlockData>  pendingBlocks= new ArrayList<>();
    private final Object           pendingLock  = new Object();

    private static final int   STABLE_NEEDED = 40;
    private static final float DRIFT_THRESHOLD = 0.006f; // 6mm
    private static final float FADE_SPEED     = 0.04f;

    // Camera state (updated each frame)
    private final float[] projMatrix = new float[16];
    private final float[] viewMatrix = new float[16];
    private float[] cameraWorldPos   = {0f, 0f, 0f};

    public interface FrameCallback {
        void onBlocksUpdated(List<AnchorLock.LockedBlock> blocks,
                             float[] proj, float[] view);
        void onPlaneFound();
    }
    private final FrameCallback frameCallback;
    private boolean planeFound = false;

    // Pending placement input
    private static class PlacementInput {
        Frame  frame;
        List<String>  originals, translated;
        List<RectF>   bounds;
        List<TypographyAnalyzer.FontProfile> profiles;
        List<Bitmap>  inpainted;
        List<Rect>    sourceBoxes;
        int viewW, viewH;
    }
    private volatile PlacementInput pendingPlacement = null;

    public ARTextRenderer(Context context, FrameCallback cb) {
        this.context       = context;
        this.frameCallback = cb;
    }

    public void setSession(Session s) { this.arSession = s; }

    // ── Called from main thread ────────────────────────────────────────────

    public void placeBlocks(Frame frame,
                             List<String> originals,
                             List<String> translated,
                             List<RectF> bounds,
                             List<TypographyAnalyzer.FontProfile> profiles,
                             List<Bitmap> inpainted,
                             List<Rect> sourceBoxes,
                             int viewW, int viewH) {
        PlacementInput input = new PlacementInput();
        input.frame      = frame;
        input.originals  = originals;
        input.translated = translated;
        input.bounds     = bounds;
        input.profiles   = profiles;
        input.inpainted  = inpainted;
        input.sourceBoxes= sourceBoxes;
        input.viewW      = viewW;
        input.viewH      = viewH;
        pendingPlacement = input; // picked up on GL thread next frame
    }

    // ── GL lifecycle ───────────────────────────────────────────────────────

    @Override
    public void onSurfaceCreated(GL10 gl, EGLConfig config) {
        GLES20.glClearColor(0f, 0f, 0f, 1f);
        try {
            backgroundRenderer.createOnGlThread(context);
        } catch (Exception e) {
            Log.e(TAG, "BG renderer failed", e);
        }
        quadRenderer = new LockedQuadRenderer();
    }

    @Override
    public void onSurfaceChanged(GL10 gl, int width, int height) {
        GLES20.glViewport(0, 0, width, height);
        if (arSession != null) {
            arSession.setDisplayGeometry(
                ((android.app.Activity) context)
                    .getWindowManager().getDefaultDisplay().getRotation(),
                width, height);
        }
    }

    @Override
    public void onDrawFrame(GL10 gl) {
        GLES20.glClear(
            GLES20.GL_COLOR_BUFFER_BIT | GLES20.GL_DEPTH_BUFFER_BIT);

        if (arSession == null) return;

        try {
            arSession.setCameraTextureName(
                backgroundRenderer.getTextureId());
            Frame  frame  = arSession.update();
            Camera camera = frame.getCamera();

            // ── 1. Camera feed ─────────────────────────────────────────────
            backgroundRenderer.draw(frame);
            if (camera.getTrackingState() != TrackingState.TRACKING) return;

            // ── 2. Update camera matrices + world position ─────────────────
            camera.getProjectionMatrix(projMatrix, 0, 0.01f, 100f);
            camera.getViewMatrix(viewMatrix, 0);

            // Extract camera world position from view matrix inverse
            float[] invView = new float[16];
            Matrix.invertM(invView, 0, viewMatrix, 0);
            cameraWorldPos = new float[]{invView[12], invView[13], invView[14]};

            // ── 3. Plane detection notify ──────────────────────────────────
            if (!planeFound) {
                for (Plane p : arSession.getAllTrackables(Plane.class)) {
                    if (p.getTrackingState() == TrackingState.TRACKING) {
                        planeFound = true;
                        ((android.app.Activity) context).runOnUiThread(
                            frameCallback::onPlaneFound);
                        break;
                    }
                }
            }

            // ── 4. Process pending placement ───────────────────────────────
            PlacementInput input = pendingPlacement;
            if (input != null) {
                pendingPlacement = null;
                processPendingPlacement(input);
            }

            // ── 5. Draw all blocks ─────────────────────────────────────────
            GLES20.glEnable(GLES20.GL_BLEND);
            GLES20.glBlendFunc(
                GLES20.GL_SRC_ALPHA, GLES20.GL_ONE_MINUS_SRC_ALPHA);
            GLES20.glDepthMask(false);

            for (BlockData b : blocks) {
                // Fade in
                b.fadeAlpha = Math.min(1f, b.fadeAlpha + FADE_SPEED);

                float[] matrix;

                if (b.frozen) {
                    // ── LOCKED: use frozen matrix, never changes ───────────
                    matrix = b.pinnedAnchor.frozenMatrix;
                    b.lockProgress = Math.min(1f, b.lockProgress + 0.03f);

                } else {
                    // ── BUILDING: update translation, keep plane rotation ──
                    if (b.pinnedAnchor.anchor == null ||
                        b.pinnedAnchor.anchor.getTrackingState()
                            != TrackingState.TRACKING) continue;

                    matrix = SurfacePinner.updateMatrix(b.pinnedAnchor);

                    // Stability check
                    if (b.pinnedAnchor.surfaceMatrix != null) {
                        float drift = translationDrift(
                            b.pinnedAnchor.surfaceMatrix, matrix);

                        if (drift < DRIFT_THRESHOLD) {
                            b.stableFrames++;
                        } else {
                            b.stableFrames = Math.max(0, b.stableFrames - 3);
                        }

                        // Enough stability → freeze permanently
                        if (b.stableFrames >= STABLE_NEEDED) {
                            SurfacePinner.freeze(b.pinnedAnchor);
                            b.frozen = true;
                            matrix   = b.pinnedAnchor.frozenMatrix;
                        }
                    }
                }

                if (matrix == null) continue;

                // ── Draw flush on surface ──────────────────────────────────
                quadRenderer.draw(
                    matrix,
                    viewMatrix,
                    projMatrix,
                    b.textureId[0],
                    b.widthMeters,
                    b.heightMeters,
                    b.fadeAlpha,
                    cameraWorldPos,
                    b.pinnedAnchor.planeNormal != null
                        ? b.pinnedAnchor.planeNormal
                        : new float[]{0f, 1f, 0f});
            }

            GLES20.glDepthMask(true);
            GLES20.glDisable(GLES20.GL_BLEND);

        } catch (Exception e) {
            Log.e(TAG, "Frame error: " + e.getMessage());
        }
    }

    // ── Placement: runs on GL thread ───────────────────────────────────────

    private void processPendingPlacement(PlacementInput input) {
        // Clear old blocks
        for (BlockData b : blocks) {
            if (b.pinnedAnchor != null && b.pinnedAnchor.anchor != null) {
                b.pinnedAnchor.anchor.detach();
            }
            GLES20.glDeleteTextures(1, b.textureId, 0);
        }
        blocks.clear();

        for (int i = 0; i < input.translated.size(); i++) {
            RectF bounds  = input.bounds.get(i);
            TypographyAnalyzer.FontProfile profile = input.profiles.get(i);

            float cx = (bounds.left + bounds.right)  / 2f;
            float cy = (bounds.top  + bounds.bottom) / 2f;

            // Estimate real-world depth at this block
            float depth = DepthPinner.estimateDepth(
                input.frame, cx, cy,
                bounds.width(), bounds.height(),
                input.viewW, input.viewH);

            // ── Create surface-pinned anchor ───────────────────────────────
            SurfacePinner.PinnedAnchor pa = SurfacePinner.create(
                input.frame, arSession, cx, cy);

            if (pa == null) {
                // Fallback: place 0.5m in front of camera
                pa = createFallbackAnchor(input.frame, cx, cy,
                    input.viewW, input.viewH, depth);
                if (pa == null) continue;
            }

            // ── Real-world size from depth + screen ratio ──────────────────
            // FOV-based: width = 2 * depth * tan(FOV/2) * screenFraction
            float fovFactor  = 1.0f; // approximate for standard FOV
            float screenFrac = bounds.width() / input.viewW;
            float widthM     = Math.max(0.05f,
                Math.min(2.0f, 2f * depth * fovFactor * screenFrac));
            float heightM    = widthM *
                (bounds.height() / Math.max(1f, bounds.width()));

            // ── Build billboard texture ────────────────────────────────────
            Bitmap bmp = FlagshipBillboard.create(
                input.inpainted.get(i),
                input.sourceBoxes.get(i),
                input.translated.get(i),   // ← translated text
                profile,
                1f);

            // Upload texture
            int[] texId = new int[1];
            GLES20.glGenTextures(1, texId, 0);
            GLES20.glBindTexture(GLES20.GL_TEXTURE_2D, texId[0]);
            GLES20.glTexParameteri(GLES20.GL_TEXTURE_2D,
                GLES20.GL_TEXTURE_MIN_FILTER, GLES20.GL_LINEAR_MIPMAP_LINEAR);
            GLES20.glTexParameteri(GLES20.GL_TEXTURE_2D,
                GLES20.GL_TEXTURE_MAG_FILTER, GLES20.GL_LINEAR);
            GLUtils.texImage2D(GLES20.GL_TEXTURE_2D, 0, bmp, 0);
            GLES20.glGenerateMipmap(GLES20.GL_TEXTURE_2D); // smooth at distance
            bmp.recycle();

            BlockData bd      = new BlockData();
            bd.pinnedAnchor   = pa;
            bd.textureId      = texId;
            bd.widthMeters    = widthM;
            bd.heightMeters   = heightM;
            bd.translated     = input.translated.get(i);
            blocks.add(bd);
        }
    }

    /**
     * Fallback: no plane detected — place quad at estimated depth
     * in front of camera, use camera's surface orientation as approximation.
     */
    private SurfacePinner.PinnedAnchor createFallbackAnchor(
            Frame frame, float screenX, float screenY,
            int viewW, int viewH, float depth) {
        try {
            com.google.ar.core.Pose camPose = frame.getCamera().getPose();
            float[] t   = camPose.getTranslation();
            float[] fwd = camPose.getZAxis();

            com.google.ar.core.Pose anchorPose =
                com.google.ar.core.Pose.makeTranslation(
                    t[0] - fwd[0] * depth,
                    t[1] - fwd[1] * depth,
                    t[2] - fwd[2] * depth);

            SurfacePinner.PinnedAnchor pa = new SurfacePinner.PinnedAnchor();
            pa.anchor = arSession.createAnchor(anchorPose);

            // Use camera forward as surface normal approximation
            pa.planeNormal = new float[]{-fwd[0], -fwd[1], -fwd[2]};

            // Derive right and up from camera
            float[] right = camPose.getXAxis();
            float[] up    = camPose.getYAxis();
            pa.planeRight  = new float[]{right[0], right[1], right[2]};
            pa.planeUp     = new float[]{up[0], up[1], up[2]};

            float[] m = new float[16];
            pa.anchor.getPose().toMatrix(m, 0);
            pa.surfaceMatrix = SurfacePinner.buildSurfaceMatrix(pa.anchor, pa);

            return pa;
        } catch (Exception e) {
            Log.e(TAG, "Fallback anchor failed", e);
            return null;
        }
    }

    private float translationDrift(float[] a, float[] b) {
        float dx = a[12]-b[12], dy = a[13]-b[13], dz = a[14]-b[14];
        return (float) Math.sqrt(dx*dx + dy*dy + dz*dz);
    }

    public void clearAll() {
        for (BlockData b : blocks) {
            if (b.pinnedAnchor != null && b.pinnedAnchor.anchor != null)
                b.pinnedAnchor.anchor.detach();
            GLES20.glDeleteTextures(1, b.textureId, 0);
        }
        blocks.clear();
        pendingPlacement = null;
        planeFound = false;
    }
}
