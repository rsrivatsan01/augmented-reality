## `LockedQuadRenderer.java` — Renders quad flush on surface with correct scaling
```java
package com.yourapp;

import android.opengl.GLES20;
import android.opengl.Matrix;

import java.nio.ByteBuffer;
import java.nio.ByteOrder;
import java.nio.FloatBuffer;
import java.nio.ShortBuffer;

/**
 * Renders a textured quad that:
 * 1. Is scaled in world-space metres (not screen pixels)
 * 2. Is aligned to surface normal (not camera)
 * 3. Sits flush on the surface (depth-pinned)
 * 4. Does NOT rotate when phone rotates
 */
public class LockedQuadRenderer {

    // Quad corners: unit square in local space
    // X = right along surface, Y = up along surface
    // Z = 0 (flat on surface)
    private static final float[] VERTICES = {
        -0.5f,  0f, -0.25f,   0f, 0f,  // top-left
        -0.5f,  0f,  0.25f,   0f, 1f,  // bottom-left
         0.5f,  0f,  0.25f,   1f, 1f,  // bottom-right
         0.5f,  0f, -0.25f,   1f, 0f,  // top-right
    };
    private static final short[] INDICES = {0, 1, 2, 0, 2, 3};

    private FloatBuffer vertexBuffer;
    private ShortBuffer indexBuffer;

    private final int program;
    private final int uMVP, uTex, uAlpha;
    private final int aPos, aUV;

    private static final String VS =
        "uniform mat4 u_MVP;\n" +
        "attribute vec4 a_Pos;\n" +
        "attribute vec2 a_UV;\n" +
        "varying vec2 v_UV;\n" +
        "void main(){\n" +
        "  gl_Position = u_MVP * a_Pos;\n" +
        "  v_UV = a_UV;\n" +
        "}\n";

    private static final String FS =
        "precision mediump float;\n" +
        "uniform sampler2D u_Tex;\n" +
        "uniform float u_Alpha;\n" +
        "varying vec2 v_UV;\n" +
        "void main(){\n" +
        "  vec4 c = texture2D(u_Tex, v_UV);\n" +
        // Discard near-transparent pixels — sharp edges, no halo
        "  if(c.a * u_Alpha < 0.05) discard;\n" +
        "  gl_FragColor = vec4(c.rgb, c.a * u_Alpha);\n" +
        "}\n";

    public LockedQuadRenderer() {
        // Build vertex buffer
        ByteBuffer vbb = ByteBuffer.allocateDirect(VERTICES.length * 4);
        vbb.order(ByteOrder.nativeOrder());
        vertexBuffer = vbb.asFloatBuffer();
        vertexBuffer.put(VERTICES).position(0);

        // Build index buffer
        ByteBuffer ibb = ByteBuffer.allocateDirect(INDICES.length * 2);
        ibb.order(ByteOrder.nativeOrder());
        indexBuffer = ibb.asShortBuffer();
        indexBuffer.put(INDICES).position(0);

        // Compile shaders
        int vs = compileShader(GLES20.GL_VERTEX_SHADER,   VS);
        int fs = compileShader(GLES20.GL_FRAGMENT_SHADER, FS);
        program = GLES20.glCreateProgram();
        GLES20.glAttachShader(program, vs);
        GLES20.glAttachShader(program, fs);
        GLES20.glLinkProgram(program);

        uMVP   = GLES20.glGetUniformLocation(program, "u_MVP");
        uTex   = GLES20.glGetUniformLocation(program, "u_Tex");
        uAlpha = GLES20.glGetUniformLocation(program, "u_Alpha");
        aPos   = GLES20.glGetAttribLocation(program,  "a_Pos");
        aUV    = GLES20.glGetAttribLocation(program,  "a_UV");
    }

    /**
     * Draw a single locked quad.
     *
     * @param surfaceMatrix  4×4 model matrix aligned to real surface
     * @param viewMatrix     ARCore camera view matrix
     * @param projMatrix     ARCore projection matrix
     * @param textureId      GL texture ID of the translated billboard
     * @param widthMeters    real-world width of the text block
     * @param heightMeters   real-world height of the text block
     * @param alpha          fade-in value 0→1
     * @param cameraPos      world position of camera (for z-offset)
     * @param planeNormal    surface normal (for z-offset direction)
     */
    public void draw(float[] surfaceMatrix,
                     float[] viewMatrix,
                     float[] projMatrix,
                     int     textureId,
                     float   widthMeters,
                     float   heightMeters,
                     float   alpha,
                     float[] cameraPos,
                     float[] planeNormal) {

        // Apply z-offset to sit flush, not float
        float[] pinnedMatrix = DepthPinner.applyZOffset(
            surfaceMatrix, planeNormal, cameraPos);

        // Scale to real-world dimensions
        float[] scaleMatrix = new float[16];
        Matrix.setIdentityM(scaleMatrix, 0);
        Matrix.scaleM(scaleMatrix, 0,
            widthMeters,       // X: width along surface
            1f,                // Y: flat on surface (no thickness)
            heightMeters);     // Z: height along surface

        float[] modelMatrix = new float[16];
        Matrix.multiplyMM(modelMatrix, 0, pinnedMatrix, 0, scaleMatrix, 0);

        // MVP
        float[] mv  = new float[16];
        float[] mvp = new float[16];
        Matrix.multiplyMM(mv,  0, viewMatrix, 0, modelMatrix, 0);
        Matrix.multiplyMM(mvp, 0, projMatrix, 0, mv,          0);

        // Draw
        GLES20.glUseProgram(program);

        GLES20.glUniformMatrix4fv(uMVP, 1, false, mvp, 0);
        GLES20.glUniform1f(uAlpha, alpha);

        GLES20.glActiveTexture(GLES20.GL_TEXTURE0);
        GLES20.glBindTexture(GLES20.GL_TEXTURE_2D, textureId);
        GLES20.glUniform1i(uTex, 0);

        int stride = 5 * 4;
        vertexBuffer.position(0);
        GLES20.glEnableVertexAttribArray(aPos);
        GLES20.glVertexAttribPointer(aPos, 3,
            GLES20.GL_FLOAT, false, stride, vertexBuffer);

        vertexBuffer.position(3);
        GLES20.glEnableVertexAttribArray(aUV);
        GLES20.glVertexAttribPointer(aUV, 2,
            GLES20.GL_FLOAT, false, stride, vertexBuffer);

        indexBuffer.position(0);
        GLES20.glDrawElements(GLES20.GL_TRIANGLES, 6,
            GLES20.GL_UNSIGNED_SHORT, indexBuffer);

        GLES20.glDisableVertexAttribArray(aPos);
        GLES20.glDisableVertexAttribArray(aUV);
    }

    private int compileShader(int type, String src) {
        int s = GLES20.glCreateShader(type);
        GLES20.glShaderSource(s, src);
        GLES20.glCompileShader(s);
        return s;
    }
}
