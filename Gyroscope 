## `DepthPinner.java` — Prevents floating using ARCore depth
```java
package com.yourapp;

import com.google.ar.core.Frame;
import com.google.ar.core.HitResult;
import com.google.ar.core.Plane;
import com.google.ar.core.Pose;
import com.google.ar.core.TrackingState;

import java.util.List;

/**
 * Uses ARCore's hit-test depth to push the overlay
 * exactly onto the real surface — eliminates floating.
 *
 * Also applies a tiny offset (1mm) toward camera
 * so the texture doesn't z-fight with the plane.
 */
public class DepthPinner {

    private static final float Z_OFFSET = 0.001f; // 1mm toward camera

    /**
     * Given a surface matrix, nudges the translation
     * along the plane normal by Z_OFFSET toward the camera.
     * This prevents z-fighting (texture flickering on surface).
     */
    public static float[] applyZOffset(float[] surfaceMatrix,
                                        float[] planeNormal,
                                        float[] cameraPos) {
        float[] result = surfaceMatrix.clone();

        // Direction from surface to camera
        float dx = cameraPos[0] - surfaceMatrix[12];
        float dy = cameraPos[1] - surfaceMatrix[13];
        float dz = cameraPos[2] - surfaceMatrix[14];
        float len = (float) Math.sqrt(dx*dx + dy*dy + dz*dz);

        if (len < 0.001f) return result;

        // Nudge toward camera by Z_OFFSET
        result[12] += (dx / len) * Z_OFFSET;
        result[13] += (dy / len) * Z_OFFSET;
        result[14] += (dz / len) * Z_OFFSET;

        return result;
    }

    /**
     * Refines anchor depth using multiple hit-tests around the text block.
     * Returns average depth in metres from camera.
     * Used to scale the billboard correctly.
     */
    public static float estimateDepth(Frame frame,
                                       float cx, float cy,
                                       float blockW, float blockH,
                                       int viewW, int viewH) {
        float[] testX = {cx - blockW*0.3f, cx, cx + blockW*0.3f};
        float[] testY = {cy - blockH*0.3f, cy, cy + blockH*0.3f};

        float totalDepth = 0f;
        int   hitCount   = 0;

        for (float tx : testX) {
            for (float ty : testY) {
                float sx = Math.max(0, Math.min(viewW, tx));
                float sy = Math.max(0, Math.min(viewH, ty));

                try {
                    List<HitResult> hits = frame.hitTest(sx, sy);
                    for (HitResult hit : hits) {
                        if (hit.getTrackable() instanceof Plane) {
                            Plane p = (Plane) hit.getTrackable();
                            if (p.getTrackingState() == TrackingState.TRACKING) {
                                totalDepth += hit.getDistance();
                                hitCount++;
                                break;
                            }
                        }
                    }
                } catch (Exception ignored) {}
            }
        }

        return hitCount > 0 ? totalDepth / hitCount : 0.5f;
    }
}
