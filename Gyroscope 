## `SurfacePinner.java` — Stores plane normal per anchor for true surface alignment
```java
package com.yourapp;

import com.google.ar.core.Anchor;
import com.google.ar.core.Frame;
import com.google.ar.core.HitResult;
import com.google.ar.core.Plane;
import com.google.ar.core.Pose;
import com.google.ar.core.Session;
import com.google.ar.core.TrackingState;

import java.util.List;

/**
 * Creates anchors that are permanently aligned to the detected plane.
 * Stores the plane's normal vector so the overlay quad can be rendered
 * flush against the real surface — not floating or rotating with phone.
 */
public class SurfacePinner {

    public static class PinnedAnchor {
        public Anchor anchor;
        public float[] planeNormal;   // world-space normal of the surface
        public float[] planeRight;    // right vector along the surface
        public float[] planeUp;       // up vector along the surface
        public float[] surfaceMatrix; // pre-built 4×4 for rendering

        // Frozen once confidence is high
        public float[] frozenMatrix;
        public boolean frozen = false;
    }

    /**
     * Hit-test at screenX/screenY and return a PinnedAnchor
     * that carries the plane's orientation, not the camera's.
     */
    public static PinnedAnchor create(Frame frame, Session session,
                                       float screenX, float screenY) {
        try {
            List<HitResult> hits = frame.hitTest(screenX, screenY);

            for (HitResult hit : hits) {
                if (!(hit.getTrackable() instanceof Plane)) continue;

                Plane plane = (Plane) hit.getTrackable();
                if (plane.getTrackingState() != TrackingState.TRACKING) continue;
                if (plane.getSubsumedBy() != null) continue;

                Anchor anchor = hit.createAnchor();
                PinnedAnchor pa = new PinnedAnchor();
                pa.anchor = anchor;

                // ── Extract plane orientation ──────────────────────────────
                // ARCore plane pose: Y axis = plane normal (points away from surface)
                Pose planePose = plane.getCenterPose();
                float[] poseMatrix = new float[16];
                planePose.toMatrix(poseMatrix, 0);

                // Y column = normal (indices 4,5,6)
                pa.planeNormal = new float[]{
                    poseMatrix[4], poseMatrix[5], poseMatrix[6]};

                // X column = right along surface (indices 0,1,2)
                pa.planeRight  = new float[]{
                    poseMatrix[0], poseMatrix[1], poseMatrix[2]};

                // Z column = up along surface (indices 8,9,10)
                pa.planeUp     = new float[]{
                    poseMatrix[8], poseMatrix[9], poseMatrix[10]};

                // Build surface-aligned model matrix immediately
                pa.surfaceMatrix = buildSurfaceMatrix(anchor, pa);

                return pa;
            }

        } catch (Exception e) {
            android.util.Log.e("SurfacePinner", "Hit test failed: " + e);
        }

        return null;
    }

    /**
     * Builds a 4×4 model matrix that:
     * 1. Positions the quad at the anchor's world position
     * 2. Aligns the quad's normal to the plane's normal
     * 3. Does NOT depend on camera orientation at all
     *
     * This means rotating the phone does nothing to the overlay.
     */
    public static float[] buildSurfaceMatrix(Anchor anchor, PinnedAnchor pa) {
        float[] anchorMatrix = new float[16];
        anchor.getPose().toMatrix(anchorMatrix, 0);

        float[] m = new float[16];

        // Column 0: right vector of plane (X axis of quad)
        m[0]  = pa.planeRight[0];
        m[1]  = pa.planeRight[1];
        m[2]  = pa.planeRight[2];
        m[3]  = 0f;

        // Column 1: normal of plane (Y axis — quad faces this direction)
        m[4]  = pa.planeNormal[0];
        m[5]  = pa.planeNormal[1];
        m[6]  = pa.planeNormal[2];
        m[7]  = 0f;

        // Column 2: up along plane (Z axis of quad)
        m[8]  = pa.planeUp[0];
        m[9]  = pa.planeUp[1];
        m[10] = pa.planeUp[2];
        m[11] = 0f;

        // Column 3: world position from anchor
        m[12] = anchorMatrix[12];
        m[13] = anchorMatrix[13];
        m[14] = anchorMatrix[14];
        m[15] = 1f;

        return m;
    }

    /**
     * Call every frame pre-lock. Updates translation from anchor
     * but keeps rotation locked to plane normal.
     */
    public static float[] updateMatrix(PinnedAnchor pa) {
        if (pa.frozen) return pa.frozenMatrix;
        if (pa.anchor == null ||
            pa.anchor.getTrackingState() != TrackingState.TRACKING) {
            return pa.surfaceMatrix;
        }

        // Only update translation — rotation stays fixed to plane
        float[] anchorMatrix = new float[16];
        pa.anchor.getPose().toMatrix(anchorMatrix, 0);

        pa.surfaceMatrix[12] = anchorMatrix[12];
        pa.surfaceMatrix[13] = anchorMatrix[13];
        pa.surfaceMatrix[14] = anchorMatrix[14];

        return pa.surfaceMatrix;
    }

    /** Freeze the matrix permanently — detach anchor */
    public static void freeze(PinnedAnchor pa) {
        pa.frozenMatrix = pa.surfaceMatrix.clone();
        pa.frozen = true;
        if (pa.anchor != null) {
            pa.anchor.detach();
            pa.anchor = null;
        }
    }
}
