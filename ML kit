## `TextOverlayView.java` — Custom View that draws AR-style text labels
```java
package com.yourapp;

import android.content.Context;
import android.graphics.*;
import android.util.AttributeSet;
import android.view.View;

import com.google.mlkit.vision.text.Text;

import java.util.ArrayList;
import java.util.List;

/**
 * Transparent overlay drawn on top of the camera preview.
 * Draws each detected text block exactly where it appears in the image.
 */
public class TextOverlayView extends View {

    // Each detected result mapped to screen coordinates
    private final List<TextBlock> blocks = new ArrayList<>();

    // Image dimensions (used for coordinate scaling)
    private int imageWidth = 1;
    private int imageHeight = 1;

    // Paints
    private final Paint boxPaint;
    private final Paint textBgPaint;
    private final Paint textPaint;
    private final Paint cornerPaint;

    public static class TextBlock {
        public RectF bounds;
        public String text;
        public TextBlock(RectF bounds, String text) {
            this.bounds = bounds;
            this.text = text;
        }
    }

    public TextOverlayView(Context context, AttributeSet attrs) {
        super(context, attrs);

        // Bounding box stroke
        boxPaint = new Paint();
        boxPaint.setStyle(Paint.Style.STROKE);
        boxPaint.setColor(Color.parseColor("#00E5FF")); // cyan
        boxPaint.setStrokeWidth(3f);
        boxPaint.setAntiAlias(true);

        // Corner accent paint
        cornerPaint = new Paint();
        cornerPaint.setStyle(Paint.Style.STROKE);
        cornerPaint.setColor(Color.parseColor("#00E5FF"));
        cornerPaint.setStrokeWidth(6f);
        cornerPaint.setStrokeCap(Paint.Cap.ROUND);
        cornerPaint.setAntiAlias(true);

        // Text background pill
        textBgPaint = new Paint();
        textBgPaint.setStyle(Paint.Style.FILL);
        textBgPaint.setColor(Color.parseColor("#CC001F3F")); // dark blue 80% opacity
        textBgPaint.setAntiAlias(true);

        // Text label
        textPaint = new Paint();
        textPaint.setColor(Color.WHITE);
        textPaint.setTextSize(32f);
        textPaint.setTypeface(Typeface.create(Typeface.MONOSPACE, Typeface.BOLD));
        textPaint.setAntiAlias(true);
    }

    /**
     * Called from MainActivity after ML Kit returns results.
     * Pass the original image size so we can scale coordinates to screen.
     */
    public void setResults(Text mlKitResult, int imgWidth, int imgHeight) {
        blocks.clear();
        imageWidth = imgWidth;
        imageHeight = imgHeight;

        for (Text.TextBlock block : mlKitResult.getTextBlocks()) {
            if (block.getBoundingBox() == null) continue;

            Rect box = block.getBoundingBox();
            // Scale from image coords → view coords (done in onDraw)
            blocks.add(new TextBlock(
                new RectF(box.left, box.top, box.right, box.bottom),
                block.getText()
            ));
        }

        invalidate(); // triggers onDraw
    }

    public void clear() {
        blocks.clear();
        invalidate();
    }

    @Override
    protected void onDraw(Canvas canvas) {
        super.onDraw(canvas);
        if (blocks.isEmpty()) return;

        float scaleX = (float) getWidth()  / imageWidth;
        float scaleY = (float) getHeight() / imageHeight;

        for (TextBlock block : blocks) {
            // Scale bounding box to screen
            RectF scaled = new RectF(
                block.bounds.left   * scaleX,
                block.bounds.top    * scaleY,
                block.bounds.right  * scaleX,
                block.bounds.bottom * scaleY
            );

            // Draw bounding box
            canvas.drawRoundRect(scaled, 8f, 8f, boxPaint);

            // Draw corner accents (AR style)
            drawCornerAccents(canvas, scaled);

            // Draw text label above the box
            drawTextLabel(canvas, block.text, scaled);
        }
    }

    /** Draws short L-shaped lines at each corner for that AR scanner look */
    private void drawCornerAccents(Canvas canvas, RectF r) {
        float len = 28f;

        // Top-left
        canvas.drawLine(r.left, r.top, r.left + len, r.top, cornerPaint);
        canvas.drawLine(r.left, r.top, r.left, r.top + len, cornerPaint);

        // Top-right
        canvas.drawLine(r.right, r.top, r.right - len, r.top, cornerPaint);
        canvas.drawLine(r.right, r.top, r.right, r.top + len, cornerPaint);

        // Bottom-left
        canvas.drawLine(r.left, r.bottom, r.left + len, r.bottom, cornerPaint);
        canvas.drawLine(r.left, r.bottom, r.left, r.bottom - len, cornerPaint);

        // Bottom-right
        canvas.drawLine(r.right, r.bottom, r.right - len, r.bottom, cornerPaint);
        canvas.drawLine(r.right, r.bottom, r.right, r.bottom - len, cornerPaint);
    }

    /** Draws a pill background + text label just above the bounding box */
    private void drawTextLabel(Canvas canvas, String text, RectF box) {
        // Truncate long text for the overlay label
        String label = text.replace("\n", " ");
        if (label.length() > 40) label = label.substring(0, 40) + "…";

        float textWidth  = textPaint.measureText(label);
        float textHeight = textPaint.getTextSize();
        float padding    = 10f;
        float radius     = 12f;

        float bgLeft   = box.left;
        float bgTop    = box.top - textHeight - padding * 2 - 4f;
        float bgRight  = bgLeft + textWidth + padding * 2;
        float bgBottom = box.top - 4f;

        // Keep label within screen bounds
        if (bgTop < 0) bgTop = box.bottom + 4f;
        if (bgRight > getWidth()) {
            bgLeft  = getWidth() - textWidth - padding * 2;
            bgRight = getWidth();
        }

        RectF bgRect = new RectF(bgLeft, bgTop, bgRight, bgBottom);
        canvas.drawRoundRect(bgRect, radius, radius, textBgPaint);
        canvas.drawText(label, bgLeft + padding, bgBottom - padding, textPaint);
    }
}
