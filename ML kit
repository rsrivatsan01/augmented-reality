## `TextDetectionProcessor.java` — ML Kit wrapper
```java
package com.yourapp;

import android.graphics.Bitmap;

import com.google.mlkit.vision.common.InputImage;
import com.google.mlkit.vision.text.Text;
import com.google.mlkit.vision.text.TextRecognition;
import com.google.mlkit.vision.text.TextRecognizer;
import com.google.mlkit.vision.text.latin.TextRecognizerOptions;

public class TextDetectionProcessor {

    public interface ResultCallback {
        void onSuccess(Text result, int imageWidth, int imageHeight);
        void onFailure(Exception e);
    }

    private final TextRecognizer recognizer;

    public TextDetectionProcessor() {
        // Latin script — swap for ChineseTextRecognizerOptions etc. if needed
        recognizer = TextRecognition.getClient(TextRecognizerOptions.DEFAULT_OPTIONS);
    }

    /** Run ML Kit on a captured bitmap. Callback fires on main thread. */
    public void process(Bitmap bitmap, ResultCallback callback) {
        InputImage image = InputImage.fromBitmap(bitmap, 0);

        recognizer.process(image)
            .addOnSuccessListener(result ->
                callback.onSuccess(result, bitmap.getWidth(), bitmap.getHeight()))
            .addOnFailureListener(callback::onFailure);
    }

    public void close() {
        recognizer.close();
    }
}
