package com.yourapp;

import android.content.Context;
import android.graphics.Canvas;
import android.graphics.Color;
import android.graphics.Paint;
import android.graphics.RectF;
import android.util.AttributeSet;
import android.util.Log;
import android.view.View;

import java.util.ArrayList;
import java.util.List;

/**
 * Transparent view drawn on top of GLSurfaceView.
 * Shows:
 * - Green box: ML Kit raw bounding box (before coordinate fix)
 * - Cyan box:  corrected screen-space bounding box (after fix)
 * - Red dot:   ARCore hit-test point sent to plane detection
 * - Yellow text: debug values per block
 */
public class DebugOverlayView extends View {

    private static final String TAG = "DebugOverlay";

    public static class DebugBlock {
        public RectF rawBounds;       // from ML Kit, raw image coords
        public RectF correctedBounds; // after coordinate transform
        public float hitX, hitY;      // screen point sent to ARCore
        public String label;          // block text + translation
        public boolean locked;
        public float confidence;
    }

    private final List<DebugBlock> debugBlocks = new ArrayList<>();

    // Paints
    private final Paint rawPaint       = new Paint();
    private final Paint correctedPaint = new Paint();
    private final Paint hitPaint       = new Paint();
    private final Paint textPaint      = new Paint();
    private final Paint lockedPaint    = new Paint();
    private final Paint bgPaint        = new Paint();

    // Screen info
    private int screenW, screenH;
    private int imageW,  imageH;  // ML Kit image dimensions

    public DebugOverlayView(Context context, AttributeSet attrs) {
        super(context, attrs);
        setWillNotDraw(false);

        rawPaint.setStyle(Paint.Style.STROKE);
        rawPaint.setColor(Color.GREEN);
        rawPaint.setStrokeWidth(4f);
        rawPaint.setAntiAlias(true);

        correctedPaint.setStyle(Paint.Style.STROKE);
        correctedPaint.setColor(Color.CYAN);
        correctedPaint.setStrokeWidth(4f);
        correctedPaint.setAntiAlias(true);

        hitPaint.setStyle(Paint.Style.FILL);
        hitPaint.setColor(Color.RED);
        hitPaint.setAntiAlias(true);

        textPaint.setColor(Color.WHITE);
        textPaint.setTextSize(28f);
        textPaint.setAntiAlias(true);

        lockedPaint.setStyle(Paint.Style.FILL);
        lockedPaint.setColor(Color.parseColor("#AA00FF00"));
        lockedPaint.setAntiAlias(true);

        bgPaint.setColor(Color.argb(140, 0, 0, 0));
    }

    public void setDebugBlocks(List<DebugBlock> blocks,
                                int screenW, int screenH,
                                int imageW,  int imageH) {
        this.debugBlocks.clear();
        this.debugBlocks.addAll(blocks);
        this.screenW = screenW;
        this.screenH = screenH;
        this.imageW  = imageW;
        this.imageH  = imageH;

        Log.d(TAG, "=== DEBUG UPDATE ===");
        Log.d(TAG, "Screen: " + screenW + "x" + screenH);
        Log.d(TAG, "Image:  " + imageW  + "x" + imageH);
        for (DebugBlock b : blocks) {
            Log.d(TAG, "Block raw="     + rectStr(b.rawBounds)
                     + " corrected="    + rectStr(b.correctedBounds)
                     + " hit=("         + b.hitX + "," + b.hitY + ")"
                     + " locked="       + b.locked
                     + " label="        + b.label);
        }

        invalidate();
    }

    public void clear() {
        debugBlocks.clear();
        invalidate();
    }

    @Override
    protected void onDraw(Canvas canvas) {
        super.onDraw(canvas);
        if (debugBlocks.isEmpty()) return;

        for (DebugBlock b : debugBlocks) {

            // ── Green: raw ML Kit box (probably wrong position) ───────────
            if (b.rawBounds != null) {
                canvas.drawRect(b.rawBounds, rawPaint);
                drawLabel(canvas, "RAW", b.rawBounds.left, b.rawBounds.top - 4f,
                    Color.GREEN);
            }

            // ── Cyan: corrected screen-space box ──────────────────────────
            if (b.correctedBounds != null) {
                canvas.drawRect(b.correctedBounds, correctedPaint);
                if (b.locked) {
                    canvas.drawRect(b.correctedBounds, lockedPaint);
                }
                drawLabel(canvas, "FIXED", b.correctedBounds.left,
                    b.correctedBounds.top - 28f, Color.CYAN);
            }

            // ── Red dot: ARCore hit-test point ────────────────────────────
            canvas.drawCircle(b.hitX, b.hitY, 12f, hitPaint);
            drawLabel(canvas,
                "HIT (" + (int)b.hitX + "," + (int)b.hitY + ")",
                b.hitX + 16f, b.hitY, Color.RED);

            // ── Yellow: block label ───────────────────────────────────────
            if (b.correctedBounds != null) {
                drawLabel(canvas, b.label,
                    b.correctedBounds.left,
                    b.correctedBounds.bottom + 32f,
                    Color.YELLOW);

                // Confidence ring
                String conf = b.locked ? "LOCKED" :
                    "conf: " + (int)(b.confidence * 100) + "%";
                drawLabel(canvas, conf,
                    b.correctedBounds.left,
                    b.correctedBounds.bottom + 60f,
                    b.locked ? Color.GREEN : Color.YELLOW);
            }
        }

        // ── Legend ────────────────────────────────────────────────────────
        float ly = 80f;
        drawLabel(canvas, "█ GREEN  = ML Kit raw box", 20f, ly, Color.GREEN);
        drawLabel(canvas, "█ CYAN   = corrected box",  20f, ly+34f, Color.CYAN);
        drawLabel(canvas, "● RED    = ARCore hit pt",  20f, ly+68f, Color.RED);
        drawLabel(canvas, "■ YELLOW = label/conf",     20f, ly+102f, Color.YELLOW);
    }

    private void drawLabel(Canvas c, String text, float x, float y, int color) {
        if (text == null) return;
        float tw = textPaint.measureText(text);
        c.drawRect(x - 2f, y - textPaint.getTextSize(),
            x + tw + 4f, y + 4f, bgPaint);
        textPaint.setColor(color);
        c.drawText(text, x, y, textPaint);
    }

    private String rectStr(RectF r) {
        if (r == null) return "null";
        return String.format("(%.0f,%.0f,%.0f,%.0f)",
            r.left, r.top, r.right, r.bottom);
    }
}
