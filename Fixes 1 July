## `CoordinateMapper.java` — The actual fix: maps ML Kit image coords → screen coords
```java
package com.yourapp;

import android.graphics.RectF;
import android.util.Log;

/**
 * ML Kit text recognition returns bounding boxes in IMAGE coordinates.
 * In portrait mode, the camera image is rotated 90° relative to the screen.
 *
 * ARCore's hit-test expects SCREEN coordinates.
 *
 * This class does the exact transformation:
 *
 * Portrait mode (rotation = 90°):
 *   Image W = screen H
 *   Image H = screen W
 *   screenX = imageY * (screenW / imageH)
 *   screenY = (imageW - imageX) * (screenH / imageW)
 *
 * We also clamp to screen bounds and log everything for debugging.
 */
public class CoordinateMapper {

    private static final String TAG = "CoordMapper";

    public static class MappedBounds {
        public RectF screen;   // corrected screen-space bounds
        public float hitX;     // centre X for ARCore hit-test
        public float hitY;     // centre Y for ARCore hit-test
    }

    /**
     * @param imageBounds  Raw bounding box from ML Kit (image pixel coords)
     * @param imageW       Width of image ML Kit processed
     * @param imageH       Height of image ML Kit processed
     * @param screenW      GLSurfaceView width
     * @param screenH      GLSurfaceView height
     * @param sensorRotation  degrees: 0, 90, 180, 270
     */
    public static MappedBounds map(RectF imageBounds,
                                    int imageW, int imageH,
                                    int screenW, int screenH,
                                    int sensorRotation) {

        Log.d(TAG, "map() imageBounds=" + imageBounds
            + " imageSize=" + imageW + "x" + imageH
            + " screenSize=" + screenW + "x" + screenH
            + " rotation=" + sensorRotation);

        float left, top, right, bottom;

        switch (sensorRotation) {
            case 90:
                // Portrait: image is rotated 90° clockwise relative to screen
                // image X → screen Y (inverted)
                // image Y → screen X
                left   = imageBounds.top   * screenW / imageH;
                top    = (imageW - imageBounds.right)  * screenH / imageW;
                right  = imageBounds.bottom * screenW / imageH;
                bottom = (imageW - imageBounds.left)   * screenH / imageW;
                break;

            case 270:
                // Reverse portrait
                left   = (imageH - imageBounds.bottom) * screenW / imageH;
                top    = imageBounds.left  * screenH / imageW;
                right  = (imageH - imageBounds.top)    * screenW / imageH;
                bottom = imageBounds.right * screenH / imageW;
                break;

            case 180:
                // Upside down
                left   = (imageW - imageBounds.right)  * screenW / imageW;
                top    = (imageH - imageBounds.bottom) * screenH / imageH;
                right  = (imageW - imageBounds.left)   * screenW / imageW;
                bottom = (imageH - imageBounds.top)    * screenH / imageH;
                break;

            default: // 0 — landscape, direct scale
                left   = imageBounds.left   * screenW / imageW;
                top    = imageBounds.top    * screenH / imageH;
                right  = imageBounds.right  * screenW / imageW;
                bottom = imageBounds.bottom * screenH / imageH;
                break;
        }

        // Clamp to screen
        left   = Math.max(0, Math.min(screenW, left));
        top    = Math.max(0, Math.min(screenH, top));
        right  = Math.max(0, Math.min(screenW, right));
        bottom = Math.max(0, Math.min(screenH, bottom));

        // Sanity check
        if (right <= left || bottom <= top) {
            Log.w(TAG, "Degenerate bounds after mapping — skipping block");
            return null;
        }

        MappedBounds result = new MappedBounds();
        result.screen = new RectF(left, top, right, bottom);
        result.hitX   = (left + right)  / 2f;
        result.hitY   = (top  + bottom) / 2f;

        Log.d(TAG, "map() → screen=" + result.screen
            + " hit=(" + result.hitX + "," + result.hitY + ")");

        return result;
    }

    /**
     * Gets the camera sensor rotation for portrait mode.
     * Usually 90 on Android phones.
     */
    public static int getSensorRotation(android.app.Activity activity) {
        // Get display rotation
        int displayRotation = activity.getWindowManager()
            .getDefaultDisplay().getRotation();

        // For portrait-locked apps on standard phones, sensor is 90°
        // We detect this from the relationship between display rotation
        // and the image dimensions returned by ML Kit
        int rot = displayRotation * 90;

        Log.d(TAG, "getSensorRotation() displayRotation=" + displayRotation
            + " → sensorRotation=" + rot);

        return rot;
    }
}
