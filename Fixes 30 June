## Fix 1: `BitmapAnalyzer.java` — Robust colour detection that doesn't fail on low contrast

The core problem: sampling a thin 6px border assumes background is uniform right next to the text. When background = text colour, this completely breaks. Fix: use **variance-based edge detection** instead of colour-difference, and widen the sample area with outlier rejection.

```java
package com.yourapp;

import android.graphics.Bitmap;
import android.graphics.Color;
import android.graphics.Rect;

import java.util.ArrayList;
import java.util.Collections;
import java.util.List;

/**
 * Robust colour + style analyzer.
 * Handles low-contrast cases (text colour ≈ background colour) by:
 * 1. Using LOCAL CONTRAST (gradient magnitude) instead of absolute colour
 *    difference to separate text from background — works even when hues match
 * 2. Sampling a WIDER border ring with median (not mean) to reject outliers
 * 3. Falling back to ML Kit's own box geometry confidence when sampling fails
 */
public class BitmapAnalyzer {

    public static void analyze(Bitmap bmp, TextBlock block) {
        Rect r = new Rect(
            (int) block.bitmapBounds.left,
            (int) block.bitmapBounds.top,
            (int) block.bitmapBounds.right,
            (int) block.bitmapBounds.bottom);

        r.left   = Math.max(0, r.left);
        r.top    = Math.max(0, r.top);
        r.right  = Math.min(bmp.getWidth()  - 1, r.right);
        r.bottom = Math.min(bmp.getHeight() - 1, r.bottom);

        if (r.isEmpty() || r.width() < 4 || r.height() < 4) {
            fallback(block);
            return;
        }

        // ── 1. Wide border ring sample (12px) with MEDIAN not mean ─────────
        block.bgColor = sampleBorderMedian(bmp, r, 12);

        // ── 2. Gradient-based text/background separation ───────────────────
        // Instead of "is this pixel different from bgColor", we check
        // "is this pixel part of a high local-contrast edge cluster"
        GradientResult grad = analyzeGradients(bmp, r);

        if (grad.confident) {
            block.textColor = grad.textColor;
            block.fontSizePx = estimateFontSize(r, grad.lineCount);
            block.isBold     = grad.avgStrokeWidth > grad.estimatedFontSize * 0.12f;
        } else {
            // ── 3. LOW CONTRAST FALLBACK ────────────────────────────────────
            // Can't reliably separate text from background.
            // Use a synthetic high-contrast colour instead of guessing wrong.
            block.textColor = pickReadableContrast(block.bgColor);
            block.fontSizePx = (r.height() / 1.4f); // assume single line, generous
            block.fontSizePx = Math.max(16f, Math.min(120f, block.fontSizePx));
            block.isBold     = false;
        }
    }

    // ── Border sampling with median (robust to outlier pixels) ─────────────

    private static int sampleBorderMedian(Bitmap bmp, Rect r, int strip) {
        List<Integer> reds = new ArrayList<>();
        List<Integer> greens = new ArrayList<>();
        List<Integer> blues = new ArrayList<>();

        collectStrip(bmp, r.left, r.right,
            Math.max(0, r.top - strip), r.top, reds, greens, blues);
        collectStrip(bmp, r.left, r.right,
            r.bottom, Math.min(bmp.getHeight()-1, r.bottom + strip),
            reds, greens, blues);
        collectStripVertical(bmp, r.top, r.bottom,
            Math.max(0, r.left - strip), r.left, reds, greens, blues);
        collectStripVertical(bmp, r.top, r.bottom,
            r.right, Math.min(bmp.getWidth()-1, r.right + strip),
            reds, greens, blues);

        if (reds.isEmpty()) return Color.WHITE;

        Collections.sort(reds);
        Collections.sort(greens);
        Collections.sort(blues);

        int mid = reds.size() / 2;
        return Color.rgb(reds.get(mid), greens.get(mid), blues.get(mid));
    }

    private static void collectStrip(Bitmap bmp, int x0, int x1,
                                      int y0, int y1,
                                      List<Integer> r, List<Integer> g, List<Integer> b) {
        for (int x = x0; x <= x1; x += 2) {
            for (int y = y0; y < y1; y++) {
                if (x < 0 || x >= bmp.getWidth() || y < 0 || y >= bmp.getHeight()) continue;
                int px = bmp.getPixel(x, y);
                r.add(Color.red(px)); g.add(Color.green(px)); b.add(Color.blue(px));
            }
        }
    }

    private static void collectStripVertical(Bitmap bmp, int y0, int y1,
                                               int x0, int x1,
                                               List<Integer> r, List<Integer> g, List<Integer> b) {
        for (int y = y0; y <= y1; y += 2) {
            for (int x = x0; x < x1; x++) {
                if (x < 0 || x >= bmp.getWidth() || y < 0 || y >= bmp.getHeight()) continue;
                int px = bmp.getPixel(x, y);
                r.add(Color.red(px)); g.add(Color.green(px)); b.add(Color.blue(px));
            }
        }
    }

    // ── Gradient-based text detection ───────────────────────────────────────

    private static class GradientResult {
        boolean confident;
        int   textColor;
        int   lineCount;
        float avgStrokeWidth;
        float estimatedFontSize;
    }

    /**
     * Uses Sobel-like gradient magnitude to find edge pixels (text strokes)
     * regardless of whether text/background hues are similar.
     * High contrast edges = text strokes, even on similar-coloured backgrounds,
     * because anti-aliasing always creates SOME local gradient at glyph edges.
     */
    private static GradientResult analyzeGradients(Bitmap bmp, Rect r) {
        GradientResult result = new GradientResult();

        int w = r.width(), h = r.height();
        if (w < 6 || h < 6) { result.confident = false; return result; }

        // Compute gradient magnitude map
        float[][] gradMag = new float[h][w];
        float maxGrad = 0f;

        for (int y = 1; y < h - 1; y++) {
            for (int x = 1; x < w - 1; x++) {
                int px = r.left + x, py = r.top + y;

                float gx = lum(bmp.getPixel(px+1, py)) - lum(bmp.getPixel(px-1, py));
                float gy = lum(bmp.getPixel(px, py+1)) - lum(bmp.getPixel(px, py-1));
                float mag = (float) Math.sqrt(gx*gx + gy*gy);

                gradMag[y][x] = mag;
                if (mag > maxGrad) maxGrad = mag;
            }
        }

        if (maxGrad < 8f) {
            // Almost no edges detected anywhere — truly flat region,
            // ML Kit probably mis-detected this as text. Not confident.
            result.confident = false;
            return result;
        }

        // Threshold: top 25% of gradient magnitudes = edge pixels
        float threshold = maxGrad * 0.25f;

        long edgeCount = 0;
        long sumR = 0, sumG = 0, sumB = 0;

        // Track stroke widths via horizontal runs of edge-adjacent pixels
        List<Integer> runLengths = new ArrayList<>();

        for (int y = 0; y < h; y++) {
            int run = 0;
            for (int x = 0; x < w; x++) {
                boolean isEdge = gradMag[y][x] > threshold;
                if (isEdge) {
                    run++;
                    int px = bmp.getPixel(r.left + x, r.top + y);
                    sumR += Color.red(px); sumG += Color.green(px); sumB += Color.blue(px);
                    edgeCount++;
                } else if (run > 0) {
                    runLengths.add(run);
                    run = 0;
                }
            }
            if (run > 0) runLengths.add(run);
        }

        // Need a meaningful number of edge pixels to be confident
        float edgeRatio = (float) edgeCount / (w * h);
        if (edgeCount < 20 || edgeRatio < 0.015f || edgeRatio > 0.6f) {
            // Too few edges (blank) or too many (noisy texture) — not confident
            result.confident = false;
            return result;
        }

        result.confident = true;
        result.textColor = Color.rgb(
            (int)(sumR / edgeCount), (int)(sumG / edgeCount), (int)(sumB / edgeCount));

        // Stroke width = median run length
        if (!runLengths.isEmpty()) {
            Collections.sort(runLengths);
            result.avgStrokeWidth = runLengths.get(runLengths.size() / 2);
        } else {
            result.avgStrokeWidth = 3f;
        }

        // Line count: count distinct horizontal bands with edge activity
        result.lineCount = countEdgeBands(gradMag, w, h, threshold);
        result.estimatedFontSize = (h / (float) Math.max(1, result.lineCount)) * 0.75f;

        return result;
    }

    private static int countEdgeBands(float[][] gradMag, int w, int h, float threshold) {
        int bands = 0;
        boolean inBand = false;

        for (int y = 0; y < h; y++) {
            int edgePixels = 0;
            for (int x = 0; x < w; x++) {
                if (gradMag[y][x] > threshold) edgePixels++;
            }
            boolean hasEdges = edgePixels > w * 0.04f;
            if (hasEdges && !inBand) { bands++; inBand = true; }
            else if (!hasEdges)       inBand = false;
        }
        return Math.max(1, bands);
    }

    // ── Fallback when totally unreadable ────────────────────────────────────

    private static float estimateFontSize(Rect r, int lineCount) {
        float size = (r.height() / (float) Math.max(1, lineCount)) * 0.75f;
        return Math.max(16f, Math.min(120f, size));
    }

    /**
     * When we truly can't separate text from background (same colour,
     * low contrast everywhere), pick a colour that's GUARANTEED readable
     * against the sampled background — don't guess wrong, pick contrast.
     */
    private static int pickReadableContrast(int bgColor) {
        float bgLum = lum(bgColor);
        // If background is light, use dark text. If dark, use light text.
        if (bgLum > 140f) {
            // Light background — use a darkened version of bg's hue, not pure black
            return Color.rgb(
                Math.max(0, Color.red(bgColor)   - 140),
                Math.max(0, Color.green(bgColor) - 140),
                Math.max(0, Color.blue(bgColor)  - 140));
        } else {
            // Dark background — use a lightened version of bg's hue, not pure white
            return Color.rgb(
                Math.min(255, Color.red(bgColor)   + 140),
                Math.min(255, Color.green(bgColor) + 140),
                Math.min(255, Color.blue(bgColor)  + 140));
        }
    }

    private static void fallback(TextBlock block) {
        block.bgColor    = Color.WHITE;
        block.textColor  = Color.BLACK;
        block.fontSizePx = 32f;
        block.isBold     = false;
    }

    private static float lum(int color) {
        return 0.299f * Color.red(color)
             + 0.587f * Color.green(color)
             + 0.114f * Color.blue(color);
    }
}
