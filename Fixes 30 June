## Fix 2: `OverlayBitmap.java` — Add subtle outline so text stays readable even in low-confidence cases

```java
// Add this to OverlayBitmap.java — replace the text drawing Paint setup

private static void drawText(Canvas c, String text,
                              int w, int h, Paint p, boolean lowConfidence) {
    if (text == null || text.isEmpty()) return;

    float maxW  = w * 0.88f;
    float padX  = w * 0.06f;
    float lineH = p.getTextSize() * 1.22f;

    List<String> lines = new ArrayList<>();
    String[] words = text.split(" ");
    StringBuilder cur = new StringBuilder();

    for (String word : words) {
        if (word.isEmpty()) continue;
        String test = cur.length() == 0 ? word : cur + " " + word;
        if (p.measureText(test) > maxW && cur.length() > 0) {
            lines.add(cur.toString());
            cur = new StringBuilder(word);
        } else {
            cur = new StringBuilder(test);
        }
    }
    if (cur.length() > 0) lines.add(cur.toString());
    if (lines.isEmpty()) return;

    float totalH = lines.size() * lineH;
    float y = (h - totalH) / 2f + p.getTextSize();

    // ── Safety outline: only added when colour detection was uncertain ─────
    // Guarantees readability even if our background/text colour guess is off
    Paint outline = null;
    if (lowConfidence) {
        outline = new Paint(p);
        outline.setStyle(Paint.Style.STROKE);
        outline.setStrokeWidth(p.getTextSize() * 0.08f);
        // Outline colour = inverse luminance of text colour
        float textLum = 0.299f*Color.red(p.getColor())
                       + 0.587f*Color.green(p.getColor())
                       + 0.114f*Color.blue(p.getColor());
        outline.setColor(textLum > 128 ? Color.argb(160,0,0,0)
                                         : Color.argb(160,255,255,255));
    }

    for (String line : lines) {
        float x = (w - p.measureText(line)) / 2f;
        x = Math.max(padX, x);

        if (outline != null) {
            c.drawText(line, x, y, outline); // outline first, behind
        }
        c.drawText(line, x, y, p);
        y += lineH;
    }
}
