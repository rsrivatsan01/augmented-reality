package com.yourapp;

import android.content.Context;
import android.graphics.*;
import android.util.AttributeSet;
import android.view.View;

import java.util.ArrayList;
import java.util.List;

public class TranslatedOverlayView extends View {

    public static class OverlayBlock {
        public RectF bounds;
        public String originalText;
        public String translatedText;

        public OverlayBlock(RectF bounds, String original, String translated) {
            this.bounds = bounds;
            this.originalText = original;
            this.translatedText = translated;
        }
    }

    private final List<OverlayBlock> blocks = new ArrayList<>();
    private int imageWidth = 1, imageHeight = 1;

    private final Paint maskPaint;
    private final Paint translatedPaint;
    private final Paint boxPaint;
    private final Paint cornerPaint;
    private final Paint originalPaint;

    public TranslatedOverlayView(Context context, AttributeSet attrs) {
        super(context, attrs);

        maskPaint = new Paint();
        maskPaint.setStyle(Paint.Style.FILL);
        maskPaint.setColor(Color.parseColor("#E6001F3F"));

        translatedPaint = new Paint();
        translatedPaint.setColor(Color.parseColor("#00E5FF"));
        translatedPaint.setTypeface(Typeface.create(Typeface.DEFAULT, Typeface.BOLD));
        translatedPaint.setAntiAlias(true);

        originalPaint = new Paint();
        originalPaint.setColor(Color.parseColor("#99FFFFFF"));
        originalPaint.setTypeface(Typeface.DEFAULT);
        originalPaint.setAntiAlias(true);

        boxPaint = new Paint();
        boxPaint.setStyle(Paint.Style.STROKE);
        boxPaint.setColor(Color.parseColor("#00E5FF"));
        boxPaint.setStrokeWidth(2.5f);
        boxPaint.setAntiAlias(true);

        cornerPaint = new Paint();
        cornerPaint.setStyle(Paint.Style.STROKE);
        cornerPaint.setColor(Color.parseColor("#00E5FF"));
        cornerPaint.setStrokeWidth(6f);
        cornerPaint.setStrokeCap(Paint.Cap.ROUND);
        cornerPaint.setAntiAlias(true);
    }

    public void setResults(List<OverlayBlock> overlayBlocks, int imgW, int imgH) {
        blocks.clear();
        blocks.addAll(overlayBlocks);
        imageWidth  = imgW;
        imageHeight = imgH;
        invalidate();
    }

    public void clear() {
        blocks.clear();
        invalidate();
    }

    @Override
    protected void onDraw(Canvas canvas) {
        super.onDraw(canvas);
        if (blocks.isEmpty()) return;

        float scaleX = (float) getWidth()  / imageWidth;
        float scaleY = (float) getHeight() / imageHeight;

        for (OverlayBlock block : blocks) {
            RectF r = new RectF(
                block.bounds.left   * scaleX,
                block.bounds.top    * scaleY,
                block.bounds.right  * scaleX,
                block.bounds.bottom * scaleY
            );

            float boxW = r.width();
            float boxH = r.height();

            // 1. Dark mask covers original text
            canvas.drawRoundRect(r, 6f, 6f, maskPaint);

            // 2. Bounding box border
            canvas.drawRoundRect(r, 6f, 6f, boxPaint);

            // 3. AR corner accents
            drawCorners(canvas, r);

            // 4. Translated text fitted inside box
            float fontSize = fitTextSize(block.translatedText, boxW - 16f, boxH * 0.65f);
            translatedPaint.setTextSize(fontSize);
            drawWrappedText(canvas, block.translatedText,
                r.left + 8f, r.top + fontSize + 4f,
                boxW - 16f, boxH * 0.65f, translatedPaint);

            // 5. Original text dimmed at bottom
            float smallSize = Math.max(20f, fontSize * 0.45f);
            originalPaint.setTextSize(smallSize);
            String orig = block.originalText.replace("\n", " ");
            if (originalPaint.measureText(orig) > boxW - 16f) {
                orig = orig.substring(0, Math.min(orig.length(), 30)) + "…";
            }
            canvas.drawText(orig, r.left + 8f, r.bottom - 8f, originalPaint);
        }
    }

    private float fitTextSize(String text, float maxWidth, float maxHeight) {
        Paint p = new Paint(translatedPaint);
        float lo = 18f, hi = 80f;
        while (hi - lo > 1f) {
            float mid = (lo + hi) / 2f;
            p.setTextSize(mid);
            float textW = p.measureText(text);
            int lines = (int) Math.ceil(textW / maxWidth);
            float totalH = lines * (mid * 1.2f);
            if (totalH <= maxHeight && textW / lines <= maxWidth) hi = mid;
            else lo = mid;
        }
        return lo;
    }

    private void drawWrappedText(Canvas canvas, String text,
                                  float x, float y,
                                  float maxWidth, float maxHeight,
                                  Paint paint) {
        String[] words = text.split(" ");
        StringBuilder line = new StringBuilder();
        float lineHeight = paint.getTextSize() * 1.25f;
        float currentY = y;

        for (String word : words) {
            String test = line.length() == 0 ? word : line + " " + word;
            if (paint.measureText(test) > maxWidth) {
                if (currentY - y + lineHeight > maxHeight) break;
                canvas.drawText(line.toString(), x, currentY, paint);
                currentY += lineHeight;
                line = new StringBuilder(word);
            } else {
                line = new StringBuilder(test);
            }
        }
        if (line.length() > 0 && currentY - y <= maxHeight) {
            canvas.drawText(line.toString(), x, currentY, paint);
        }
    }

    private void drawCorners(Canvas canvas, RectF r) {
        float len = 24f;
        canvas.drawLine(r.left,  r.top,    r.left + len,  r.top,         cornerPaint);
        canvas.drawLine(r.left,  r.top,    r.left,        r.top + len,   cornerPaint);
        canvas.drawLine(r.right, r.top,    r.right - len, r.top,         cornerPaint);
        canvas.drawLine(r.right, r.top,    r.right,       r.top + len,   cornerPaint);
        canvas.drawLine(r.left,  r.bottom, r.left + len,  r.bottom,      cornerPaint);
        canvas.drawLine(r.left,  r.bottom, r.left,        r.bottom - len,cornerPaint);
        canvas.drawLine(r.right, r.bottom, r.right - len, r.bottom,      cornerPaint);
        canvas.drawLine(r.right, r.bottom, r.right,       r.bottom - len,cornerPaint);
    }
}
