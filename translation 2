package com.yourapp;

import com.google.mlkit.common.model.DownloadConditions;
import com.google.mlkit.nl.languageid.LanguageIdentification;
import com.google.mlkit.nl.languageid.LanguageIdentifier;
import com.google.mlkit.nl.translate.TranslateLanguage;
import com.google.mlkit.nl.translate.Translation;
import com.google.mlkit.nl.translate.Translator;
import com.google.mlkit.nl.translate.TranslatorOptions;

import java.util.List;
import java.util.ArrayList;
import java.util.concurrent.atomic.AtomicInteger;

public class TranslationProcessor {

    public interface TranslationCallback {
        void onComplete(List<String> translatedBlocks);
        void onError(String error);
        void onDownloadProgress(String message);
    }

    private Translator currentTranslator;
    private final LanguageIdentifier languageIdentifier;

    public TranslationProcessor() {
        languageIdentifier = LanguageIdentification.getClient();
    }

    /**
     * Translates a list of text blocks.
     * If sourceCode is "auto", ML Kit identifies the language first.
     */
    public void translate(List<String> textBlocks,
                          String sourceCode,
                          String targetCode,
                          TranslationCallback callback) {

        if (textBlocks == null || textBlocks.isEmpty()) {
            callback.onError("No text to translate");
            return;
        }

        if (sourceCode.equals("auto")) {
            String combinedText = String.join(" ", textBlocks);
            languageIdentifier.identifyLanguage(combinedText)
                .addOnSuccessListener(detectedCode -> {
                    String resolvedCode = detectedCode.equals("und")
                        ? TranslateLanguage.ENGLISH
                        : detectedCode;
                    buildAndTranslate(textBlocks, resolvedCode, targetCode, callback);
                })
                .addOnFailureListener(e ->
                    buildAndTranslate(textBlocks,
                        TranslateLanguage.ENGLISH, targetCode, callback));
        } else {
            buildAndTranslate(textBlocks, sourceCode, targetCode, callback);
        }
    }

    private void buildAndTranslate(List<String> blocks,
                                   String sourceCode,
                                   String targetCode,
                                   TranslationCallback callback) {
        if (sourceCode.equals(targetCode)) {
            callback.onComplete(blocks);
            return;
        }

        if (currentTranslator != null) currentTranslator.close();

        TranslatorOptions options = new TranslatorOptions.Builder()
            .setSourceLanguage(sourceCode)
            .setTargetLanguage(targetCode)
            .build();

        currentTranslator = Translation.getClient(options);

        DownloadConditions conditions = new DownloadConditions.Builder()
            .requireWifi()
            .build();

        callback.onDownloadProgress("Downloading language model…");

        currentTranslator.downloadModelIfNeeded(conditions)
            .addOnSuccessListener(v -> translateAllBlocks(blocks, callback))
            .addOnFailureListener(e ->
                callback.onError("Model download failed: " + e.getMessage()));
    }

    /**
     * Translates each block individually so positions stay mapped 1-to-1.
     */
    private void translateAllBlocks(List<String> blocks, TranslationCallback callback) {
        List<String> results = new ArrayList<>();
        for (int i = 0; i < blocks.size(); i++) results.add("");

        AtomicInteger pending = new AtomicInteger(blocks.size());

        for (int i = 0; i < blocks.size(); i++) {
            final int index = i;
            currentTranslator.translate(blocks.get(i))
                .addOnSuccessListener(translated -> {
                    results.set(index, translated);
                    if (pending.decrementAndGet() == 0) {
                        callback.onComplete(results);
                    }
                })
                .addOnFailureListener(e -> {
                    results.set(index, blocks.get(index)); // fallback: keep original
                    if (pending.decrementAndGet() == 0) {
                        callback.onComplete(results);
                    }
                });
        }
    }

    public void close() {
        if (currentTranslator != null) currentTranslator.close();
        languageIdentifier.close();
    }
}
