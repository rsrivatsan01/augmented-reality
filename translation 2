## `MainActivity.java`
```java
package com.yourapp;

import android.Manifest;
import android.content.pm.PackageManager;
import android.graphics.Bitmap;
import android.graphics.RectF;
import android.os.Bundle;
import android.view.View;
import android.widget.*;
import androidx.annotation.NonNull;
import androidx.appcompat.app.AppCompatActivity;
import androidx.camera.core.*;
import androidx.camera.lifecycle.ProcessCameraProvider;
import androidx.camera.view.PreviewView;
import androidx.core.app.ActivityCompat;
import androidx.core.content.ContextCompat;

import com.google.mlkit.vision.text.Text;
import com.google.common.util.concurrent.ListenableFuture;

import java.util.*;
import java.util.concurrent.*;

public class MainActivity extends AppCompatActivity {

    private static final int CAMERA_PERM = 100;

    private PreviewView cameraPreview;
    private ImageView frozenFrame;
    private TranslatedOverlayView translatedOverlay;
    private TextView statusText, loadingText;
    private Button btnCapture, btnReset;
    private View loadingPanel;
    private Spinner spinnerSource, spinnerTarget;
    private ImageButton btnSwap;

    private ImageCapture imageCapture;
    private ExecutorService cameraExecutor;
    private TextDetectionProcessor textDetector;
    private TranslationProcessor translator;
    private boolean isProcessing = false;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        bindViews();
        setupSpinners();
        setupButtons();

        textDetector   = new TextDetectionProcessor();
        translator     = new TranslationProcessor();
        cameraExecutor = Executors.newSingleThreadExecutor();

        if (hasCameraPermission()) startCamera();
        else ActivityCompat.requestPermissions(this,
            new String[]{Manifest.permission.CAMERA}, CAMERA_PERM);
    }

    private void bindViews() {
        cameraPreview     = findViewById(R.id.camera_preview);
        frozenFrame       = findViewById(R.id.frozen_frame);
        translatedOverlay = findViewById(R.id.translated_overlay);
        statusText        = findViewById(R.id.status_text);
        loadingText       = findViewById(R.id.loading_text);
        loadingPanel      = findViewById(R.id.loading_panel);
        btnCapture        = findViewById(R.id.btn_capture);
        btnReset          = findViewById(R.id.btn_reset);
        spinnerSource     = findViewById(R.id.spinner_source);
        spinnerTarget     = findViewById(R.id.spinner_target);
        btnSwap           = findViewById(R.id.btn_swap);
    }

    private void setupSpinners() {
        String[] names = LanguageManager.getDisplayNames();
        ArrayAdapter<String> adapter = new ArrayAdapter<>(
            this, android.R.layout.simple_spinner_item, names);
        adapter.setDropDownViewResource(
            android.R.layout.simple_spinner_dropdown_item);

        spinnerSource.setAdapter(adapter);
        spinnerTarget.setAdapter(adapter);
        spinnerSource.setSelection(0); // Auto Detect
        spinnerTarget.setSelection(1); // English
    }

    private String getSourceCode() {
        return LanguageManager.getCode(spinnerSource.getSelectedItem().toString());
    }

    private String getTargetCode() {
        return LanguageManager.getCode(spinnerTarget.getSelectedItem().toString());
    }

    private void setupButtons() {
        btnCapture.setOnClickListener(v -> captureAndProcess());

        btnReset.setOnClickListener(v -> {
            translatedOverlay.clear();
            frozenFrame.setVisibility(View.GONE);
            frozenFrame.setImageBitmap(null);
            cameraPreview.setVisibility(View.VISIBLE);
            btnReset.setVisibility(View.GONE);
            btnCapture.setVisibility(View.VISIBLE);
            statusText.setText("Select languages, then tap to scan");
        });

        btnSwap.setOnClickListener(v -> {
            int src = spinnerSource.getSelectedItemPosition();
            int tgt = spinnerTarget.getSelectedItemPosition();
            spinnerSource.setSelection(tgt);
            spinnerTarget.setSelection(src);
        });
    }

    private void startCamera() {
        ListenableFuture<ProcessCameraProvider> future =
            ProcessCameraProvider.getInstance(this);

        future.addListener(() -> {
            try {
                ProcessCameraProvider provider = future.get();
                Preview preview = new Preview.Builder().build();
                preview.setSurfaceProvider(cameraPreview.getSurfaceProvider());

                imageCapture = new ImageCapture.Builder()
                    .setCaptureMode(ImageCapture.CAPTURE_MODE_MINIMIZE_LATENCY)
                    .build();

                provider.unbindAll();
                provider.bindToLifecycle(this,
                    CameraSelector.DEFAULT_BACK_CAMERA,
                    preview, imageCapture);

            } catch (Exception e) {
                showStatus("Camera error: " + e.getMessage());
            }
        }, ContextCompat.getMainExecutor(this));
    }

    private void captureAndProcess() {
        if (isProcessing || imageCapture == null) return;

        if (spinnerTarget.getSelectedItemPosition() == 0) {
            Toast.makeText(this,
                "Please select a target language (not Auto Detect)",
                Toast.LENGTH_SHORT).show();
            return;
        }

        isProcessing = true;
        btnCapture.setEnabled(false);
        showLoading("Capturing…");

        imageCapture.takePicture(cameraExecutor,
            new ImageCapture.OnImageCapturedCallback() {

                @Override
                public void onCaptureSuccess(@NonNull ImageProxy proxy) {
                    Bitmap bitmap = proxy.toBitmap();
                    int rotation  = proxy.getImageInfo().getRotationDegrees();
                    proxy.close();

                    Bitmap rotated = rotateBitmap(bitmap, rotation);

                    runOnUiThread(() -> {
                        frozenFrame.setImageBitmap(rotated);
                        frozenFrame.setVisibility(View.VISIBLE);
                        cameraPreview.setVisibility(View.INVISIBLE);
                        showLoading("Detecting text…");
                    });

                    textDetector.process(rotated,
                        new TextDetectionProcessor.ResultCallback() {

                        @Override
                        public void onSuccess(Text result, int imgW, int imgH) {
                            if (result.getTextBlocks().isEmpty()) {
                                runOnUiThread(() -> {
                                    hideLoading();
                                    showStatus("No text found. Try again.");
                                    resetAfterDelay();
                                });
                                return;
                            }

                            List<String> textList   = new ArrayList<>();
                            List<RectF>  boundsList = new ArrayList<>();

                            for (Text.TextBlock block : result.getTextBlocks()) {
                                if (block.getBoundingBox() == null) continue;
                                textList.add(block.getText());
                                android.graphics.Rect r = block.getBoundingBox();
                                boundsList.add(
                                    new RectF(r.left, r.top, r.right, r.bottom));
                            }

                            runOnUiThread(() -> showLoading("Translating…"));

                            translator.translate(textList,
                                getSourceCode(), getTargetCode(),
                                new TranslationProcessor.TranslationCallback() {

                                @Override
                                public void onComplete(List<String> translated) {
                                    List<TranslatedOverlayView.OverlayBlock> overlayBlocks
                                        = new ArrayList<>();
                                    for (int i = 0; i < translated.size(); i++) {
                                        overlayBlocks.add(
                                            new TranslatedOverlayView.OverlayBlock(
                                                boundsList.get(i),
                                                textList.get(i),
                                                translated.get(i)));
                                    }
                                    runOnUiThread(() -> {
                                        translatedOverlay.setResults(
                                            overlayBlocks, imgW, imgH);
                                        hideLoading();
                                        showStatus("✅ " + translated.size()
                                            + " block(s) translated");
                                        btnReset.setVisibility(View.VISIBLE);
                                        btnCapture.setVisibility(View.GONE);
                                        isProcessing = false;
                                        btnCapture.setEnabled(true);
                                    });
                                }

                                @Override
                                public void onError(String error) {
                                    runOnUiThread(() -> {
                                        hideLoading();
                                        showStatus("Translation error: " + error);
                                        isProcessing = false;
                                        btnCapture.setEnabled(true);
                                    });
                                }

                                @Override
                                public void onDownloadProgress(String message) {
                                    runOnUiThread(() -> showLoading(message));
                                }
                            });
                        }

                        @Override
                        public void onFailure(Exception e) {
                            runOnUiThread(() -> {
                                hideLoading();
                                showStatus("Detection failed: " + e.getMessage());
                                isProcessing = false;
                                btnCapture.setEnabled(true);
                            });
                        }
                    });
                }

                @Override
                public void onError(@NonNull ImageCaptureException e) {
                    runOnUiThread(() -> {
                        hideLoading();
                        showStatus("Capture error: " + e.getMessage());
                        isProcessing = false;
                        btnCapture.setEnabled(true);
                    });
                }
            });
    }

    private void showLoading(String message) {
        loadingText.setText(message);
        loadingPanel.setVisibility(View.VISIBLE);
    }

    private void hideLoading() {
        loadingPanel.setVisibility(View.GONE);
    }

    private void showStatus(String msg) {
        statusText.setText(msg);
    }

    private void resetAfterDelay() {
        new android.os.Handler().postDelayed(() -> {
            frozenFrame.setVisibility(View.GONE);
            cameraPreview.setVisibility(View.VISIBLE);
            showStatus("Select languages, then tap to scan");
            isProcessing = false;
            btnCapture.setEnabled(true);
        }, 2000);
    }

    private Bitmap rotateBitmap(Bitmap src, int degrees) {
        if (degrees == 0) return src;
        android.graphics.Matrix m = new android.graphics.Matrix();
        m.postRotate(degrees);
        return Bitmap.createBitmap(
            src, 0, 0, src.getWidth(), src.getHeight(), m, true);
    }

    private boolean hasCameraPermission() {
        return ContextCompat.checkSelfPermission(this,
            Manifest.permission.CAMERA) == PackageManager.PERMISSION_GRANTED;
    }

    @Override
    public void onRequestPermissionsResult(int code,
            @NonNull String[] perms, @NonNull int[] results) {
        super.onRequestPermissionsResult(code, perms, results);
        if (code == CAMERA_PERM && results.length > 0
                && results[0] == PackageManager.PERMISSION_GRANTED) {
            startCamera();
        }
    }

    @Override
    protected void onDestroy() {
        super.onDestroy();
        cameraExecutor.shutdown();
        textDetector.close();
        translator.close();
    }
}
```

That's the complete second half — `TranslationProcessor` → `TranslatedOverlayView` → `activity_main.xml` → `MainActivity`. Everything from `LanguageManager` and `build.gradle` stays the same as the first response.