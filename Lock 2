import java.util.ArrayList;
import java.util.List;

public class MainActivity extends AppCompatActivity
        implements ARTextRenderer.FrameCallback {

    private static final int CAMERA_PERM = 100;

    // ── Views ──────────────────────────────────────────────────────────────
    private GLSurfaceView      glSurfaceView;
    private ScannerOverlayView scannerOverlay;
    private LockIndicatorView  lockIndicatorView;
    private TextView           statusText, loadingText;
    private Button             btnCapture, btnReset;
    private View               loadingPanel;
