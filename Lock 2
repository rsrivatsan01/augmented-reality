    @Override
    protected void onDestroy() {
        super.onDestroy();
        monitorSharpness = false;
        scannerOverlay.stopAnimation();
        lockIndicatorView.stopAnimation();
        if (arSession != null) { arSession.close(); arSession = null; }
        translator.close();
