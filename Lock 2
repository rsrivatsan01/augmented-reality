        glSurfaceView.setPreserveEGLContextOnPause(true);
        glSurfaceView.setEGLContextClientVersion(2);

        arRenderer = new ARTextRenderer(this, this);
        arRenderer.setSession(arSession);

        glSurfaceView.setRenderer(arRenderer);
        glSurfaceView.setRenderMode(GLSurfaceView.RENDERMODE_CONTINUOUSLY);

        scannerOverlay.startAnimation();
        lockIndicatorView.startAnimation();
        startSharpnessMonitor();
    }

    // ── Lifecycle ──────────────────────────────────────────────────────────

    @Override
    protected void onResume() {
        super.onResume();
        if (arSession != null) {
            try {
                arSession.resume();
                sessionPaused = false;
                glSurfaceView.onResume();
                startSharpnessMonitor();
            } catch (CameraNotAvailableException e) {
                showStatus("Camera not available");
            }
        }
    }

    @Override
    protected void onPause() {
        super.onPause();
        monitorSharpness = false;
