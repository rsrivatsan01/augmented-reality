```java
package com.yourapp;

import android.content.Context;
import android.graphics.Canvas;
import android.graphics.Color;
import android.graphics.Paint;
import android.graphics.RectF;
import android.util.AttributeSet;
import android.view.View;

/**
 * Animated scanner viewfinder drawn on top of the AR surface view.
 * Shows:
 * - Corner brackets (pulse green when sharp)
 * - Horizontal scan line that sweeps up and down
 * - Sharpness score bar at the bottom
 */
public class ScannerOverlayView extends View {

    public enum State { IDLE, SCANNING, SHARP, PROCESSING, LOCKED }

    private State state = State.IDLE;

    // Paints
    private final Paint cornerPaint  = new Paint();
    private final Paint scanPaint    = new Paint();
    private final Paint barBgPaint   = new Paint();
    private final Paint barFillPaint = new Paint();
    private final Paint labelPaint   = new Paint();

    // Animation
    private float scanLineY    = 0f;
    private float scanDir      = 1f;
    private float sharpness    = 0f;   // 0–1
    private float cornerAlpha  = 1f;
    private float pulsePhase   = 0f;

    private final android.os.Handler handler = new android.os.Handler();
    private final Runnable ticker = new Runnable() {
        @Override public void run() {
            tick();
            handler.postDelayed(this, 16); // ~60fps
        }
    };

    public ScannerOverlayView(Context context, AttributeSet attrs) {
        super(context, attrs);
        setWillNotDraw(false);

        cornerPaint.setStyle(Paint.Style.STROKE);
        cornerPaint.setStrokeWidth(6f);
        cornerPaint.setStrokeCap(Paint.Cap.ROUND);
        cornerPaint.setAntiAlias(true);

        scanPaint.setStyle(Paint.Style.STROKE);
        scanPaint.setStrokeWidth(2f);
        scanPaint.setAntiAlias(true);

        barBgPaint.setColor(Color.parseColor("#44FFFFFF"));
        barBgPaint.setAntiAlias(true);

        barFillPaint.setAntiAlias(true);

        labelPaint.setColor(Color.WHITE);
        labelPaint.setTextSize(28f);
        labelPaint.setAntiAlias(true);
        labelPaint.setTextAlign(Paint.Align.CENTER);
    }

    public void setState(State s) {
        this.state = s;
        invalidate();
    }

    public void setSharpness(float s) {
        this.sharpness = Math.max(0f, Math.min(1f, s));
        invalidate();
    }

    public void startAnimation() { handler.post(ticker); }
    public void stopAnimation()  { handler.removeCallbacks(ticker); }

    private void tick() {
        pulsePhase += 0.08f;
        if (pulsePhase > (float)(Math.PI * 2)) pulsePhase = 0f;

        // Scan line movement
        if (state == State.SCANNING || state == State.IDLE) {
            scanLineY += scanDir * 4f;
            if (scanLineY > getHeight() * 0.85f) scanDir = -1f;
            if (scanLineY < getHeight() * 0.15f) scanDir =  1f;
        }

        invalidate();
    }

    @Override
    protected void onDraw(Canvas canvas) {
        super.onDraw(canvas);
        if (state == State.LOCKED || state == State.PROCESSING) {
            if (state == State.PROCESSING) drawProcessingOverlay(canvas);
            return;
        }

        int w = getWidth(), h = getHeight();

        // ── Corner colour based on state ───────────────────────────────────
        int cornerColor;
        switch (state) {
            case SHARP:
                float pulse = (float)(Math.sin(pulsePhase) * 0.3f + 0.7f);
                cornerColor = Color.argb((int)(255*pulse),0,255,140);
                break;
            case SCANNING:
                cornerColor = Color.parseColor("#00E5FF");
                break;
            default:
                cornerColor = Color.parseColor("#88FFFFFF");
        }
        cornerPaint.setColor(cornerColor);

        // ── Viewfinder box ─────────────────────────────────────────────────
        float margin = w * 0.10f;
        float cx0 = margin, cy0 = h * 0.25f;
        float cx1 = w - margin, cy1 = h * 0.75f;
        float armLen = w * 0.10f;

        // Top-left
        canvas.drawLine(cx0, cy0, cx0+armLen, cy0, cornerPaint);
        canvas.drawLine(cx0, cy0, cx0, cy0+armLen, cornerPaint);
        // Top-right
        canvas.drawLine(cx1, cy0, cx1-armLen, cy0, cornerPaint);
        canvas.drawLine(cx1, cy0, cx1, cy0+armLen, cornerPaint);
        // Bottom-left
        canvas.drawLine(cx0, cy1, cx0+armLen, cy1, cornerPaint);
        canvas.drawLine(cx0, cy1, cx0, cy1-armLen, cornerPaint);
        // Bottom-right
        canvas.drawLine(cx1, cy1, cx1-armLen, cy1, cornerPaint);
        canvas.drawLine(cx1, cy1, cx1, cy1-armLen, cornerPaint);

        // ── Scan line ──────────────────────────────────────────────────────
        if (state == State.SCANNING || state == State.IDLE) {
            float scanY = cy0 + (scanLineY / h) * (cy1 - cy0);
            int scanAlpha = (int)(120 + 80 * Math.sin(pulsePhase));
            scanPaint.setColor(Color.argb(scanAlpha, 0, 229, 255));

            // Gradient-style scan line (brighter in centre)
            for (int i = -3; i <= 3; i++) {
                int a = (int)(scanAlpha * (1f - Math.abs(i)/4f));
                scanPaint.setColor(Color.argb(a, 0, 229, 255));
                canvas.drawLine(cx0, scanY+i, cx1, scanY+i, scanPaint);
            }
        }

        // ── Sharpness bar ──────────────────────────────────────────────────
        float barX0 = cx0, barY0 = cy1 + 20f;
        float barW  = cx1 - cx0, barH = 8f;

        canvas.drawRoundRect(
            new RectF(barX0, barY0, barX0+barW, barY0+barH),
            4f, 4f, barBgPaint);

        int fillColor = sharpness > 0.7f
            ? Color.parseColor("#00FF8C")
            : sharpness > 0.4f
                ? Color.parseColor("#FFD700")
                : Color.parseColor("#FF4444");
        barFillPaint.setColor(fillColor);

        canvas.drawRoundRect(
            new RectF(barX0, barY0, barX0 + barW*sharpness, barY0+barH),
            4f, 4f, barFillPaint);

        // Label
        String label = state == State.SHARP
            ? "Ready — tap to scan"
            : sharpness > 0.4f ? "Hold steady…" : "Aim at text";
        canvas.drawText(label, w/2f, barY0 + 36f, labelPaint);
    }

    private void drawProcessingOverlay(Canvas canvas) {
        int w = getWidth(), h = getHeight();
        Paint p = new Paint();
        p.setColor(Color.argb(60, 0, 0, 0));
        canvas.drawRect(0, 0, w, h, p);

        // Spinning arc
        p.setColor(Color.parseColor("#00E5FF"));
        p.setStyle(Paint.Style.STROKE);
        p.setStrokeWidth(6f);
        p.setAntiAlias(true);
        float cx = w/2f, cy = h/2f, r = 60f;
        float startAngle = (pulsePhase * 180f / (float)Math.PI) * 2f;
        canvas.drawArc(new RectF(cx-r,cy-r,cx+r,cy+r),
            startAngle, 260f, false, p);

        labelPaint.setTextSize(34f);
        canvas.drawText("Processing…", cx, cy + r + 48f, labelPaint);
    }
}
