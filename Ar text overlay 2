## `FlagshipBillboard.java` — Replaces `NaturalTextBillboard`
```java
package com.yourapp;

import android.graphics.Bitmap;
import android.graphics.Canvas;
import android.graphics.Color;
import android.graphics.LinearGradient;
import android.graphics.Paint;
import android.graphics.RectF;
import android.graphics.Shader;

import java.util.ArrayList;
import java.util.List;

/**
 * Flagship billboard renderer.
 * - Inpainted background (no flat colour)
 * - Perfect font matching from TypographyAnalyzer
 * - Text alignment matched to original
 * - Fade-in alpha controlled externally for animation
 */
public class FlagshipBillboard {

    private static final int BMP_H = 256;

    public static Bitmap create(Bitmap inpaintedSource,
                                 android.graphics.Rect sourceBox,
                                 String translatedText,
                                 TypographyAnalyzer.FontProfile profile,
                                 float alpha) { // 0→1 for fade-in animation

        int bmpW = Math.max(128, Math.min(1024,
            (int)(BMP_H * (profile.blockWidthPx / Math.max(1, profile.blockHeightPx)))));
        int bmpH = BMP_H;

        Bitmap bmp = Bitmap.createBitmap(bmpW, bmpH, Bitmap.Config.ARGB_8888);
        Canvas canvas = new Canvas(bmp);

        // ── 1. Stretch inpainted background region into billboard ──────────
        if (inpaintedSource != null && sourceBox != null) {
            int sl = Math.max(0, sourceBox.left);
            int st = Math.max(0, sourceBox.top);
            int sr = Math.min(inpaintedSource.getWidth()  - 1, sourceBox.right);
            int sb = Math.min(inpaintedSource.getHeight() - 1, sourceBox.bottom);

            if (sr > sl && sb > st) {
                Bitmap patch = Bitmap.createBitmap(
                    inpaintedSource, sl, st, sr - sl, sb - st);
                Bitmap scaled = Bitmap.createScaledBitmap(patch, bmpW, bmpH, true);
                canvas.drawBitmap(scaled, 0, 0, null);
                patch.recycle();
                scaled.recycle();
            }
        } else {
            // Fallback: flat background colour
            Paint bg = new Paint();
            bg.setColor(profile.backgroundColor);
            canvas.drawRect(0, 0, bmpW, bmpH, bg);
        }

        // ── 2. Seamless edge blend (alpha fade at borders) ─────────────────
        int bgR = Color.red(profile.backgroundColor);
        int bgG = Color.green(profile.backgroundColor);
        int bgB = Color.blue(profile.backgroundColor);

        drawEdgeFade(canvas, bmpW, bmpH, bgR, bgG, bgB);

        // ── 3. Draw translated text with full profile matching ─────────────
        Paint textPaint = new Paint();
        textPaint.setTypeface(profile.typeface);
        textPaint.setColor(profile.textColor);
        textPaint.setAntiAlias(true);
        textPaint.setSubpixelText(true);
        textPaint.setLetterSpacing(profile.letterSpacing);

        // Scale font to billboard space
        float scaledSize = profile.fontSizePx * (bmpH / Math.max(1f, profile.blockHeightPx));
        scaledSize = Math.max(22f, Math.min(scaledSize, bmpH * 0.72f));
        textPaint.setTextSize(scaledSize);

        // Apply fade-in alpha
        int textAlpha = (int)(255 * alpha);
        textPaint.setAlpha(textAlpha);

        // Wrap + align text
        drawAlignedText(canvas, translatedText, bmpW, bmpH,
            textPaint, profile.textAlignment);

        return bmp;
    }

    private static void drawEdgeFade(Canvas canvas, int w, int h,
                                      int r, int g, int b) {
        Paint p = new Paint();
        float edgeW = w * 0.10f;
        float edgeH = h * 0.12f;

        int opaque = Color.argb(160, r, g, b);
        int trans  = Color.argb(0,   r, g, b);

        // Left
        p.setShader(new LinearGradient(0,0,edgeW,0,
            opaque,trans,Shader.TileMode.CLAMP));
        canvas.drawRect(0,0,edgeW,h,p);

        // Right
        p.setShader(new LinearGradient(w-edgeW,0,w,0,
            trans,opaque,Shader.TileMode.CLAMP));
        canvas.drawRect(w-edgeW,0,w,h,p);

        // Top
        p.setShader(new LinearGradient(0,0,0,edgeH,
            opaque,trans,Shader.TileMode.CLAMP));
        canvas.drawRect(0,0,w,edgeH,p);

        // Bottom
        p.setShader(new LinearGradient(0,h-edgeH,0,h,
            trans,opaque,Shader.TileMode.CLAMP));
        canvas.drawRect(0,h-edgeH,w,h,p);
    }

    private static void drawAlignedText(Canvas canvas, String text,
                                         int bmpW, int bmpH,
                                         Paint paint, float alignment) {
        float maxW   = bmpW * 0.86f;
        float padX   = bmpW * 0.07f;
        float lineH  = paint.getTextSize() * 1.22f;

        // Word wrap
        List<String> lines = new ArrayList<>();
        String[] words = text.split(" ");
        StringBuilder cur = new StringBuilder();

        for (String word : words) {
            String test = cur.length()==0 ? word : cur+" "+word;
            if (paint.measureText(test) > maxW) {
                if (cur.length()>0) lines.add(cur.toString());
                cur = new StringBuilder(word);
            } else {
                cur = new StringBuilder(test);
            }
        }
        if (cur.length()>0) lines.add(cur.toString());

        float totalH = lines.size() * lineH;
        float startY = (bmpH - totalH) / 2f + paint.getTextSize();

        for (String line : lines) {
            float tw = paint.measureText(line);
            float startX;

            if (alignment < 0.33f) {
                startX = padX; // left
            } else if (alignment < 0.66f) {
                startX = (bmpW - tw) / 2f; // centre
            } else {
                startX = bmpW - padX - tw; // right
            }

            canvas.drawText(line, startX, startY, paint);
            startY += lineH;
        }
    }
}
