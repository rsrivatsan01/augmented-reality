## `TypographyAnalyzer.java` — Stroke width, slant, weight, spacing detection
```java
package com.yourapp;

import android.graphics.Bitmap;
import android.graphics.Color;
import android.graphics.Rect;
import android.graphics.Typeface;

import com.google.mlkit.vision.text.Text;

/**
 * Analyses pixel data to detect:
 * - Font weight (bold vs regular) via stroke width transform
 * - Italic via horizontal pixel run slant
 * - Letter spacing approximation
 * - Best matching system Typeface
 */
public class TypographyAnalyzer {

    public static class FontProfile {
        public Typeface typeface;
        public boolean  isBold;
        public boolean  isItalic;
        public float    letterSpacing; // em units for Paint.setLetterSpacing()
        public float    fontSizePx;
        public int      textColor;
        public int      backgroundColor;
        public float    blockWidthPx;
        public float    blockHeightPx;
        public float    textAlignment;  // 0=left, 0.5=centre, 1=right
    }

    public static FontProfile analyze(Bitmap bitmap, Text.TextBlock block) {
        FontProfile profile = new FontProfile();
        Rect box = block.getBoundingBox();
        if (box == null) return defaultProfile();

        int left   = Math.max(0, box.left);
        int top    = Math.max(0, box.top);
        int right  = Math.min(bitmap.getWidth()  - 1, box.right);
        int bottom = Math.min(bitmap.getHeight() - 1, box.bottom);

        if (right <= left || bottom <= top) return defaultProfile();

        int blockW = right - left;
        int blockH = bottom - top;

        profile.blockWidthPx  = blockW;
        profile.blockHeightPx = blockH;

        // ── 1. Extract pixel data ──────────────────────────────────────────
        int[] pixels = new int[blockW * blockH];
        bitmap.getPixels(pixels, 0, blockW, left, top, blockW, blockH);

        // ── 2. Colour separation ───────────────────────────────────────────
        long sumLR=0,sumLG=0,sumLB=0,lc=0;
        long sumDR=0,sumDG=0,sumDB=0,dc=0;

        for (int px : pixels) {
            float lum = luminance(px);
            if (lum > 128f) {
                sumLR+=Color.red(px); sumLG+=Color.green(px);
                sumLB+=Color.blue(px); lc++;
            } else {
                sumDR+=Color.red(px); sumDG+=Color.green(px);
                sumDB+=Color.blue(px); dc++;
            }
        }

        boolean darkOnLight = lc >= dc;
        if (darkOnLight) {
            profile.backgroundColor = lc>0
                ? Color.rgb((int)(sumLR/lc),(int)(sumLG/lc),(int)(sumLB/lc))
                : Color.WHITE;
            profile.textColor = dc>0
                ? Color.rgb((int)(sumDR/dc),(int)(sumDG/dc),(int)(sumDB/dc))
                : Color.BLACK;
        } else {
            profile.backgroundColor = dc>0
                ? Color.rgb((int)(sumDR/dc),(int)(sumDG/dc),(int)(sumDB/dc))
                : Color.BLACK;
            profile.textColor = lc>0
                ? Color.rgb((int)(sumLR/lc),(int)(sumLG/lc),(int)(sumLB/lc))
                : Color.WHITE;
        }

        // ── 3. Stroke width transform (bold detection) ─────────────────────
        // Measure average horizontal run length of text pixels
        float textLum = luminance(profile.textColor);
        float avgRunLength = averageTextRunLength(
            pixels, blockW, blockH, textLum > 128f);

        // Runs > 15% of block height = bold
        float runRatio = avgRunLength / Math.max(1, blockH);
        profile.isBold = runRatio > 0.04f;

        // ── 4. Slant detection (italic) ────────────────────────────────────
        profile.isItalic = detectSlant(pixels, blockW, blockH, textLum > 128f);

        // ── 5. Font size from line metrics ────────────────────────────────
        int lineCount = Math.max(1, block.getLines().size());
        profile.fontSizePx = (blockH / (float) lineCount) * 0.72f;
        profile.fontSizePx = Math.max(16f, Math.min(profile.fontSizePx, 120f));

        // ── 6. Letter spacing from inter-character gap analysis ────────────
        profile.letterSpacing = estimateLetterSpacing(
            pixels, blockW, blockH, textLum > 128f);

        // ── 7. Text alignment from pixel mass distribution ─────────────────
        profile.textAlignment = detectAlignment(pixels, blockW, blockH, textLum > 128f);

        // ── 8. Pick best matching Typeface ─────────────────────────────────
        profile.typeface = selectTypeface(profile);

        return profile;
    }

    // ── Stroke width: average horizontal run of text-coloured pixels ───────

    private static float averageTextRunLength(int[] pixels, int w, int h,
                                               boolean textIsLight) {
        float totalRuns = 0; int runCount = 0;
        for (int y = 0; y < h; y++) {
            int run = 0;
            for (int x = 0; x < w; x++) {
                int px = pixels[y * w + x];
                boolean isText = textIsLight
                    ? luminance(px) > 128f
                    : luminance(px) <= 128f;
                if (isText) {
                    run++;
                } else {
                    if (run > 0) { totalRuns += run; runCount++; run = 0; }
                }
            }
            if (run > 0) { totalRuns += run; runCount++; }
        }
        return runCount > 0 ? totalRuns / runCount : 1f;
    }

    // ── Slant: measure horizontal offset of text mass between top/bottom ───

    private static boolean detectSlant(int[] pixels, int w, int h,
                                        boolean textIsLight) {
        if (h < 10) return false;

        // Centre of mass X in top third vs bottom third
        long topMassX = 0, topCount = 0;
        long botMassX = 0, botCount = 0;
        int thirdH = h / 3;

        for (int y = 0; y < thirdH; y++) {
            for (int x = 0; x < w; x++) {
                int px = pixels[y * w + x];
                boolean isText = textIsLight
                    ? luminance(px) > 128f : luminance(px) <= 128f;
                if (isText) { topMassX += x; topCount++; }
            }
        }
        for (int y = h - thirdH; y < h; y++) {
            for (int x = 0; x < w; x++) {
                int px = pixels[y * w + x];
                boolean isText = textIsLight
                    ? luminance(px) > 128f : luminance(px) <= 128f;
                if (isText) { botMassX += x; botCount++; }
            }
        }

        if (topCount == 0 || botCount == 0) return false;

        float topCX = (float) topMassX / topCount;
        float botCX = (float) botMassX / botCount;
        float slantRatio = Math.abs(topCX - botCX) / Math.max(1, w);

        // Slant > 8% of block width = italic
        return slantRatio > 0.08f;
    }

    // ── Letter spacing: average gap between text runs on a row ────────────

    private static float estimateLetterSpacing(int[] pixels, int w, int h,
                                                boolean textIsLight) {
        float totalGap = 0; int gapCount = 0;
        int midY = h / 2;

        int gap = 0; boolean inGap = false;
        for (int x = 0; x < w; x++) {
            int px = pixels[midY * w + x];
            boolean isText = textIsLight
                ? luminance(px) > 128f : luminance(px) <= 128f;
            if (!isText) {
                if (inGap) gap++;
                else { inGap = true; gap = 1; }
            } else {
                if (inGap && gap > 1 && gap < w / 4) {
                    totalGap += gap; gapCount++;
                }
                inGap = false; gap = 0;
            }
        }

        if (gapCount == 0) return 0f;
        float avgGap = totalGap / gapCount;
        // Normalise to em units: roughly gap/fontSize
        return Math.max(-0.05f, Math.min(0.2f, avgGap / Math.max(1, h) - 0.05f));
    }

    // ── Alignment: where is text pixel mass concentrated ──────────────────

    private static float detectAlignment(int[] pixels, int w, int h,
                                          boolean textIsLight) {
        long massX = 0, count = 0;
        for (int y = 0; y < h; y++) {
            for (int x = 0; x < w; x++) {
                int px = pixels[y * w + x];
                boolean isText = textIsLight
                    ? luminance(px) > 128f : luminance(px) <= 128f;
                if (isText) { massX += x; count++; }
            }
        }
        if (count == 0) return 0f;
        float cx = (float) massX / count;
        return cx / Math.max(1, w); // 0=left, 0.5=centre, 1=right
    }

    // ── Typeface selection ─────────────────────────────────────────────────

    private static Typeface selectTypeface(FontProfile p) {
        int style = Typeface.NORMAL;
        if (p.isBold && p.isItalic) style = Typeface.BOLD_ITALIC;
        else if (p.isBold)          style = Typeface.BOLD;
        else if (p.isItalic)        style = Typeface.ITALIC;

        // Contrast-based family heuristic
        float contrast = contrast(p.textColor, p.backgroundColor);
        if (contrast > 8f) {
            return Typeface.create(Typeface.SERIF, style);
        } else if (contrast > 5f) {
            return Typeface.create("sans-serif-medium", style);
        } else if (contrast > 3f) {
            return Typeface.create(Typeface.DEFAULT, style);
        } else {
            return Typeface.create("sans-serif-light", style);
        }
    }

    private static float luminance(int color) {
        return 0.299f*Color.red(color)
             + 0.587f*Color.green(color)
             + 0.114f*Color.blue(color);
    }

    private static float contrast(int c1, int c2) {
        float l1 = relLum(c1), l2 = relLum(c2);
        return (Math.max(l1,l2)+0.05f)/(Math.min(l1,l2)+0.05f);
    }

    private static float relLum(int c) {
        float r=lin(Color.red(c)/255f),
              g=lin(Color.green(c)/255f),
              b=lin(Color.blue(c)/255f);
        return 0.2126f*r+0.7152f*g+0.0722f*b;
    }

    private static float lin(float c) {
        return c<=0.03928f ? c/12.92f : (float)Math.pow((c+0.055f)/1.055f,2.4);
    }

    private static FontProfile defaultProfile() {
        FontProfile p = new FontProfile();
        p.typeface         = Typeface.DEFAULT;
        p.isBold           = false;
        p.isItalic         = false;
        p.letterSpacing    = 0f;
        p.fontSizePx       = 32f;
        p.textColor        = Color.BLACK;
        p.backgroundColor  = Color.WHITE;
        p.blockWidthPx     = 200f;
        p.blockHeightPx    = 60f;
        p.textAlignment    = 0f;
        return p;
    }
}
