## `PoseInterpolator.java` — Smooth anchor jitter elimination
```java
package com.yourapp;

import android.opengl.Matrix;

/**
 * Exponential moving average on 4×4 pose matrices.
 * Eliminates ARCore anchor jitter — anchors glide instead of snap.
 */
public class PoseInterpolator {

    private final float smoothing; // 0=instant, 1=never moves. ~0.15 is good
    private float[] smoothed = null;
    private boolean initialised = false;

    public PoseInterpolator(float smoothing) {
        this.smoothing = smoothing;
    }

    /**
     * Feed the raw anchor matrix each frame, get back a smoothed one.
     */
    public float[] smooth(float[] raw) {
        if (!initialised || smoothed == null) {
            smoothed = raw.clone();
            initialised = true;
            return smoothed;
        }

        // Interpolate each element of the 4×4 matrix
        for (int i = 0; i < 16; i++) {
            smoothed[i] = smoothed[i] * smoothing + raw[i] * (1f - smoothing);
        }

        // Re-orthogonalise rotation part (prevents matrix drift over time)
        reOrthogonalise(smoothed);

        return smoothed;
    }

    public void reset() {
        smoothed     = null;
        initialised  = false;
    }

    /**
     * Gram-Schmidt on columns 0,1,2 of the 4×4 matrix
     * to keep rotation matrix valid after interpolation.
     */
    private void reOrthogonalise(float[] m) {
        // Column 0 (right)
        float r0x=m[0],r0y=m[1],r0z=m[2];
        float len0 = (float)Math.sqrt(r0x*r0x+r0y*r0y+r0z*r0z);
        if (len0>0){m[0]/=len0;m[1]/=len0;m[2]/=len0;}

        // Column 1 (up) — orthogonalise against column 0
        float r1x=m[4],r1y=m[5],r1z=m[6];
        float dot01=m[0]*r1x+m[1]*r1y+m[2]*r1z;
        r1x-=dot01*m[0]; r1y-=dot01*m[1]; r1z-=dot01*m[2];
        float len1=(float)Math.sqrt(r1x*r1x+r1y*r1y+r1z*r1z);
        if (len1>0){m[4]=r1x/len1;m[5]=r1y/len1;m[6]=r1z/len1;}

        // Column 2 (forward) = cross(col0, col1)
        m[8] =m[1]*m[6]-m[2]*m[5];
        m[9] =m[2]*m[4]-m[0]*m[6];
        m[10]=m[0]*m[5]-m[1]*m[4];
    }
}
