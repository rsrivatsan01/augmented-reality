## `InpaintingEraser.java` — Gradient-aware background reconstruction
```java
package com.yourapp;

import android.graphics.Bitmap;
import android.graphics.Color;
import android.graphics.Rect;

import com.google.mlkit.vision.text.Text;

/**
 * Reconstructs the background behind each text block.
 * Instead of flat colour fill, samples the region border
 * and interpolates across the block — handles gradients,
 * shadows, and textured backgrounds.
 */
public class InpaintingEraser {

    /**
     * Returns a new Bitmap with all text block regions inpainted.
     * The returned bitmap is used both for style analysis and
     * as the base for the billboard texture.
     */
    public static Bitmap erase(Bitmap source, java.util.List<Text.TextBlock> blocks) {
        Bitmap result = source.copy(Bitmap.Config.ARGB_8888, true);

        for (Text.TextBlock block : blocks) {
            if (block.getBoundingBox() == null) continue;
            inpaintBlock(result, block.getBoundingBox());
        }

        return result;
    }

    private static void inpaintBlock(Bitmap bmp, Rect box) {
        int left   = Math.max(1, box.left);
        int top    = Math.max(1, box.top);
        int right  = Math.min(bmp.getWidth()  - 2, box.right);
        int bottom = Math.min(bmp.getHeight() - 2, box.bottom);

        if (right <= left || bottom <= top) return;

        int w = right - left;
        int h = bottom - top;

        // Sample border pixels (outside the box) for the 4 edges
        int[] topEdge    = sampleEdge(bmp, left, top    - 1, right, top    - 1);
        int[] bottomEdge = sampleEdge(bmp, left, bottom + 1, right, bottom + 1);
        int[] leftEdge   = sampleEdge(bmp, left - 1, top, left - 1, bottom);
        int[] rightEdge  = sampleEdge(bmp, right + 1, top, right + 1, bottom);

        // For each pixel inside the box, bilinearly interpolate
        // from the 4 edges based on position
        for (int y = top; y <= bottom; y++) {
            float fy = (float)(y - top) / Math.max(1, h);

            // Left and right colours at this row (from vertical edges)
            int lColor = leftEdge[Math.min((int)(fy * leftEdge.length),
                leftEdge.length - 1)];
            int rColor = rightEdge[Math.min((int)(fy * rightEdge.length),
                rightEdge.length - 1)];

            for (int x = left; x <= right; x++) {
                float fx = (float)(x - left) / Math.max(1, w);

                // Top and bottom colours at this column
                int tColor = topEdge[Math.min((int)(fx * topEdge.length),
                    topEdge.length - 1)];
                int bColor = bottomEdge[Math.min((int)(fx * bottomEdge.length),
                    bottomEdge.length - 1)];

                // Bilinear blend: horizontal + vertical
                int hBlend = blendColors(lColor, rColor, fx);
                int vBlend = blendColors(tColor, bColor, fy);

                // Average horizontal and vertical blends
                int finalColor = blendColors(hBlend, vBlend, 0.5f);

                bmp.setPixel(x, y, finalColor);
            }
        }
    }

    private static int[] sampleEdge(Bitmap bmp, int x0, int y0, int x1, int y1) {
        if (x0 == x1) {
            // Vertical edge
            int len = Math.max(1, Math.abs(y1 - y0) + 1);
            int[] colors = new int[len];
            int minY = Math.min(y0, y1);
            int maxY = Math.max(y0, y1);
            for (int i = 0; i < len; i++) {
                int y = Math.min(bmp.getHeight() - 1, Math.max(0, minY + i));
                int x = Math.min(bmp.getWidth()  - 1, Math.max(0, x0));
                colors[i] = bmp.getPixel(x, y);
            }
            return colors;
        } else {
            // Horizontal edge
            int len = Math.max(1, Math.abs(x1 - x0) + 1);
            int[] colors = new int[len];
            int minX = Math.min(x0, x1);
            int maxX = Math.max(x0, x1);
            for (int i = 0; i < len; i++) {
                int x = Math.min(bmp.getWidth()  - 1, Math.max(0, minX + i));
                int y = Math.min(bmp.getHeight() - 1, Math.max(0, y0));
                colors[i] = bmp.getPixel(x, y);
            }
            return colors;
        }
    }

    private static int blendColors(int c1, int c2, float t) {
        int r = (int)(Color.red(c1)   * (1 - t) + Color.red(c2)   * t);
        int g = (int)(Color.green(c1) * (1 - t) + Color.green(c2) * t);
        int b = (int)(Color.blue(c1)  * (1 - t) + Color.blue(c2)  * t);
        return Color.rgb(
            Math.min(255, Math.max(0, r)),
            Math.min(255, Math.max(0, g)),
            Math.min(255, Math.max(0, b))
        );
    }
}
