```java
package com.yourapp;

import android.graphics.Bitmap;
import android.graphics.Color;

import java.util.ArrayList;
import java.util.List;

/**
 * Captures N frames, scores each by Laplacian variance (sharpness),
 * returns the sharpest one.
 */
public class SharpnessDetector {

    public interface SharpnessCallback {
        void onFrameScore(float score, float maxPossible);
        void onBestFrame(Bitmap bitmap, float score);
    }

    private static final int SAMPLE_STEP = 4; // check every 4th pixel for speed

    /**
     * Scores a bitmap's sharpness using Laplacian variance.
     * Higher = sharper. Above ~80 is good for text detection.
     */
    public static float score(Bitmap bmp) {
        int w = bmp.getWidth();
        int h = bmp.getHeight();

        // Sample centre region (text is usually centred)
        int x0 = w / 4, x1 = 3 * w / 4;
        int y0 = h / 4, y1 = 3 * h / 4;

        double mean = 0, variance = 0;
        int count = 0;
        List<Double> laplacians = new ArrayList<>();

        for (int y = y0 + 1; y < y1 - 1; y += SAMPLE_STEP) {
            for (int x = x0 + 1; x < x1 - 1; x += SAMPLE_STEP) {
                // Laplacian kernel: centre×4 - 4 neighbours
                int c  = luminance(bmp.getPixel(x,     y));
                int n  = luminance(bmp.getPixel(x,     y - 1));
                int s  = luminance(bmp.getPixel(x,     y + 1));
                int e  = luminance(bmp.getPixel(x + 1, y));
                int w2 = luminance(bmp.getPixel(x - 1, y));

                double lap = 4 * c - n - s - e - w2;
                laplacians.add(lap);
                mean += lap;
                count++;
            }
        }

        if (count == 0) return 0f;
        mean /= count;

        for (double v : laplacians)
            variance += (v - mean) * (v - mean);

        return (float)(variance / count);
    }

    private static int luminance(int pixel) {
        return (int)(0.299f * Color.red(pixel)
                   + 0.587f * Color.green(pixel)
                   + 0.114f * Color.blue(pixel));
    }

    /** Picks the sharpest from a list of bitmaps */
    public static Bitmap pickSharpest(List<Bitmap> frames) {
        Bitmap best  = frames.get(0);
        float  bestS = 0f;
        for (Bitmap b : frames) {
            float s = score(b);
            if (s > bestS) { bestS = s; best = b; }
        }
        return best;
    }
}
