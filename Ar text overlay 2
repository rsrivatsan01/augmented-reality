private ScannerOverlayView scannerOverlay;
private android.os.Vibrator vibrator;
private static final float SHARP_THRESHOLD = 60f;
private static final float SHARP_MAX = 400f;

// In bindViews():
scannerOverlay = findViewById(R.id.scanner_overlay);

// In onCreate():
vibrator = (android.os.Vibrator) getSystemService(VIBRATOR_SERVICE);
scannerOverlay.startAnimation();

// Replace captureAndProcess():
private void captureAndProcess() {
    if (isProcessing) return;
    if (spinnerTarget.getSelectedItemPosition() == 0) {
        Toast.makeText(this, "Select a target language", Toast.LENGTH_SHORT).show();
        return;
    }

    isProcessing = true;
    btnCapture.setEnabled(false);
    scannerOverlay.setState(ScannerOverlayView.State.PROCESSING);
    showLoading("Capturing 3 frames…");

    // Capture 3 frames 200ms apart, pick sharpest
    List<Bitmap> frames = new ArrayList<>();
    captureMultiFrame(frames, 3, 200, () -> {
        Bitmap sharpest = SharpnessDetector.pickSharpest(frames);

        // Haptic feedback on capture
        if (vibrator != null)
            vibrator.vibrate(android.os.VibrationEffect
                .createOneShot(40, android.os.VibrationEffect.DEFAULT_AMPLITUDE));

        int w = glSurfaceView.getWidth();
        int h = glSurfaceView.getHeight();
        runOnUiThread(() -> showLoading("Detecting text…"));
        runTextDetection(sharpest, w, h);
    });
}

private void captureMultiFrame(List<Bitmap> out, int remaining,
                                long delayMs, Runnable onDone) {
    int w = glSurfaceView.getWidth();
    int h = glSurfaceView.getHeight();
    Bitmap bmp = Bitmap.createBitmap(w, h, Bitmap.Config.ARGB_8888);

    PixelCopy.request(glSurfaceView, bmp, result -> {
        if (result == PixelCopy.SUCCESS) out.add(bmp);

        if (remaining <= 1 || out.size() == 0) {
            onDone.run();
        } else {
            new android.os.Handler(android.os.Looper.getMainLooper())
                .postDelayed(() -> captureMultiFrame(out, remaining-1, delayMs, onDone),
                    delayMs);
        }
    }, new android.os.Handler(android.os.Looper.getMainLooper()));
}

// Live sharpness feedback — call this in a background loop:
private void startSharpnessMonitor() {
    new Thread(() -> {
        while (!isProcessing) {
            try { Thread.sleep(300); } catch (InterruptedException e) { break; }
            int w = glSurfaceView.getWidth();
            int h = glSurfaceView.getHeight();
            if (w == 0 || h == 0) continue;

            Bitmap probe = Bitmap.createBitmap(w/4, h/4, Bitmap.Config.ARGB_8888);
            // Downsample for speed
            PixelCopy.request(glSurfaceView,
                new android.graphics.Rect(w/4, h/4, 3*w/4, 3*h/4),
                probe, result -> {
                    if (result == PixelCopy.SUCCESS) {
                        float score = SharpnessDetector.score(probe);
                        float normalised = Math.min(1f, score / SHARP_MAX);
                        probe.recycle();
                        runOnUiThread(() -> {
                            scannerOverlay.setSharpness(normalised);
                            if (score > SHARP_THRESHOLD) {
                                scannerOverlay.setState(
                                    ScannerOverlayView.State.SHARP);
                            } else {
                                scannerOverlay.setState(
                                    ScannerOverlayView.State.SCANNING);
                            }
                        });
                    }
                }, new android.os.Handler(android.os.Looper.getMainLooper()));
        }
    }).start();
}
