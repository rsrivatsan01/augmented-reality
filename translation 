package com.yourapp;

import com.google.mlkit.nl.translate.TranslateLanguage;
import java.util.LinkedHashMap;
import java.util.Map;

public class LanguageManager {

    // Display name → ML Kit language code
    public static final Map<String, String> LANGUAGES = new LinkedHashMap<>();

    static {
        LANGUAGES.put("Auto Detect",  "auto");
        LANGUAGES.put("English",      TranslateLanguage.ENGLISH);
        LANGUAGES.put("Hindi",        TranslateLanguage.HINDI);
        LANGUAGES.put("French",       TranslateLanguage.FRENCH);
        LANGUAGES.put("Spanish",      TranslateLanguage.SPANISH);
        LANGUAGES.put("German",       TranslateLanguage.GERMAN);
        LANGUAGES.put("Chinese",      TranslateLanguage.CHINESE);
        LANGUAGES.put("Japanese",     TranslateLanguage.JAPANESE);
        LANGUAGES.put("Korean",       TranslateLanguage.KOREAN);
        LANGUAGES.put("Arabic",       TranslateLanguage.ARABIC);
        LANGUAGES.put("Portuguese",   TranslateLanguage.PORTUGUESE);
        LANGUAGES.put("Russian",      TranslateLanguage.RUSSIAN);
        LANGUAGES.put("Italian",      TranslateLanguage.ITALIAN);
        LANGUAGES.put("Turkish",      TranslateLanguage.TURKISH);
        LANGUAGES.put("Dutch",        TranslateLanguage.DUTCH);
        LANGUAGES.put("Polish",       TranslateLanguage.POLISH);
        LANGUAGES.put("Bengali",      TranslateLanguage.BENGALI);
        LANGUAGES.put("Tamil",        TranslateLanguage.TAMIL);
        LANGUAGES.put("Telugu",       TranslateLanguage.TELUGU);
    }

    public static String[] getDisplayNames() {
        return LANGUAGES.keySet().toArray(new String[0]);
    }

    public static String getCode(String displayName) {
        return LANGUAGES.getOrDefault(displayName, TranslateLanguage.ENGLISH);
    }
}
