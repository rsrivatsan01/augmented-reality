package com.yourapp;

import android.content.Context;
import android.graphics.Bitmap;
import android.graphics.Rect;
import android.graphics.RectF;
import android.opengl.GLES20;
import android.opengl.GLSurfaceView;
import android.opengl.GLUtils;
import android.opengl.Matrix;
import android.util.Log;

import com.google.ar.core.Camera;
import com.google.ar.core.Frame;
import com.google.ar.core.Session;
import com.google.ar.core.TrackingState;

import java.nio.ByteBuffer;
import java.nio.ByteOrder;
import java.nio.FloatBuffer;
import java.util.ArrayList;
import java.util.List;

import javax.microedition.khronos.egl.EGLConfig;
import javax.microedition.khronos.opengles.GL10;

public class ARTextRenderer implements GLSurfaceView.Renderer {

    private static final String TAG = "ARTextRenderer";

    // Shader with alpha support
    private static final String VERTEX_SHADER =
        "uniform mat4 u_MVP;\n" +
        "attribute vec4 a_Position;\n" +
        "attribute vec2 a_TexCoord;\n" +
        "varying vec2 v_TexCoord;\n" +
        "void main() {\n" +
        "  gl_Position = u_MVP * a_Position;\n" +
        "  v_TexCoord = a_TexCoord;\n" +
        "}\n";

    private static final String FRAGMENT_SHADER =
        "precision mediump float;\n" +
        "uniform sampler2D u_Texture;\n" +
        "uniform float u_Alpha;\n" +
        "varying vec2 v_TexCoord;\n" +
        "void main() {\n" +
        "  vec4 c = texture2D(u_Texture, v_TexCoord);\n" +
        "  gl_FragColor = vec4(c.rgb, c.a * u_Alpha);\n" +
        "}\n";

    private static final float[] QUAD_VERTICES = {
        -0.5f,  0.25f, 0f,  0f, 0f,
        -0.5f, -0.25f, 0f,  0f, 1f,
         0.5f, -0.25f, 0f,  1f, 1f,
         0.5f,  0.25f, 0f,  1f, 0f,
    };
    private static final short[] QUAD_INDICES = {0,1,2,0,2,3};

    private final Context context;
    private Session arSession;

    // GL
    private int shaderProgram;
    private int uMVP, uTexture, uAlpha, aPosition, aTexCoord;
    private FloatBuffer quadBuffer;
    private final BackgroundRenderer backgroundRenderer = new BackgroundRenderer();

    // Anchor system
    private final AnchorLock anchorLock = new AnchorLock();

    // Textures per block (index matches anchorLock.getBlocks())
    private final List<int[]> blockTextures = new ArrayList<>();

    // Stored style + inpainted source per block for texture rebuild
    private final List<TypographyAnalyzer.FontProfile> blockProfiles = new ArrayList<>();
    private final List<Bitmap> blockInpaintedBitmaps = new ArrayList<>();
    private final List<Rect>   blockSourceBoxes = new ArrayList<>();

    // Pending placements (from main thread → GL thread)
    private static class PendingBlock {
        RectF screenBounds;
        String original, translated;
        TypographyAnalyzer.FontProfile profile;
        Bitmap inpainted;
        Rect sourceBox;
    }
    private final List<PendingBlock> pendingBlocks = new ArrayList<>();
    private final Object pendingLock = new Object();

    // Pose smoothers (only used pre-lock)
    private final List<PoseInterpolator> smoothers = new ArrayList<>();

    // Matrices
    private final float[] projMatrix = new float[16];
    private final float[] viewMatrix = new float[16];
    private final float[] mvpMatrix  = new float[16];

    // Callback
    public interface FrameCallback {
        void onBlocksUpdated(List<AnchorLock.LockedBlock> blocks, float[] projMatrix, float[] viewMatrix);
        void onPlaneFound();
    }
    private final FrameCallback frameCallback;
    private boolean planeFound = false;

    public ARTextRenderer(Context context, FrameCallback callback) {
        this.context       = context;
        this.frameCallback = callback;
    }

    public void setSession(Session s) { this.arSession = s; }

    // ── Called from main thread ────────────────────────────────────────────

    public void placeBlocks(Frame frame,
                            List<String> originals,
                            List<String> translated,
                            List<RectF> screenBounds,
                            List<TypographyAnalyzer.FontProfile> profiles,
                            List<Bitmap> inpainted,
                            List<Rect> sourceBoxes,
                            int viewW, int viewH) {

        anchorLock.clearAll();

        synchronized (pendingLock) {
            pendingBlocks.clear();
            blockTextures.clear();
            blockProfiles.clear();
            blockInpaintedBitmaps.clear();
            blockSourceBoxes.clear();
            smoothers.clear();

            for (int i = 0; i < translated.size(); i++) {
                AnchorLock.LockedBlock lb = anchorLock.createBlock(
                    frame, arSession,
                    screenBounds.get(i),
                    originals.get(i),
                    translated.get(i),
                    viewW, viewH);

                if (lb == null) continue;

                PendingBlock pb = new PendingBlock();
                pb.screenBounds = screenBounds.get(i);
                pb.original     = originals.get(i);
                pb.translated   = translated.get(i);
                pb.profile      = profiles.get(i);
                pb.inpainted    = inpainted.get(i);
                pb.sourceBox    = sourceBoxes.get(i);
                pendingBlocks.add(pb);
            }
        }
    }

    // ── GL lifecycle ───────────────────────────────────────────────────────

    @Override
    public void onSurfaceCreated(GL10 gl, EGLConfig config) {
        GLES20.glClearColor(0f, 0f, 0f, 1f);
        try { backgroundRenderer.createOnGlThread(context); }
        catch (Exception e) { Log.e(TAG, "BG renderer failed", e); }

        shaderProgram = buildShaderProgram();
        uMVP      = GLES20.glGetUniformLocation(shaderProgram, "u_MVP");
        uTexture  = GLES20.glGetUniformLocation(shaderProgram, "u_Texture");
        uAlpha    = GLES20.glGetUniformLocation(shaderProgram, "u_Alpha");
        aPosition = GLES20.glGetAttribLocation(shaderProgram,  "a_Position");
        aTexCoord = GLES20.glGetAttribLocation(shaderProgram,  "a_TexCoord");

        ByteBuffer bb = ByteBuffer.allocateDirect(QUAD_VERTICES.length * 4);
        bb.order(ByteOrder.nativeOrder());
        quadBuffer = bb.asFloatBuffer();
        quadBuffer.put(QUAD_VERTICES).position(0);
    }

    @Override
    public void onSurfaceChanged(GL10 gl, int width, int height) {
        GLES20.glViewport(0, 0, width, height);
        if (arSession != null) {
            arSession.setDisplayGeometry(
                ((android.app.Activity) context)
                    .getWindowManager().getDefaultDisplay().getRotation(),
                width, height);
        }
    }

    @Override
    public void onDrawFrame(GL10 gl) {
        GLES20.glClear(GLES20.GL_COLOR_BUFFER_BIT | GLES20.GL_DEPTH_BUFFER_BIT);
        if (arSession == null) return;

        try {
            arSession.setCameraTextureName(backgroundRenderer.getTextureId());
            Frame  frame  = arSession.update();
            Camera camera = frame.getCamera();

            // ── 1. Camera feed ─────────────────────────────────────────────
            backgroundRenderer.draw(frame);
            if (camera.getTrackingState() != TrackingState.TRACKING) return;

            // ── 2. Plane detection notify ──────────────────────────────────
            if (!planeFound) {
                for (com.google.ar.core.Plane p :
                        arSession.getAllTrackables(com.google.ar.core.Plane.class)) {
                    if (p.getTrackingState() == TrackingState.TRACKING) {
                        planeFound = true;
                        ((android.app.Activity) context)
                            .runOnUiThread(frameCallback::onPlaneFound);
                        break;
                    }
                }
            }

            // ── 3. Upload pending block textures ───────────────────────────
            synchronized (pendingLock) {
                for (PendingBlock pb : pendingBlocks) {
                    int[] texId = new int[1];
                    GLES20.glGenTextures(1, texId, 0);

                    float aspect = pb.profile.blockHeightPx > 0
                        ? pb.profile.blockWidthPx / pb.profile.blockHeightPx : 2f;

                    Bitmap bmp = FlagshipBillboard.create(
                        pb.inpainted, pb.sourceBox,
                        pb.translated, pb.profile, 1f);

                    uploadTexture(texId[0], bmp);
                    bmp.recycle();

                    blockTextures.add(texId);
                    blockProfiles.add(pb.profile);
                    blockInpaintedBitmaps.add(pb.inpainted);
                    blockSourceBoxes.add(pb.sourceBox);
                    smoothers.add(new PoseInterpolator(0.15f));
                }
                pendingBlocks.clear();
            }

            // ── 4. Update anchor lock system ───────────────────────────────
            anchorLock.updateAll();

            // ── 5. Get camera matrices ─────────────────────────────────────
            camera.getProjectionMatrix(projMatrix, 0, 0.05f, 100f);
            camera.getViewMatrix(viewMatrix, 0);

            // ── 6. Draw blocks ─────────────────────────────────────────────
            GLES20.glEnable(GLES20.GL_BLEND);
            GLES20.glBlendFunc(GLES20.GL_SRC_ALPHA, GLES20.GL_ONE_MINUS_SRC_ALPHA);
            GLES20.glDepthMask(false);
            GLES20.glUseProgram(shaderProgram);

            List<AnchorLock.LockedBlock> blocks = anchorLock.getBlocks();

            for (int i = 0; i < blocks.size() && i < blockTextures.size(); i++) {
                AnchorLock.LockedBlock b = blocks.get(i);

                float[] matrix = anchorLock.getRenderMatrix(b);
                if (matrix == null) continue;

                // Smooth pre-lock only
                if (b.state != AnchorLock.LockState.LOCKED) {
                    matrix = smoothers.get(i).smooth(matrix);
                }

                // Surface-aligned billboard (not camera-facing when locked)
                float[] modelMatrix = b.state == AnchorLock.LockState.LOCKED
                    ? makeSurfaceAligned(matrix, b.blockWidthMeters)
                    : makeBillboard(matrix, viewMatrix, b.blockWidthMeters);

                float[] mv = new float[16];
                Matrix.multiplyMM(mv, 0, viewMatrix, 0, modelMatrix, 0);
                Matrix.multiplyMM(mvpMatrix, 0, projMatrix, 0, mv, 0);

                GLES20.glUniformMatrix4fv(uMVP, 1, false, mvpMatrix, 0);
                GLES20.glUniform1f(uAlpha, b.fadeAlpha);

                GLES20.glActiveTexture(GLES20.GL_TEXTURE0);
                GLES20.glBindTexture(GLES20.GL_TEXTURE_2D, blockTextures.get(i)[0]);
                GLES20.glUniform1i(uTexture, 0);

                drawQuad();
            }

            GLES20.glDepthMask(true);
            GLES20.glDisable(GLES20.GL_BLEND);

            // Notify UI for lock indicators
            if (frameCallback != null) {
                final List<AnchorLock.LockedBlock> snap = new ArrayList<>(blocks);
                final float[] proj = projMatrix.clone();
                final float[] view = viewMatrix.clone();
                ((android.app.Activity) context).runOnUiThread(
                    () -> frameCallback.onBlocksUpdated(snap, proj, view));
            }

        } catch (Exception e) {
            Log.e(TAG, "Frame error: " + e.getMessage());
        }
    }

    /**
     * Surface-aligned: locked overlay lies flat on the real surface.
     * Uses the plane normal from the frozen matrix.
     */
    private float[] makeSurfaceAligned(float[] anchorMatrix, float widthMeters) {
        float[] result = anchorMatrix.clone();
        // Scale X and Y axes by block size
        result[0]  *= widthMeters;
        result[1]  *= widthMeters;
        result[2]  *= widthMeters;
        result[4]  *= widthMeters * 0.5f;
        result[5]  *= widthMeters * 0.5f;
        result[6]  *= widthMeters * 0.5f;
        return result;
    }

    private float[] makeBillboard(float[] anchorMatrix,
                                   float[] viewMatrix, float widthMeters) {
        float[] result = new float[16];
        Matrix.setIdentityM(result, 0);
        result[0]=viewMatrix[0]; result[1]=viewMatrix[4]; result[2]=viewMatrix[8];
        result[4]=viewMatrix[1]; result[5]=viewMatrix[5]; result[6]=viewMatrix[9];
        result[8]=viewMatrix[2]; result[9]=viewMatrix[6]; result[10]=viewMatrix[10];
        result[0]*=widthMeters; result[1]*=widthMeters; result[2]*=widthMeters;
        result[4]*=widthMeters*0.5f;
        result[5]*=widthMeters*0.5f;
        result[6]*=widthMeters*0.5f;
        result[12]=anchorMatrix[12];
        result[13]=anchorMatrix[13];
        result[14]=anchorMatrix[14];
        result[15]=1f;
        return result;
    }

    private void drawQuad() {
        int stride = 5 * 4;
        quadBuffer.position(0);
        GLES20.glEnableVertexAttribArray(aPosition);
        GLES20.glEnableVertexAttribArray(aTexCoord);
        GLES20.glVertexAttribPointer(aPosition, 3,
            GLES20.GL_FLOAT, false, stride, quadBuffer);
        quadBuffer.position(3);
        GLES20.glVertexAttribPointer(aTexCoord, 2,
            GLES20.GL_FLOAT, false, stride, quadBuffer);

        ByteBuffer ib = ByteBuffer.allocateDirect(12).order(ByteOrder.nativeOrder());
        ib.asShortBuffer().put(QUAD_INDICES).position(0);
        GLES20.glDrawElements(GLES20.GL_TRIANGLES, 6,
            GLES20.GL_UNSIGNED_SHORT, ib.asShortBuffer());

        GLES20.glDisableVertexAttribArray(aPosition);
        GLES20.glDisableVertexAttribArray(aTexCoord);
    }

    private void uploadTexture(int id, Bitmap bmp) {
        GLES20.glBindTexture(GLES20.GL_TEXTURE_2D, id);
        GLES20.glTexParameteri(GLES20.GL_TEXTURE_2D,
            GLES20.GL_TEXTURE_MIN_FILTER, GLES20.GL_LINEAR);
        GLES20.glTexParameteri(GLES20.GL_TEXTURE_2D,
            GLES20.GL_TEXTURE_MAG_FILTER, GLES20.GL_LINEAR);
        GLUtils.texImage2D(GLES20.GL_TEXTURE_2D, 0, bmp, 0);
    }

    private int buildShaderProgram() {
        int vs = compile(GLES20.GL_VERTEX_SHADER,   VERTEX_SHADER);
        int fs = compile(GLES20.GL_FRAGMENT_SHADER, FRAGMENT_SHADER);
        int p  = GLES20.glCreateProgram();
        GLES20.glAttachShader(p, vs);
        GLES20.glAttachShader(p, fs);
        GLES20.glLinkProgram(p);
        return p;
    }

    private int compile(int type, String src) {
        int s = GLES20.glCreateShader(type);
        GLES20.glShaderSource(s, src);
        GLES20.glCompileShader(s);
        return s;
    }

    public void clearAll() {
        anchorLock.clearAll();
        synchronized (pendingLock) { pendingBlocks.clear(); }
        blockTextures.clear();
        blockProfiles.clear();
        blockInpaintedBitmaps.clear();
        blockSourceBoxes.clear();
        smoothers.clear();
        planeFound = false;
    }
}
