## `LockIndicatorView.java` — Per-block lock confirmation UI
```java
package com.yourapp;

import android.content.Context;
import android.graphics.Canvas;
import android.graphics.Color;
import android.graphics.Paint;
import android.graphics.RectF;
import android.util.AttributeSet;
import android.view.View;

import java.util.ArrayList;
import java.util.List;

/**
 * Draws per-block confidence rings + lock animation
 * on top of the GL surface view.
 * Each block gets:
 *  - BUILDING:    spinning cyan arc (confidence %)
 *  - CONFIRMING:  full ring pulsing yellow
 *  - LOCKED:      green checkmark burst that fades out
 */
public class LockIndicatorView extends View {

    public static class BlockIndicator {
        public float screenX, screenY; // centre in screen coords
        public AnchorLock.LockState state;
        public float confidence;        // 0→1
        public float lockAnimProgress;  // 0→1
        public boolean animDone = false;
    }

    private final List<BlockIndicator> indicators = new ArrayList<>();

    private final Paint ringBgPaint  = new Paint();
    private final Paint ringFillPaint= new Paint();
    private final Paint checkPaint   = new Paint();
    private final Paint burstPaint   = new Paint();
    private final Paint labelPaint   = new Paint();

    private float animPhase = 0f;
    private final android.os.Handler handler = new android.os.Handler();
    private final Runnable ticker = new Runnable() {
        @Override public void run() {
            animPhase += 0.07f;
            if (animPhase > (float)(Math.PI*2)) animPhase = 0f;
            invalidate();
            handler.postDelayed(this, 16);
        }
    };

    public LockIndicatorView(Context context, AttributeSet attrs) {
        super(context, attrs);
        setWillNotDraw(false);

        ringBgPaint.setStyle(Paint.Style.STROKE);
        ringBgPaint.setStrokeWidth(5f);
        ringBgPaint.setColor(Color.argb(60, 255, 255, 255));
        ringBgPaint.setAntiAlias(true);

        ringFillPaint.setStyle(Paint.Style.STROKE);
        ringFillPaint.setStrokeWidth(5f);
        ringFillPaint.setAntiAlias(true);
        ringFillPaint.setStrokeCap(Paint.Cap.ROUND);

        checkPaint.setStyle(Paint.Style.STROKE);
        checkPaint.setStrokeWidth(7f);
        checkPaint.setColor(Color.parseColor("#00FF8C"));
        checkPaint.setStrokeCap(Paint.Cap.ROUND);
        checkPaint.setAntiAlias(true);

        burstPaint.setStyle(Paint.Style.STROKE);
        burstPaint.setStrokeWidth(3f);
        burstPaint.setAntiAlias(true);

        labelPaint.setTextSize(24f);
        labelPaint.setAntiAlias(true);
        labelPaint.setTextAlign(Paint.Align.CENTER);
    }

    public void startAnimation() { handler.post(ticker); }
    public void stopAnimation()  { handler.removeCallbacks(ticker); }

    public void setIndicators(List<BlockIndicator> list) {
        indicators.clear();
        indicators.addAll(list);
        invalidate();
    }

    @Override
    protected void onDraw(Canvas canvas) {
        super.onDraw(canvas);

        for (BlockIndicator ind : indicators) {
            if (ind.animDone) continue;

            float cx = ind.screenX;
            float cy = ind.screenY;
            float r  = 36f;
            RectF oval = new RectF(cx-r, cy-r, cx+r, cy+r);

            switch (ind.state) {

                case BUILDING: {
                    // Spinning arc showing confidence
                    canvas.drawOval(oval, ringBgPaint);

                    ringFillPaint.setColor(Color.parseColor("#00E5FF"));
                    float sweep = ind.confidence * 360f;
                    float start = (animPhase * 180f / (float)Math.PI) * 2f;
                    canvas.drawArc(oval, start, sweep, false, ringFillPaint);

                    // Confidence % label
                    labelPaint.setColor(Color.parseColor("#AAFFFFFF"));
                    canvas.drawText(
                        (int)(ind.confidence*100)+"%",
                        cx, cy + 8f, labelPaint);
                    break;
                }

                case CONFIRMING: {
                    // Full pulsing yellow ring
                    float pulse = (float)(Math.sin(animPhase*2)*0.3f+0.7f);
                    ringFillPaint.setColor(Color.argb(
                        (int)(255*pulse), 255, 215, 0));
                    canvas.drawOval(oval, ringFillPaint);

                    labelPaint.setColor(Color.parseColor("#FFD700"));
                    canvas.drawText("Locking…", cx, cy+r+24f, labelPaint);
                    break;
                }

                case LOCKED: {
                    float p = ind.lockAnimProgress;

                    if (p < 1f) {
                        // Burst: expanding rings fading out
                        for (int i = 0; i < 3; i++) {
                            float delay = i * 0.2f;
                            float bp = Math.max(0f, p - delay);
                            if (bp <= 0f) continue;
                            float br = r + bp * 60f;
                            int ba = (int)(255 * (1f - bp));
                            burstPaint.setColor(Color.argb(ba, 0, 255, 140));
                            RectF bOval = new RectF(cx-br,cy-br,cx+br,cy+br);
                            canvas.drawOval(bOval, burstPaint);
                        }

                        // Checkmark draws in
                        float checkP = Math.min(1f, p * 2f);
                        if (checkP > 0f) {
                            // Two-stroke checkmark
                            float x1=cx-r*0.45f, y1=cy;
                            float x2=cx-r*0.1f, y2=cy+r*0.45f;
                            float x3=cx+r*0.5f, y3=cy-r*0.4f;

                            if (checkP < 0.5f) {
                                float t = checkP / 0.5f;
                                canvas.drawLine(x1,y1,
                                    x1+(x2-x1)*t, y1+(y2-y1)*t, checkPaint);
                            } else {
                                float t = (checkP-0.5f)/0.5f;
                                canvas.drawLine(x1,y1,x2,y2,checkPaint);
                                canvas.drawLine(x2,y2,
                                    x2+(x3-x2)*t, y2+(y3-y2)*t, checkPaint);
                            }
                        }

                        // Green locked label
                        if (p > 0.6f) {
                            int la = (int)(255*(p-0.6f)/0.4f);
                            labelPaint.setColor(Color.argb(la,0,255,140));
                            canvas.drawText("Locked", cx, cy+r+24f, labelPaint);
                        }

                    } else {
                        // Animation done — mark to stop drawing
                        ind.animDone = true;
                    }
                    break;
                }
            }
        }
    }
}
