## `AnchorLock.java` — 3-point anchor system with confidence scoring
```java
package com.yourapp;

import com.google.ar.core.Anchor;
import com.google.ar.core.Camera;
import com.google.ar.core.Frame;
import com.google.ar.core.HitResult;
import com.google.ar.core.Plane;
import com.google.ar.core.Pose;
import com.google.ar.core.Session;
import com.google.ar.core.TrackingState;

import java.util.ArrayList;
import java.util.List;

/**
 * Places 3 anchors per text block (top-left, top-right, bottom-centre).
 * Each frame averages their poses → stable centre.
 * Once confidence threshold met → freezes pose permanently.
 */
public class AnchorLock {

    public enum LockState { BUILDING, CONFIRMING, LOCKED }

    // Per-block data
    public static class LockedBlock {
        public Anchor anchorTL, anchorTR, anchorBC; // 3-point triangle
        public float[] frozenMatrix;   // final frozen 4×4 pose
        public LockState state = LockState.BUILDING;
        public float confidence = 0f;  // 0→1
        public int stableFrames = 0;   // frames within threshold
        public float[] lastMatrix;
        public String translatedText;
        public String originalText;
        public float blockWidthMeters;

        // Animation
        public float lockAnimProgress = 0f; // 0→1 for lock-in animation
        public float fadeAlpha = 0f;         // fade-in
    }

    private static final int STABLE_FRAMES_NEEDED = 45;  // ~1.5s at 30fps
    private static final float STABLE_THRESHOLD   = 0.008f; // 8mm drift tolerance
    private static final float FADE_SPEED         = 0.05f;
    private static final float LOCK_ANIM_SPEED    = 0.04f;

    private final List<LockedBlock> blocks = new ArrayList<>();
    private final Object lock = new Object();

    /**
     * Place 3 anchors for a text block using hit-tests at 3 screen points.
     */
    public LockedBlock createBlock(Frame frame,
                                   Session session,
                                   android.graphics.RectF screenBounds,
                                   String original,
                                   String translated,
                                   int viewW, int viewH) {
        float cx = (screenBounds.left + screenBounds.right)  / 2f;
        float cy = (screenBounds.top  + screenBounds.bottom) / 2f;
        float left  = screenBounds.left;
        float right = screenBounds.right;
        float top   = screenBounds.top;
        float bot   = screenBounds.bottom;

        // 3 hit-test points: top-left, top-right, bottom-centre
        Anchor aTL = hitTestAnchor(frame, session, left,  top, viewW, viewH);
        Anchor aTR = hitTestAnchor(frame, session, right, top, viewW, viewH);
        Anchor aBC = hitTestAnchor(frame, session, cx,    bot, viewW, viewH);

        if (aTL == null && aTR == null && aBC == null) return null;

        // Fallback: place any missing anchor at camera + 0.5m forward
        if (aTL == null) aTL = fallbackAnchor(session, frame, -0.1f, 0f);
        if (aTR == null) aTR = fallbackAnchor(session, frame,  0.1f, 0f);
        if (aBC == null) aBC = fallbackAnchor(session, frame,  0f,  -0.1f);

        LockedBlock b = new LockedBlock();
        b.anchorTL         = aTL;
        b.anchorTR         = aTR;
        b.anchorBC         = aBC;
        b.originalText     = original;
        b.translatedText   = translated;
        b.blockWidthMeters = estimateWidth(aTL, aTR);

        synchronized (lock) { blocks.add(b); }
        return b;
    }

    /**
     * Call every GL frame. Updates each block's pose, confidence, lock state.
     * Returns true if any block changed state (needs texture rebuild).
     */
    public boolean updateAll() {
        boolean changed = false;
        synchronized (lock) {
            for (LockedBlock b : blocks) {
                if (b.state == LockState.LOCKED) {
                    // Frozen — just animate
                    b.lockAnimProgress = Math.min(1f,
                        b.lockAnimProgress + LOCK_ANIM_SPEED);
                    b.fadeAlpha = Math.min(1f, b.fadeAlpha + FADE_SPEED);
                    continue;
                }

                if (!allTracking(b)) continue;

                // Average the 3 anchor poses
                float[] avg = averagePose(b);
                b.fadeAlpha = Math.min(1f, b.fadeAlpha + FADE_SPEED);

                if (b.lastMatrix != null) {
                    float drift = poseDrift(b.lastMatrix, avg);

                    if (drift < STABLE_THRESHOLD) {
                        b.stableFrames++;
                        b.confidence = Math.min(1f,
                            (float) b.stableFrames / STABLE_FRAMES_NEEDED);
                    } else {
                        // Drifting — reset counter
                        b.stableFrames = Math.max(0, b.stableFrames - 2);
                        b.confidence   = (float) b.stableFrames / STABLE_FRAMES_NEEDED;
                    }

                    // Transition states
                    if (b.stableFrames >= STABLE_FRAMES_NEEDED * 0.7f
                            && b.state == LockState.BUILDING) {
                        b.state = LockState.CONFIRMING;
                        changed = true;
                    }

                    if (b.stableFrames >= STABLE_FRAMES_NEEDED
                            && b.state == LockState.CONFIRMING) {
                        // LOCK IT — freeze the pose permanently
                        b.frozenMatrix = avg.clone();
                        b.state        = LockState.LOCKED;
                        b.lockAnimProgress = 0f;

                        // Detach anchors — no longer needed
                        b.anchorTL.detach();
                        b.anchorTR.detach();
                        b.anchorBC.detach();
                        b.anchorTL = null;
                        b.anchorTR = null;
                        b.anchorBC = null;
                        changed = true;
                    }
                }

                b.lastMatrix = avg;
            }
        }
        return changed;
    }

    /**
     * Returns the best current matrix for rendering this block.
     * Uses frozen matrix if locked, otherwise live average.
     */
    public float[] getRenderMatrix(LockedBlock b) {
        if (b.state == LockState.LOCKED && b.frozenMatrix != null) {
            return b.frozenMatrix;
        }
        if (!allTracking(b)) return b.lastMatrix;
        return averagePose(b);
    }

    // ── Internals ──────────────────────────────────────────────────────────

    private Anchor hitTestAnchor(Frame frame, Session session,
                                  float screenX, float screenY,
                                  int viewW, int viewH) {
        try {
            List<HitResult> hits = frame.hitTest(screenX, screenY);
            for (HitResult hit : hits) {
                if (hit.getTrackable() instanceof Plane) {
                    Plane plane = (Plane) hit.getTrackable();
                    if (plane.getTrackingState() == TrackingState.TRACKING
                            && plane.getSubsumedBy() == null) {
                        return hit.createAnchor();
                    }
                }
                // Also accept point cloud hits for non-planar surfaces
                if (hit.getTrackable() instanceof
                        com.google.ar.core.PointCloud) {
                    return hit.createAnchor();
                }
            }
        } catch (Exception e) { /* ignore */ }
        return null;
    }

    private Anchor fallbackAnchor(Session session, Frame frame,
                                   float offsetX, float offsetZ) {
        try {
            Pose camPose = frame.getCamera().getPose();
            float[] t    = camPose.getTranslation();
            float[] fwd  = camPose.getZAxis();
            Pose pose    = Pose.makeTranslation(
                t[0] + offsetX - fwd[0]*0.5f,
                t[1]           - fwd[1]*0.5f,
                t[2] + offsetZ - fwd[2]*0.5f);
            return session.createAnchor(pose);
        } catch (Exception e) { return null; }
    }

    /** Average translation of 3 anchors, keep TL's rotation */
    private float[] averagePose(LockedBlock b) {
        float[] mTL = new float[16];
        float[] mTR = new float[16];
        float[] mBC = new float[16];
        b.anchorTL.getPose().toMatrix(mTL, 0);
        b.anchorTR.getPose().toMatrix(mTR, 0);
        b.anchorBC.getPose().toMatrix(mBC, 0);

        float[] avg = mTL.clone();
        // Average translation columns only (indices 12,13,14)
        avg[12] = (mTL[12] + mTR[12] + mBC[12]) / 3f;
        avg[13] = (mTL[13] + mTR[13] + mBC[13]) / 3f;
        avg[14] = (mTL[14] + mTR[14] + mBC[14]) / 3f;
        return avg;
    }

    /** Euclidean distance between translation parts of two matrices */
    private float poseDrift(float[] a, float[] b) {
        float dx = a[12]-b[12], dy = a[13]-b[13], dz = a[14]-b[14];
        return (float)Math.sqrt(dx*dx + dy*dy + dz*dz);
    }

    private boolean allTracking(LockedBlock b) {
        return b.anchorTL != null
            && b.anchorTR != null
            && b.anchorBC != null
            && b.anchorTL.getTrackingState() == TrackingState.TRACKING
            && b.anchorTR.getTrackingState() == TrackingState.TRACKING
            && b.anchorBC.getTrackingState() == TrackingState.TRACKING;
    }

    private float estimateWidth(Anchor a1, Anchor a2) {
        if (a1 == null || a2 == null) return 0.2f;
        float[] m1 = new float[16]; a1.getPose().toMatrix(m1, 0);
        float[] m2 = new float[16]; a2.getPose().toMatrix(m2, 0);
        float dx = m1[12]-m2[12], dy = m1[13]-m2[13], dz = m1[14]-m2[14];
        float dist = (float)Math.sqrt(dx*dx+dy*dy+dz*dz);
        return Math.max(0.05f, Math.min(dist, 2.0f));
    }

    public List<LockedBlock> getBlocks() { return blocks; }

    public void clearAll() {
        synchronized (lock) {
            for (LockedBlock b : blocks) {
                if (b.anchorTL != null) b.anchorTL.detach();
                if (b.anchorTR != null) b.anchorTR.detach();
                if (b.anchorBC != null) b.anchorBC.detach();
            }
            blocks.clear();
        }
    }
}
