    // ── PIPELINE ───────────────────────────────────────────────────────────

    private void scan() {
        if (busy) return;
        if (spnTgt.getSelectedItemPosition() == 0) {
            Toast.makeText(this,
                "Select a target language", Toast.LENGTH_SHORT).show();
            return;
        }

        busy = true;
        btnScan.setEnabled(false);
        loading("Capturing…");

        int w = glView.getWidth();
        int h = glView.getHeight();
        Bitmap bmp = Bitmap.createBitmap(w, h, Bitmap.Config.ARGB_8888);

        PixelCopy.request(glView, bmp, result -> {
            if (result != PixelCopy.SUCCESS) {
                runOnUiThread(() -> {
                    hideLoading(); status("Capture failed");
                    reset();
                });
                return;
            }

            runOnUiThread(() -> loading("Detecting text…"));

            // ── Step 1: ML Kit OCR ─────────────────────────────────────────
            ocr.process(InputImage.fromBitmap(bmp, 0))
                .addOnSuccessListener(mlResult -> {

                    if (mlResult.getTextBlocks().isEmpty()) {
                        runOnUiThread(() -> {
                            hideLoading();
                            status("No text detected");
                            reset();
                        });
                        return;
                    }

                    // Build TextBlock list with bitmapBounds + colour info
                    List<TextBlock>  textBlocks = new ArrayList<>();
                    List<String>     originals  = new ArrayList<>();

                    for (Text.TextBlock tb : mlResult.getTextBlocks()) {
                        if (tb.getBoundingBox() == null) continue;
                        if (tb.getText().trim().isEmpty()) continue;

                        TextBlock b = new TextBlock();
                        b.original  = tb.getText().trim();
                        originals.add(b.original);

                        // bitmapBounds in bitmap pixel coords
                        // bitmap == screen since PixelCopy captures glView
                        Rect r = tb.getBoundingBox();
                        b.bitmapBounds = new RectF(
                            r.left, r.top, r.right, r.bottom);

                        // Sample colours from the captured bitmap
                        BitmapAnalyzer.analyze(bmp, b);

                        textBlocks.add(b);
                    }

                    if (textBlocks.isEmpty()) {
                        runOnUiThread(() -> {
                            hideLoading(); status("No valid blocks"); reset();
                        });
                        return;
                    }

                    runOnUiThread(() -> loading("Translating…"));

                    String src = LanguageManager.getCode(
                        spnSrc.getSelectedItem().toString());
                    String tgt = LanguageManager.getCode(
                        spnTgt.getSelectedItem().toString());

                    // ── Step 2: ML Kit Translate ───────────────────────────
                    translator.translate(originals, src, tgt,
                        new TranslationProcessor.Callback() {

                        @Override
                        public void onDone(List<String> results) {
                            // Map translations back 1-to-1
                            for (int i = 0; i < results.size()
                                    && i < textBlocks.size(); i++) {
                                textBlocks.get(i).translated = results.get(i);
                            }

                            runOnUiThread(() -> loading("Placing in AR…"));

                            // ── Step 3: Place in ARCore ────────────────────
                            try {
                                Frame frame = arSession.update();
                                int vW = glView.getWidth();
                                int vH = glView.getHeight();

                                // Queue onto GL thread
                                glView.queueEvent(() ->
                                    renderer.queuePlacement(
                                        textBlocks, frame, vW, vH));

                                runOnUiThread(() -> {
                                    hideLoading();
                                    status("✅ "
                                        + textBlocks.size()
                                        + " block(s) placed — locking…");
                                    btnClear.setVisibility(View.VISIBLE);
                                    vibrate();
                                    busy = false;
                                });

                            } catch (Exception e) {
                                runOnUiThread(() -> {
                                    hideLoading();
                                    status("AR error: " + e.getMessage());
                                    reset();
                                });
                            }
                        }

                        @Override
                        public void onError(String msg) {
                            runOnUiThread(() -> {
                                hideLoading();
                                status("Translation error: " + msg);
                                reset();
                            });
                        }

                        @Override
                        public void onStatus(String msg) {
                            runOnUiThread(() -> loading(msg));
                        }
                    });
                })
                .addOnFailureListener(e -> runOnUiThread(() -> {
                    hideLoading();
                    status("OCR failed: " + e.getMessage());
                    reset();
