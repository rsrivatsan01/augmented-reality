## `BitmapAnalyzer.java` — Correct colour sampling, no pixel cluster magic
```java
package com.yourapp;

import android.graphics.Bitmap;
import android.graphics.Color;
import android.graphics.Rect;

/**
 * Samples pixels OUTSIDE the text bounding box (border strip)
 * for background colour — avoids text pixels entirely.
 * Samples pixels INSIDE for dominant non-background colour = text colour.
 */
public class BitmapAnalyzer {

    public static void analyze(Bitmap bmp, TextBlock block) {
        Rect r = new Rect(
            (int) block.bitmapBounds.left,
            (int) block.bitmapBounds.top,
            (int) block.bitmapBounds.right,
            (int) block.bitmapBounds.bottom);

        // Clamp
        r.left   = Math.max(0, r.left);
        r.top    = Math.max(0, r.top);
        r.right  = Math.min(bmp.getWidth()  - 1, r.right);
        r.bottom = Math.min(bmp.getHeight() - 1, r.bottom);

        if (r.isEmpty()) {
            block.bgColor   = Color.WHITE;
            block.textColor = Color.BLACK;
            block.fontSizePx= 32f;
            block.isBold    = false;
            return;
        }

        // ── Sample border OUTSIDE box for background colour ────────────────
        block.bgColor = sampleOuterBorder(bmp, r);

        // ── Sample INSIDE box for text colour ──────────────────────────────
        block.textColor = sampleInnerText(bmp, r, block.bgColor);

        // ── Font size: box height / estimated line count ───────────────────
        int lineCount   = Math.max(1, countTextLines(bmp, r, block.bgColor));
        block.fontSizePx= Math.max(16f,
            Math.min(120f, (r.height() / (float) lineCount) * 0.75f));

        // ── Bold: average stroke width > 12% of font size ─────────────────
        block.isBold    = averageStrokeWidth(bmp, r, block.bgColor)
            > block.fontSizePx * 0.12f;
    }

    // Sample a 6px strip OUTSIDE the bounding box
    private static int sampleOuterBorder(Bitmap bmp, Rect r) {
        long R=0, G=0, B=0; long n=0;
        int strip = 6;

        // Top strip
        for (int x = r.left; x <= r.right; x++) {
            for (int y = Math.max(0, r.top - strip); y < r.top; y++) {
                int px = bmp.getPixel(x, y);
                R+=Color.red(px); G+=Color.green(px); B+=Color.blue(px); n++;
            }
        }
        // Bottom strip
        for (int x = r.left; x <= r.right; x++) {
            for (int y = r.bottom + 1;
                 y <= Math.min(bmp.getHeight()-1, r.bottom + strip); y++) {
                int px = bmp.getPixel(x, y);
                R+=Color.red(px); G+=Color.green(px); B+=Color.blue(px); n++;
            }
        }
        // Left strip
        for (int y = r.top; y <= r.bottom; y++) {
            for (int x = Math.max(0, r.left - strip); x < r.left; x++) {
                int px = bmp.getPixel(x, y);
                R+=Color.red(px); G+=Color.green(px); B+=Color.blue(px); n++;
            }
        }
        // Right strip
        for (int y = r.top; y <= r.bottom; y++) {
            for (int x = r.right + 1;
                 x <= Math.min(bmp.getWidth()-1, r.right + strip); x++) {
                int px = bmp.getPixel(x, y);
                R+=Color.red(px); G+=Color.green(px); B+=Color.blue(px); n++;
            }
        }

        if (n == 0) return Color.WHITE;
        return Color.rgb((int)(R/n), (int)(G/n), (int)(B/n));
    }

    // Find the most common non-background colour inside the box
    private static int sampleInnerText(Bitmap bmp, Rect r, int bgColor) {
        float bgL = lum(bgColor);
        long R=0, G=0, B=0; long n=0;

        // Sample every 3rd pixel for speed
        for (int y = r.top; y <= r.bottom; y += 3) {
            for (int x = r.left; x <= r.right; x += 3) {
                int px = bmp.getPixel(x, y);
                float diff = Math.abs(lum(px) - bgL);
                // Only count pixels that differ significantly from background
                if (diff > 40f) {
                    R+=Color.red(px); G+=Color.green(px);
                    B+=Color.blue(px); n++;
                }
            }
        }

        if (n == 0) {
            // Fallback: invert background
            return Color.rgb(
                255 - Color.red(bgColor),
                255 - Color.green(bgColor),
                255 - Color.blue(bgColor));
        }
        return Color.rgb((int)(R/n), (int)(G/n), (int)(B/n));
    }

    // Count horizontal runs of text pixels to estimate line count
    private static int countTextLines(Bitmap bmp, Rect r, int bgColor) {
        float bgL = lum(bgColor);
        int lines = 0; boolean inLine = false;

        for (int y = r.top; y <= r.bottom; y++) {
            int textPixels = 0;
            for (int x = r.left; x <= r.right; x += 2) {
                if (Math.abs(lum(bmp.getPixel(x, y)) - bgL) > 40f)
                    textPixels++;
            }
            boolean hasText = textPixels > (r.width() / 6);
            if (hasText && !inLine) { lines++; inLine = true; }
            else if (!hasText)        inLine = false;
        }
        return Math.max(1, lines);
    }

    // Average horizontal run length of text pixels
    private static float averageStrokeWidth(Bitmap bmp, Rect r, int bgColor) {
        float bgL = lum(bgColor);
        float total = 0; int count = 0;
        int midY = (r.top + r.bottom) / 2;

        int run = 0;
        for (int x = r.left; x <= r.right; x++) {
            boolean isText =
                Math.abs(lum(bmp.getPixel(x, midY)) - bgL) > 40f;
            if (isText) run++;
            else if (run > 0) { total += run; count++; run = 0; }
        }
        return count > 0 ? total / count : 4f;
    }

    private static float lum(int color) {
        return 0.299f * Color.red(color)
             + 0.587f * Color.green(color)
             + 0.114f * Color.blue(color);
    }
}
