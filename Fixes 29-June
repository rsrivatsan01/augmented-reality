## `OverlayBitmap.java` — Clean bitmap: background colour + translated text only
```java
package com.yourapp;

import android.graphics.Bitmap;
import android.graphics.Canvas;
import android.graphics.Color;
import android.graphics.LinearGradient;
import android.graphics.Paint;
import android.graphics.Shader;
import android.graphics.Typeface;

import java.util.ArrayList;
import java.util.List;

/**
 * Creates the overlay bitmap.
 * Step 1: Fill with sampled background colour
 * Step 2: Edge-fade to blend with surroundings
 * Step 3: Draw TRANSLATED text in sampled font size + colour
 *
 * Nothing else. No borders, no badges, no debug info.
 */
public class OverlayBitmap {

    private static final int BMP_W = 512;
    private static final int BMP_H = 256;

    public static Bitmap create(TextBlock block) {
        // Aspect ratio of original text block
        float aspect = block.bitmapBounds.width()
            / Math.max(1f, block.bitmapBounds.height());
        aspect = Math.max(0.5f, Math.min(8f, aspect));

        int bmpW = BMP_W;
        int bmpH = Math.max(64, (int)(BMP_W / aspect));
        bmpH     = Math.min(bmpH, 512);

        Bitmap bmp = Bitmap.createBitmap(bmpW, bmpH, Bitmap.Config.ARGB_8888);
        Canvas c   = new Canvas(bmp);

        // ── 1. Background fill ─────────────────────────────────────────────
        Paint bgPaint = new Paint();
        bgPaint.setColor(block.bgColor);
        c.drawRect(0, 0, bmpW, bmpH, bgPaint);

        // ── 2. Edge fade so it blends with real background ─────────────────
        int r = Color.red(block.bgColor);
        int g = Color.green(block.bgColor);
        int b = Color.blue(block.bgColor);
        drawFade(c, bmpW, bmpH, r, g, b);

        // ── 3. Translated text ─────────────────────────────────────────────
        Paint tp = new Paint();
        tp.setAntiAlias(true);
        tp.setSubpixelText(true);
        tp.setColor(block.textColor);

        // Weight
        int style = block.isBold ? Typeface.BOLD : Typeface.NORMAL;
        tp.setTypeface(Typeface.create(Typeface.DEFAULT, style));

        // Scale font size from bitmap-pixel-space to our bitmap dimensions
        float scale    = bmpH / Math.max(1f, block.bitmapBounds.height());
        float fontSize = block.fontSizePx * scale;
        fontSize       = Math.max(24f, Math.min(fontSize, bmpH * 0.70f));
        tp.setTextSize(fontSize);

        // Draw wrapped, vertically centred
        drawText(c, block.translated, bmpW, bmpH, tp);

        return bmp;
    }

    private static void drawFade(Canvas c, int w, int h, int r, int g, int b) {
        Paint p    = new Paint();
        int opaque = Color.argb(180, r, g, b);
        int clear  = Color.argb(0,   r, g, b);
        float ex   = w * 0.10f;
        float ey   = h * 0.12f;

        p.setShader(new LinearGradient(
            0,0,ex,0,opaque,clear,Shader.TileMode.CLAMP));
        c.drawRect(0,0,ex,h,p);

        p.setShader(new LinearGradient(
            w-ex,0,w,0,clear,opaque,Shader.TileMode.CLAMP));
        c.drawRect(w-ex,0,w,h,p);

        p.setShader(new LinearGradient(
            0,0,0,ey,opaque,clear,Shader.TileMode.CLAMP));
        c.drawRect(0,0,w,ey,p);

        p.setShader(new LinearGradient(
            0,h-ey,0,h,clear,opaque,Shader.TileMode.CLAMP));
        c.drawRect(0,h-ey,w,h,p);
    }

    private static void drawText(Canvas c, String text,
                                  int w, int h, Paint p) {
        if (text == null || text.isEmpty()) return;

        float maxW  = w * 0.88f;
        float padX  = w * 0.06f;
        float lineH = p.getTextSize() * 1.22f;

        // Word wrap
        List<String> lines = new ArrayList<>();
        String[] words = text.split(" ");
        StringBuilder cur = new StringBuilder();

        for (String word : words) {
            if (word.isEmpty()) continue;
            String test = cur.length() == 0 ? word : cur + " " + word;
            if (p.measureText(test) > maxW && cur.length() > 0) {
                lines.add(cur.toString());
                cur = new StringBuilder(word);
            } else {
                cur = new StringBuilder(test);
            }
        }
        if (cur.length() > 0) lines.add(cur.toString());
        if (lines.isEmpty())  return;

        // Vertical centre
        float totalH = lines.size() * lineH;
        float y      = (h - totalH) / 2f + p.getTextSize();

        for (String line : lines) {
            // Horizontal centre
            float x = (w - p.measureText(line)) / 2f;
            x = Math.max(padX, x);
            c.drawText(line, x, y, p);
            y += lineH;
        }
    }
}
