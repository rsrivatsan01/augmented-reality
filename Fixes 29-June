## `ARRenderer.java` — Clean renderer, no billboard, surface-locked only
```java
package com.yourapp;

import android.content.Context;
import android.graphics.Bitmap;
import android.opengl.GLES20;
import android.opengl.GLSurfaceView;
import android.opengl.GLUtils;
import android.opengl.Matrix;
import android.util.Log;

import com.google.ar.core.Anchor;
import com.google.ar.core.Camera;
import com.google.ar.core.Frame;
import com.google.ar.core.HitResult;
import com.google.ar.core.Plane;
import com.google.ar.core.Pose;
import com.google.ar.core.Session;
import com.google.ar.core.TrackingState;

import java.nio.ByteBuffer;
import java.nio.ByteOrder;
import java.nio.FloatBuffer;
import java.nio.ShortBuffer;
import java.util.ArrayList;
import java.util.List;

import javax.microedition.khronos.egl.EGLConfig;
import javax.microedition.khronos.opengles.GL10;

public class ARRenderer implements GLSurfaceView.Renderer {

    private static final String TAG = "ARRenderer";

    // ── Shader ─────────────────────────────────────────────────────────────
    // Surface-locked: MVP built from plane normal, not camera rotation
    private static final String VS =
        "uniform mat4 u_MVP;\n" +
        "attribute vec4 a_Pos;\n" +
        "attribute vec2 a_UV;\n" +
        "varying vec2 v_UV;\n" +
        "void main(){\n" +
        "  gl_Position = u_MVP * a_Pos;\n" +
        "  v_UV = a_UV;\n" +
        "}\n";

    private static final String FS =
        "precision mediump float;\n" +
        "uniform sampler2D u_Tex;\n" +
        "uniform float u_Alpha;\n" +
        "varying vec2 v_UV;\n" +
        "void main(){\n" +
        "  vec4 col = texture2D(u_Tex, v_UV);\n" +
        "  if(col.a * u_Alpha < 0.04) discard;\n" +
        "  gl_FragColor = vec4(col.rgb, col.a * u_Alpha);\n" +
        "}\n";

    // Unit quad lying flat (XZ plane), Y=up = plane normal direction
    // UV: (0,0)=top-left (1,1)=bottom-right
    private static final float[] QUAD = {
        // x,     y,    z,    u,   v
        -0.5f,  0f, -0.5f,   0f,  0f,   // top-left
        -0.5f,  0f,  0.5f,   0f,  1f,   // bottom-left
         0.5f,  0f,  0.5f,   1f,  1f,   // bottom-right
         0.5f,  0f, -0.5f,   1f,  0f,   // top-right
    };
    private static final short[] IDX = {0,1,2, 0,2,3};

    // GL handles
    private int prog, uMVP, uTex, uAlpha, aPos, aUV;
    private FloatBuffer vBuf;
    private ShortBuffer iBuf;

    private final BackgroundRenderer bgRenderer = new BackgroundRenderer();

    // ── Data ───────────────────────────────────────────────────────────────
    private final List<TextBlock> blocks    = new ArrayList<>();
    private volatile boolean      needsClear= false;

    // Queued placement (main thread → GL thread)
    private static class QueuedPlacement {
        List<TextBlock> blocks;
        Frame frame;
        int viewW, viewH;
    }
    private volatile QueuedPlacement queued = null;

    private final float[] proj = new float[16];
    private final float[] view = new float[16];

    private final Context context;
    private Session session;

    private static final float FADE_SPEED   = 0.05f;
    private static final int   LOCK_FRAMES  = 35;   // ~1s
    private static final float LOCK_DRIFT   = 0.005f; // 5mm

    public interface Callback {
        void onPlaneDetected();
        void onAllLocked(int count);
    }
    private final Callback cb;
    private boolean planeSeen = false;

    public ARRenderer(Context ctx, Callback cb) {
        this.context = ctx;
        this.cb      = cb;
    }

    public void setSession(Session s) { this.session = s; }

    // ── Called from main thread after translation completes ────────────────

    public void queuePlacement(List<TextBlock> blocks,
                                Frame frame, int vW, int vH) {
        QueuedPlacement q = new QueuedPlacement();
        q.blocks = blocks;
        q.frame  = frame;
        q.viewW  = vW;
        q.viewH  = vH;
        queued   = q;
    }

    public void clear() {
        needsClear = true;
    }

    // ── GL ─────────────────────────────────────────────────────────────────

    @Override
    public void onSurfaceCreated(GL10 gl, EGLConfig cfg) {
        GLES20.glClearColor(0,0,0,1);
        try { bgRenderer.createOnGlThread(context); }
        catch (Exception e) { Log.e(TAG,"BG fail",e); }

        // Compile shaders
        int vs = shader(GLES20.GL_VERTEX_SHADER, VS);
        int fs = shader(GLES20.GL_FRAGMENT_SHADER, FS);
        prog   = GLES20.glCreateProgram();
        GLES20.glAttachShader(prog, vs);
        GLES20.glAttachShader(prog, fs);
        GLES20.glLinkProgram(prog);

        uMVP  = GLES20.glGetUniformLocation(prog, "u_MVP");
        uTex  = GLES20.glGetUniformLocation(prog, "u_Tex");
        uAlpha= GLES20.glGetUniformLocation(prog, "u_Alpha");
        aPos  = GLES20.glGetAttribLocation(prog,  "a_Pos");
        aUV   = GLES20.glGetAttribLocation(prog,  "a_UV");

        ByteBuffer v = ByteBuffer.allocateDirect(QUAD.length * 4);
        v.order(ByteOrder.nativeOrder());
        vBuf = v.asFloatBuffer();
        vBuf.put(QUAD).position(0);

        ByteBuffer i = ByteBuffer.allocateDirect(IDX.length * 2);
        i.order(ByteOrder.nativeOrder());
        iBuf = i.asShortBuffer();
        iBuf.put(IDX).position(0);
    }

    @Override
    public void onSurfaceChanged(GL10 gl, int w, int h) {
        GLES20.glViewport(0, 0, w, h);
        if (session != null) {
            int rot = ((android.app.Activity) context)
                .getWindowManager().getDefaultDisplay().getRotation();
            session.setDisplayGeometry(rot, w, h);
        }
    }

    @Override
    public void onDrawFrame(GL10 gl) {
        GLES20.glClear(
            GLES20.GL_COLOR_BUFFER_BIT | GLES20.GL_DEPTH_BUFFER_BIT);
        if (session == null) return;

        try {
            session.setCameraTextureName(bgRenderer.getTextureId());
            Frame  frame  = session.update();
            Camera camera = frame.getCamera();

            // Draw live camera feed first
            bgRenderer.draw(frame);

            if (camera.getTrackingState() != TrackingState.TRACKING) return;

            camera.getProjectionMatrix(proj, 0, 0.01f, 100f);
            camera.getViewMatrix(view, 0);

            // Detect planes
            if (!planeSeen) {
                for (Plane p : session.getAllTrackables(Plane.class)) {
                    if (p.getTrackingState() == TrackingState.TRACKING) {
                        planeSeen = true;
                        ((android.app.Activity)context)
                            .runOnUiThread(cb::onPlaneDetected);
                        break;
                    }
                }
            }

            // Clear if requested
            if (needsClear) {
                needsClear = false;
                freeBlocks();
            }

            // Process queued placement
            QueuedPlacement q = queued;
            if (q != null) {
                queued = null;
                placeBlocks(q);
            }

            // Draw blocks
            if (blocks.isEmpty()) return;

            GLES20.glEnable(GLES20.GL_BLEND);
            GLES20.glBlendFunc(
                GLES20.GL_SRC_ALPHA, GLES20.GL_ONE_MINUS_SRC_ALPHA);
            GLES20.glDepthMask(false);
            GLES20.glUseProgram(prog);

            int lockedCount = 0;
            for (TextBlock b : blocks) {
                float[] matrix = getMatrix(b);
                if (matrix == null) continue;

                if (b.locked) lockedCount++;
                else          tryLock(b, matrix);

                b.fadeAlpha = Math.min(1f, b.fadeAlpha + FADE_SPEED);

                drawBlock(b, matrix);
            }

            GLES20.glDepthMask(true);
            GLES20.glDisable(GLES20.GL_BLEND);

            if (lockedCount == blocks.size() && !blocks.isEmpty()) {
                final int n = lockedCount;
                ((android.app.Activity)context)
                    .runOnUiThread(() -> cb.onAllLocked(n));
            }

        } catch (Exception e) {
            Log.e(TAG, "Draw error: " + e.getMessage());
        }
    }

    // ── Placement ──────────────────────────────────────────────────────────

    private void placeBlocks(QueuedPlacement q) {
        freeBlocks();

        for (TextBlock b : q.blocks) {
            if (b.translated == null || b.translated.isEmpty()) continue;

            float cx = (b.bitmapBounds.left + b.bitmapBounds.right)  / 2f;
            float cy = (b.bitmapBounds.top  + b.bitmapBounds.bottom) / 2f;

            // ── Scale bounding box from bitmap → screen coords ─────────────
            // The bitmap was taken from the GLSurfaceView via PixelCopy
            // so bitmap pixels == screen pixels — no scaling needed
            float screenX = cx;
            float screenY = cy;

            // ── Hit-test to find real surface ──────────────────────────────
            Anchor anchor    = null;
            float[] planeMatrix = null;
            float   depth    = 0.6f; // default 60cm

            try {
                List<HitResult> hits = q.frame.hitTest(screenX, screenY);
                for (HitResult hit : hits) {
                    if (!(hit.getTrackable() instanceof Plane)) continue;
                    Plane plane = (Plane) hit.getTrackable();
                    if (plane.getTrackingState() != TrackingState.TRACKING) continue;
                    if (plane.getSubsumedBy() != null) continue;

                    anchor = hit.createAnchor();
                    depth  = hit.getDistance();

                    // ── Build surface-aligned matrix from PLANE, not camera ─
                    // This is the key fix: rotation from plane, not view matrix
                    float[] pm = new float[16];
                    plane.getCenterPose().toMatrix(pm, 0);

                    float[] anchorM = new float[16];
                    hit.getHitPose().toMatrix(anchorM, 0);

                    // Use plane orientation for rotation,
                    // anchor position for translation
                    planeMatrix = new float[]{
                        pm[0], pm[1], pm[2],  0f,
                        pm[4], pm[5], pm[6],  0f,
                        pm[8], pm[9], pm[10], 0f,
                        anchorM[12], anchorM[13], anchorM[14], 1f
                    };
                    break;
                }
            } catch (Exception e) {
                Log.e(TAG, "Hit test failed", e);
            }

            // Fallback: no plane found yet, place 0.6m in front of camera
            if (anchor == null || planeMatrix == null) {
                try {
                    Pose camPose = q.frame.getCamera().getPose();
                    float[] t   = camPose.getTranslation();
                    float[] fwd = camPose.getZAxis();
                    Pose pose   = Pose.makeTranslation(
                        t[0] - fwd[0] * depth,
                        t[1] - fwd[1] * depth,
                        t[2] - fwd[2] * depth);
                    anchor      = session.createAnchor(pose);
                    planeMatrix = new float[16];
                    pose.toMatrix(planeMatrix, 0);
                } catch (Exception e) {
                    Log.e(TAG, "Fallback anchor failed", e);
                    continue;
                }
            }

            // ── Real-world size ────────────────────────────────────────────
            // FOV ~60°: tan(30°) ≈ 0.577
            float tanHalfFov  = 0.577f;
            float screenFracW = b.bitmapBounds.width()  / q.viewW;
            float screenFracH = b.bitmapBounds.height() / q.viewH;
            b.widthM  = Math.max(0.04f,
                Math.min(3f, 2f * depth * tanHalfFov * screenFracW));
            b.heightM = Math.max(0.02f,
                Math.min(2f, 2f * depth * tanHalfFov * screenFracH));

            // ── Upload GL texture ──────────────────────────────────────────
            Bitmap bmp = OverlayBitmap.create(b); // uses b.translated
            int[] tex  = new int[1];
            GLES20.glGenTextures(1, tex, 0);
            GLES20.glBindTexture(GLES20.GL_TEXTURE_2D, tex[0]);
            GLES20.glTexParameteri(GLES20.GL_TEXTURE_2D,
                GLES20.GL_TEXTURE_MIN_FILTER, GLES20.GL_LINEAR_MIPMAP_LINEAR);
            GLES20.glTexParameteri(GLES20.GL_TEXTURE_2D,
                GLES20.GL_TEXTURE_MAG_FILTER, GLES20.GL_LINEAR);
            GLES20.glTexParameteri(GLES20.GL_TEXTURE_2D,
                GLES20.GL_TEXTURE_WRAP_S, GLES20.GL_CLAMP_TO_EDGE);
            GLES20.glTexParameteri(GLES20.GL_TEXTURE_2D,
                GLES20.GL_TEXTURE_WRAP_T, GLES20.GL_CLAMP_TO_EDGE);
            GLUtils.texImage2D(GLES20.GL_TEXTURE_2D, 0, bmp, 0);
            GLES20.glGenerateMipmap(GLES20.GL_TEXTURE_2D);
            bmp.recycle();

            b.glTexture  = tex[0];
            b.anchor     = anchor;
            b.planeMatrix= planeMatrix;
            blocks.add(b);
        }
    }

    // ── Per-frame matrix ───────────────────────────────────────────────────

    private float[] getMatrix(TextBlock b) {
        if (b.locked) return b.lockedMatrix;

        if (b.anchor == null ||
            b.anchor.getTrackingState() != TrackingState.TRACKING) {
            return b.lockedMatrix; // last known
        }

        // Translation from live anchor, rotation from plane (fixed)
        float[] anchorM = new float[16];
        b.anchor.getPose().toMatrix(anchorM, 0);

        float[] m = b.planeMatrix.clone();
        m[12] = anchorM[12];
        m[13] = anchorM[13];
        m[14] = anchorM[14];
        return m;
    }

    // ── Locking ────────────────────────────────────────────────────────────

    private void tryLock(TextBlock b, float[] current) {
        if (b.lockedMatrix == null) {
            b.lockedMatrix = current.clone();
            return;
        }

        // Measure translation drift
        float dx = current[12] - b.lockedMatrix[12];
        float dy = current[13] - b.lockedMatrix[13];
        float dz = current[14] - b.lockedMatrix[14];
        float drift = (float) Math.sqrt(dx*dx + dy*dy + dz*dz);

        if (drift < LOCK_DRIFT) {
            b.stableFrames++;
        } else {
            b.stableFrames = 0;
            b.lockedMatrix = current.clone();
        }

        if (b.stableFrames >= LOCK_FRAMES) {
            b.lockedMatrix = current.clone();
            b.locked       = true;
            if (b.anchor != null) {
                b.anchor.detach();
                b.anchor = null;
            }
        }
    }

    // ── Draw ───────────────────────────────────────────────────────────────

    private void drawBlock(TextBlock b, float[] model) {
        if (b.glTexture < 0) return;

        // Scale quad to real-world block size
        float[] scale = new float[16];
        Matrix.setIdentityM(scale, 0);
        Matrix.scaleM(scale, 0, b.widthM, 1f, b.heightM);

        float[] scaled = new float[16];
        Matrix.multiplyMM(scaled, 0, model, 0, scale, 0);

        // Nudge 1mm toward camera to avoid z-fighting
        float[] invView = new float[16];
        Matrix.invertM(invView, 0, view, 0);
        float nudge = 0.001f;
        float dx    = invView[12] - scaled[12];
        float dy    = invView[13] - scaled[13];
        float dz    = invView[14] - scaled[14];
        float len   = (float) Math.sqrt(dx*dx+dy*dy+dz*dz);
        if (len > 0) {
            scaled[12] += (dx/len)*nudge;
            scaled[13] += (dy/len)*nudge;
            scaled[14] += (dz/len)*nudge;
        }

        float[] mv  = new float[16];
        float[] mvp = new float[16];
        Matrix.multiplyMM(mv,  0, view, 0, scaled, 0);
        Matrix.multiplyMM(mvp, 0, proj, 0, mv,     0);

        GLES20.glUniformMatrix4fv(uMVP, 1, false, mvp, 0);
        GLES20.glUniform1f(uAlpha, b.fadeAlpha);

        GLES20.glActiveTexture(GLES20.GL_TEXTURE0);
        GLES20.glBindTexture(GLES20.GL_TEXTURE_2D, b.glTexture);
        GLES20.glUniform1i(uTex, 0);

        int stride = 5 * 4;
        vBuf.position(0);
        GLES20.glEnableVertexAttribArray(aPos);
        GLES20.glVertexAttribPointer(aPos, 3,
            GLES20.GL_FLOAT, false, stride, vBuf);
        vBuf.position(3);
        GLES20.glEnableVertexAttribArray(aUV);
        GLES20.glVertexAttribPointer(aUV, 2,
            GLES20.GL_FLOAT, false, stride, vBuf);
        iBuf.position(0);
        GLES20.glDrawElements(GLES20.GL_TRIANGLES, 6,
            GLES20.GL_UNSIGNED_SHORT, iBuf);
        GLES20.glDisableVertexAttribArray(aPos);
        GLES20.glDisableVertexAttribArray(aUV);
    }

    // ── Cleanup ────────────────────────────────────────────────────────────

    private void freeBlocks() {
        for (TextBlock b : blocks) {
            if (b.anchor != null) b.anchor.detach();
            if (b.glTexture >= 0) {
                int[] t = {b.glTexture};
                GLES20.glDeleteTextures(1, t, 0);
            }
        }
        blocks.clear();
    }

    private int shader(int type, String src) {
        int s = GLES20.glCreateShader(type);
        GLES20.glShaderSource(s, src);
        GLES20.glCompileShader(s);
        return s;
    }
}
