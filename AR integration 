## `MainActivity.java`
```java
package com.yourapp;

import android.Manifest;
import android.content.pm.PackageManager;
import android.graphics.Bitmap;
import android.graphics.RectF;
import android.opengl.GLSurfaceView;
import android.os.Bundle;
import android.view.PixelCopy;
import android.view.View;
import android.widget.*;
import androidx.annotation.NonNull;
import androidx.appcompat.app.AppCompatActivity;
import androidx.core.app.ActivityCompat;
import androidx.core.content.ContextCompat;

import com.google.ar.core.*;
import com.google.ar.core.exceptions.*;
import com.google.mlkit.vision.common.InputImage;
import com.google.mlkit.vision.text.Text;
import com.google.mlkit.vision.text.TextRecognition;
import com.google.mlkit.vision.text.TextRecognizer;
import com.google.mlkit.vision.text.latin.TextRecognizerOptions;

import java.util.ArrayList;
import java.util.List;

public class MainActivity extends AppCompatActivity
    implements ARTextRenderer.FrameCallback {

    private static final int CAMERA_PERM = 100;

    // Views
    private GLSurfaceView glSurfaceView;
    private TextView statusText, loadingText;
    private Button btnCapture, btnReset;
    private View loadingPanel;
    private Spinner spinnerSource, spinnerTarget;
    private ImageButton btnSwap;

    // AR
    private Session arSession;
    private ARTextRenderer arRenderer;
    private Frame lastFrame; // latest ARCore frame for hit-testing

    // ML Kit
    private TextRecognizer textRecognizer;
    private TranslationProcessor translator;

    private boolean isProcessing = false;
    private boolean sessionPaused = true;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        bindViews();
        setupSpinners();
        setupButtons();

        textRecognizer = TextRecognition.getClient(TextRecognizerOptions.DEFAULT_OPTIONS);
        translator     = new TranslationProcessor();

        if (hasCameraPermission()) initAR();
        else ActivityCompat.requestPermissions(this,
            new String[]{Manifest.permission.CAMERA}, CAMERA_PERM);
    }

    private void bindViews() {
        glSurfaceView = findViewById(R.id.gl_surface_view);
        statusText    = findViewById(R.id.status_text);
        loadingText   = findViewById(R.id.loading_text);
        loadingPanel  = findViewById(R.id.loading_panel);
        btnCapture    = findViewById(R.id.btn_capture);
        btnReset      = findViewById(R.id.btn_reset);
        spinnerSource = findViewById(R.id.spinner_source);
        spinnerTarget = findViewById(R.id.spinner_target);
        btnSwap       = findViewById(R.id.btn_swap);
    }

    private void setupSpinners() {
        String[] names = LanguageManager.getDisplayNames();
        ArrayAdapter<String> adapter = new ArrayAdapter<>(
            this, android.R.layout.simple_spinner_item, names);
        adapter.setDropDownViewResource(
            android.R.layout.simple_spinner_dropdown_item);
        spinnerSource.setAdapter(adapter);
        spinnerTarget.setAdapter(adapter);
        spinnerSource.setSelection(0); // Auto Detect
        spinnerTarget.setSelection(1); // English
    }

    private void setupButtons() {
        btnCapture.setOnClickListener(v -> captureAndProcess());

        btnReset.setOnClickListener(v -> {
            arRenderer.clearAnchors();
            btnReset.setVisibility(View.GONE);
            btnCapture.setEnabled(true);
            statusText.setText("Point camera at text, then tap scan");
        });

        btnSwap.setOnClickListener(v -> {
            int src = spinnerSource.getSelectedItemPosition();
            int tgt = spinnerTarget.getSelectedItemPosition();
            spinnerSource.setSelection(tgt);
            spinnerTarget.setSelection(src);
        });
    }

    // ── ARCore init ────────────────────────────────────────────────────────

    private void initAR() {
        try {
            arSession = new Session(this);

            Config config = new Config(arSession);
            config.setFocusMode(Config.FocusMode.AUTO);
            config.setUpdateMode(Config.UpdateMode.LATEST_CAMERA_IMAGE);
            // Enable plane detection so we can stick text to real surfaces
            config.setPlaneFindingMode(Config.PlaneFindingMode.HORIZONTAL_AND_VERTICAL);
            config.setLightEstimationMode(Config.LightEstimationMode.DISABLED);
            arSession.configure(config);

        } catch (UnavailableException e) {
            statusText.setText("ARCore unavailable: " + e.getMessage());
            return;
        }

        glSurfaceView.setPreserveEGLContextOnPause(true);
        glSurfaceView.setEGLContextClientVersion(2);

        arRenderer = new ARTextRenderer(this, this);
        arRenderer.setSession(arSession);

        glSurfaceView.setRenderer(arRenderer);
        glSurfaceView.setRenderMode(GLSurfaceView.RENDERMODE_CONTINUOUSLY);
    }

    @Override
    protected void onResume() {
        super.onResume();
        if (arSession != null) {
            try {
                arSession.resume();
                sessionPaused = false;
                glSurfaceView.onResume();
            } catch (CameraNotAvailableException e) {
                statusText.setText("Camera not available");
            }
        }
    }

    @Override
    protected void onPause() {
        super.onPause();
        if (!sessionPaused && arSession != null) {
            glSurfaceView.onPause();
            arSession.pause();
            sessionPaused = true;
        }
    }

    @Override
    protected void onDestroy() {
        super.onDestroy();
        if (arSession != null) { arSession.close(); arSession = null; }
        translator.close();
        textRecognizer.close();
    }

    // ── Capture pipeline ───────────────────────────────────────────────────

    private void captureAndProcess() {
        if (isProcessing) return;

        if (spinnerTarget.getSelectedItemPosition() == 0) {
            Toast.makeText(this,
                "Please select a target language", Toast.LENGTH_SHORT).show();
            return;
        }

        isProcessing = true;
        btnCapture.setEnabled(false);
        showLoading("Capturing screen…");

        // Capture the GLSurfaceView pixel content
        int w = glSurfaceView.getWidth();
        int h = glSurfaceView.getHeight();
        Bitmap screenshot = Bitmap.createBitmap(w, h, Bitmap.Config.ARGB_8888);

        PixelCopy.request(glSurfaceView, screenshot, result -> {
            if (result == PixelCopy.SUCCESS) {
                runOnUiThread(() -> showLoading("Detecting text…"));
                runTextDetection(screenshot, w, h);
            } else {
                runOnUiThread(() -> {
                    hideLoading();
                    showStatus("Screen capture failed");
                    isProcessing = false;
                    btnCapture.setEnabled(true);
                });
            }
        }, new android.os.Handler(android.os.Looper.getMainLooper()));
    }

    private void runTextDetection(Bitmap bitmap, int viewW, int viewH) {
        InputImage image = InputImage.fromBitmap(bitmap, 0);

        textRecognizer.process(image)
            .addOnSuccessListener(result -> {
                if (result.getTextBlocks().isEmpty()) {
                    runOnUiThread(() -> {
                        hideLoading();
                        showStatus("No text found. Try again.");
                        isProcessing = false;
                        btnCapture.setEnabled(true);
                    });
                    return;
                }

                // Collect texts and screen bounds
                List<String> texts  = new ArrayList<>();
                List<RectF>  bounds = new ArrayList<>();

                for (Text.TextBlock block : result.getTextBlocks()) {
                    if (block.getBoundingBox() == null) continue;
                    texts.add(block.getText());
                    android.graphics.Rect r = block.getBoundingBox();
                    bounds.add(new RectF(r.left, r.top, r.right, r.bottom));
                }

                runOnUiThread(() -> showLoading("Translating…"));

                String srcCode = LanguageManager.getCode(
                    spinnerSource.getSelectedItem().toString());
                String tgtCode = LanguageManager.getCode(
                    spinnerTarget.getSelectedItem().toString());

                translator.translate(texts, srcCode, tgtCode,
                    new TranslationProcessor.TranslationCallback() {

                    @Override
                    public void onComplete(List<String> translated) {
                        runOnUiThread(() -> showLoading("Placing AR anchors…"));

                        // Get a fresh frame for hit-testing
                        try {
                            Frame frame = arSession.update();
                            // Place AR anchors on GL thread via renderer
                            glSurfaceView.queueEvent(() ->
                                arRenderer.placeAnchors(
                                    frame, texts, translated, bounds, viewW, viewH));

                            runOnUiThread(() -> {
                                hideLoading();
                                showStatus("✅ " + translated.size()
                                    + " text block(s) anchored in AR");
                                btnReset.setVisibility(View.VISIBLE);
                                isProcessing = false;
                                // Leave capture disabled — user hits Clear to reset
                            });

                        } catch (Exception e) {
                            runOnUiThread(() -> {
                                hideLoading();
                                showStatus("Anchor placement failed: " + e.getMessage());
                                isProcessing = false;
                                btnCapture.setEnabled(true);
                            });
                        }
                    }

                    @Override
                    public void onError(String error) {
                        runOnUiThread(() -> {
                            hideLoading();
                            showStatus("Translation error: " + error);
                            isProcessing = false;
                            btnCapture.setEnabled(true);
                        });
                    }

                    @Override
                    public void onProgress(String message) {
                        runOnUiThread(() -> showLoading(message));
                    }
                });
            })
            .addOnFailureListener(e -> runOnUiThread(() -> {
                hideLoading();
                showStatus("Detection failed: " + e.getMessage());
                isProcessing = false;
                btnCapture.setEnabled(true);
            }));
    }

    // ── ARTextRenderer.FrameCallback ───────────────────────────────────────

    @Override
    public void onTracking(int anchorCount) {
        if (anchorCount > 0)
            showStatus("🔵 " + anchorCount + " text block(s) tracked in AR");
    }

    @Override
    public void onPlaneFound() {
        showStatus("Surface detected — tap scan when ready");
    }

    // ── Helpers ────────────────────────────────────────────────────────────

    private void showLoading(String msg) {
        loadingText.setText(msg);
        loadingPanel.setVisibility(View.VISIBLE);
    }

    private void hideLoading() {
        loadingPanel.setVisibility(View.GONE);
    }

    private void showStatus(String msg) {
        statusText.setText(msg);
    }

    private boolean hasCameraPermission() {
        return ContextCompat.checkSelfPermission(this,
            Manifest.permission.CAMERA) == PackageManager.PERMISSION_GRANTED;
    }

    @Override
    public void onRequestPermissionsResult(int code,
            @NonNull String[] perms, @NonNull int[] results) {
        super.onRequestPermissionsResult(code, perms, results);
        if (code == CAMERA_PERM && results.length > 0
                && results[0] == PackageManager.PERMISSION_GRANTED) {
            initAR();
        }
    }
}
