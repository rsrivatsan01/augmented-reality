## `ARTextRenderer.java` — GL Renderer: camera preview + 3D text anchors
```java
package com.yourapp;

import android.content.Context;
import android.graphics.Bitmap;
import android.graphics.Canvas;
import android.graphics.Color;
import android.graphics.Paint;
import android.graphics.Typeface;
import android.opengl.GLES20;
import android.opengl.GLSurfaceView;
import android.opengl.GLUtils;
import android.opengl.Matrix;
import android.util.Log;

import com.google.ar.core.Anchor;
import com.google.ar.core.Camera;
import com.google.ar.core.Frame;
import com.google.ar.core.HitResult;
import com.google.ar.core.Plane;
import com.google.ar.core.Pose;
import com.google.ar.core.Session;
import com.google.ar.core.TrackingState;

import java.nio.ByteBuffer;
import java.nio.ByteOrder;
import java.nio.FloatBuffer;
import java.util.ArrayList;
import java.util.List;

import javax.microedition.khronos.egl.EGLConfig;
import javax.microedition.khronos.opengles.GL10;

public class ARTextRenderer implements GLSurfaceView.Renderer {

    private static final String TAG = "ARTextRenderer";

    // ── GL shader: renders a textured quad (the translated text billboard) ─
    private static final String VERTEX_SHADER =
        "uniform mat4 u_MVP;\n" +
        "attribute vec4 a_Position;\n" +
        "attribute vec2 a_TexCoord;\n" +
        "varying vec2 v_TexCoord;\n" +
        "void main() {\n" +
        "  gl_Position = u_MVP * a_Position;\n" +
        "  v_TexCoord = a_TexCoord;\n" +
        "}\n";

    private static final String FRAGMENT_SHADER =
        "precision mediump float;\n" +
        "uniform sampler2D u_Texture;\n" +
        "varying vec2 v_TexCoord;\n" +
        "void main() {\n" +
        "  gl_FragColor = texture2D(u_Texture, v_TexCoord);\n" +
        "}\n";

    // Quad vertices: a flat billboard in local space
    private static final float[] QUAD_VERTICES = {
        -0.5f,  0.25f, 0f,   0f, 0f,   // top-left
        -0.5f, -0.25f, 0f,   0f, 1f,   // bottom-left
         0.5f, -0.25f, 0f,   1f, 1f,   // bottom-right
         0.5f,  0.25f, 0f,   1f, 0f,   // top-right
    };
    private static final short[] QUAD_INDICES = {0, 1, 2, 0, 2, 3};

    private final Context context;
    private Session arSession;

    // GL handles
    private int shaderProgram;
    private int uMVP, uTexture, aPosition, aTexCoord;
    private FloatBuffer quadBuffer;
    private final BackgroundRenderer backgroundRenderer = new BackgroundRenderer();

    // Anchored text blocks placed in world space
    private final List<AnchoredTextBlock> anchoredBlocks = new ArrayList<>();
    private final List<AnchoredTextBlock> pendingAnchors = new ArrayList<>();
    private final Object anchorLock = new Object();

    // Matrices
    private final float[] projMatrix  = new float[16];
    private final float[] viewMatrix  = new float[16];
    private final float[] modelMatrix = new float[16];
    private final float[] mvpMatrix   = new float[16];

    // Texture cache per block
    private final List<int[]> blockTextures = new ArrayList<>();

    // Callback to update UI
    public interface FrameCallback {
        void onTracking(int anchorCount);
        void onPlaneFound();
    }
    private final FrameCallback frameCallback;
    private boolean planeFound = false;

    public ARTextRenderer(Context context, FrameCallback callback) {
        this.context       = context;
        this.frameCallback = callback;
    }

    public void setSession(Session session) {
        this.arSession = session;
    }

    // ── Called from main thread after translation completes ────────────────

    /**
     * Places each translated text block as an AR anchor on the detected plane.
     * Uses the frame's hit-test to find the real-world surface position.
     */
    public void placeAnchors(Frame frame,
                             List<String> originalTexts,
                             List<String> translatedTexts,
                             List<android.graphics.RectF> screenBounds,
                             int viewWidth, int viewHeight) {
        synchronized (anchorLock) {
            // Clear old anchors
            for (AnchoredTextBlock b : anchoredBlocks) b.detach();
            anchoredBlocks.clear();
            blockTextures.clear();
            pendingAnchors.clear();

            for (int i = 0; i < translatedTexts.size(); i++) {
                android.graphics.RectF bounds = screenBounds.get(i);

                // Hit-test at the center of each text block's screen position
                float centerX = (bounds.left + bounds.right)  / 2f / viewWidth;
                float centerY = (bounds.top  + bounds.bottom) / 2f / viewHeight;

                // ARCore hit-test: finds the real-world plane at that screen point
                List<HitResult> hits = frame.hitTest(
                    centerX * viewWidth, centerY * viewHeight);

                Anchor anchor = null;
                for (HitResult hit : hits) {
                    if (hit.getTrackable() instanceof Plane) {
                        Plane plane = (Plane) hit.getTrackable();
                        if (plane.getTrackingState() == TrackingState.TRACKING) {
                            anchor = hit.createAnchor();
                            break;
                        }
                    }
                }

                // Fallback: if no plane hit, place anchor 0.5m in front of camera
                if (anchor == null) {
                    Pose cameraPose = frame.getCamera().getPose();
                    float[] translation = cameraPose.getTranslation();
                    float[] forward     = cameraPose.getZAxis();
                    Pose anchorPose = Pose.makeTranslation(
                        translation[0] - forward[0] * 0.5f,
                        translation[1] - forward[1] * 0.5f,
                        translation[2] - forward[2] * 0.5f
                    );
                    anchor = arSession.createAnchor(anchorPose);
                }

                // Estimate width: fraction of screen width → ~0.3m default
                float widthMeters = 0.3f * (bounds.width() / viewWidth);

                pendingAnchors.add(new AnchoredTextBlock(
                    anchor,
                    originalTexts.get(i),
                    translatedTexts.get(i),
                    Math.max(0.1f, widthMeters)
                ));
            }
        }
    }

    // ── GL lifecycle ───────────────────────────────────────────────────────

    @Override
    public void onSurfaceCreated(GL10 gl, EGLConfig config) {
        GLES20.glClearColor(0f, 0f, 0f, 1f);

        try {
            backgroundRenderer.createOnGlThread(context);
        } catch (Exception e) {
            Log.e(TAG, "Background renderer failed", e);
        }

        shaderProgram = buildShaderProgram();
        uMVP      = GLES20.glGetUniformLocation(shaderProgram, "u_MVP");
        uTexture  = GLES20.glGetUniformLocation(shaderProgram, "u_Texture");
        aPosition = GLES20.glGetAttribLocation(shaderProgram,  "a_Position");
        aTexCoord = GLES20.glGetAttribLocation(shaderProgram,  "a_TexCoord");

        // Upload quad geometry
        ByteBuffer bb = ByteBuffer.allocateDirect(QUAD_VERTICES.length * 4);
        bb.order(ByteOrder.nativeOrder());
        quadBuffer = bb.asFloatBuffer();
        quadBuffer.put(QUAD_VERTICES);
        quadBuffer.position(0);
    }

    @Override
    public void onSurfaceChanged(GL10 gl, int width, int height) {
        GLES20.glViewport(0, 0, width, height);
        if (arSession != null) {
            arSession.setDisplayGeometry(
                ((android.app.Activity) context)
                    .getWindowManager().getDefaultDisplay().getRotation(),
                width, height);
        }
    }

    @Override
    public void onDrawFrame(GL10 gl) {
        GLES20.glClear(GLES20.GL_COLOR_BUFFER_BIT | GLES20.GL_DEPTH_BUFFER_BIT);

        if (arSession == null) return;

        try {
            arSession.setCameraTextureName(backgroundRenderer.getTextureId());
            Frame frame = arSession.update();
            Camera camera = frame.getCamera();

            // ── 1. Draw live camera feed ───────────────────────────────────
            backgroundRenderer.draw(frame);

            if (camera.getTrackingState() != TrackingState.TRACKING) return;

            // ── 2. Detect planes (notify UI once) ─────────────────────────
            if (!planeFound) {
                for (Plane plane : arSession.getAllTrackables(Plane.class)) {
                    if (plane.getTrackingState() == TrackingState.TRACKING) {
                        planeFound = true;
                        if (frameCallback != null)
                            ((android.app.Activity) context)
                                .runOnUiThread(frameCallback::onPlaneFound);
                        break;
                    }
                }
            }

            // ── 3. Move pending anchors to active list ─────────────────────
            synchronized (anchorLock) {
                if (!pendingAnchors.isEmpty()) {
                    // Generate textures for new blocks
                    for (AnchoredTextBlock block : pendingAnchors) {
                        int[] texId = new int[1];
                        GLES20.glGenTextures(1, texId, 0);
                        Bitmap bmp = createTextBitmap(
                            block.translatedText, block.originalText);
                        uploadTexture(texId[0], bmp);
                        bmp.recycle();
                        blockTextures.add(texId);
                    }
                    anchoredBlocks.addAll(pendingAnchors);
                    pendingAnchors.clear();
                }
            }

            // ── 4. Get camera matrices ─────────────────────────────────────
            camera.getProjectionMatrix(projMatrix, 0, 0.05f, 100f);
            camera.getViewMatrix(viewMatrix, 0);

            // ── 5. Draw each anchored text block ───────────────────────────
            GLES20.glEnable(GLES20.GL_BLEND);
            GLES20.glBlendFunc(GLES20.GL_SRC_ALPHA, GLES20.GL_ONE_MINUS_SRC_ALPHA);
            GLES20.glDepthMask(false);

            GLES20.glUseProgram(shaderProgram);

            for (int i = 0; i < anchoredBlocks.size(); i++) {
                AnchoredTextBlock block = anchoredBlocks.get(i);
                if (block.anchor.getTrackingState() != TrackingState.TRACKING) continue;

                // Get anchor pose in world space
                float[] anchorMatrix = new float[16];
                block.anchor.getPose().toMatrix(anchorMatrix, 0);

                // Billboard: face the camera always
                float[] billboardMatrix = makeBillboard(anchorMatrix, viewMatrix,
                    block.blockWidthMeters);

                // MVP = Proj × View × Model
                float[] mv = new float[16];
                Matrix.multiplyMM(mv, 0, viewMatrix, 0, billboardMatrix, 0);
                Matrix.multiplyMM(mvpMatrix, 0, projMatrix, 0, mv, 0);

                // Bind texture
                GLES20.glActiveTexture(GLES20.GL_TEXTURE0);
                GLES20.glBindTexture(GLES20.GL_TEXTURE_2D, blockTextures.get(i)[0]);
                GLES20.glUniform1i(uTexture, 0);

                // Upload MVP
                GLES20.glUniformMatrix4fv(uMVP, 1, false, mvpMatrix, 0);

                // Draw quad
                drawQuad();
            }

            GLES20.glDepthMask(true);
            GLES20.glDisable(GLES20.GL_BLEND);

            // Notify UI
            if (frameCallback != null) {
                final int count = anchoredBlocks.size();
                ((android.app.Activity) context)
                    .runOnUiThread(() -> frameCallback.onTracking(count));
            }

        } catch (Exception e) {
            Log.e(TAG, "Frame draw error: " + e.getMessage());
        }
    }

    // ── Billboard matrix: keeps quad always facing the camera ─────────────

    private float[] makeBillboard(float[] anchorMatrix,
                                  float[] viewMatrix,
                                  float widthMeters) {
        // Extract anchor position
        float tx = anchorMatrix[12];
        float ty = anchorMatrix[13];
        float tz = anchorMatrix[14];

        // Extract camera right/up from view matrix rows
        float[] result = new float[16];
        Matrix.setIdentityM(result, 0);

        // Right vector = view matrix row 0
        result[0] = viewMatrix[0];
        result[1] = viewMatrix[4];
        result[2] = viewMatrix[8];

        // Up vector = view matrix row 1
        result[4] = viewMatrix[1];
        result[5] = viewMatrix[5];
        result[6] = viewMatrix[9];

        // Forward = view matrix row 2 (negated for GL)
        result[8]  = viewMatrix[2];
        result[9]  = viewMatrix[6];
        result[10] = viewMatrix[10];

        // Scale by width
        result[0] *= widthMeters; result[1] *= widthMeters; result[2] *= widthMeters;
        result[4] *= widthMeters * 0.5f;
        result[5] *= widthMeters * 0.5f;
        result[6] *= widthMeters * 0.5f;

        // Translation
        result[12] = tx;
        result[13] = ty;
        result[14] = tz;
        result[15] = 1f;

        return result;
    }

    // ── Draw the quad ──────────────────────────────────────────────────────

    private void drawQuad() {
        int stride = 5 * 4; // 5 floats × 4 bytes

        GLES20.glEnableVertexAttribArray(aPosition);
        GLES20.glEnableVertexAttribArray(aTexCoord);

        quadBuffer.position(0);
        GLES20.glVertexAttribPointer(aPosition, 3, GLES20.GL_FLOAT, false, stride, quadBuffer);

        quadBuffer.position(3);
        GLES20.glVertexAttribPointer(aTexCoord, 2, GLES20.GL_FLOAT, false, stride, quadBuffer);

        GLES20.glDrawElements(GLES20.GL_TRIANGLES, 6, GLES20.GL_UNSIGNED_SHORT,
            ByteBuffer.wrap(new byte[]{0,0, 0,1, 0,2, 0,0, 0,2, 0,3})
                .order(ByteOrder.nativeOrder())
                .asShortBuffer()
                .put(QUAD_INDICES)
                .position(0));

        GLES20.glDisableVertexAttribArray(aPosition);
        GLES20.glDisableVertexAttribArray(aTexCoord);
    }

    // ── Render translated text to a Bitmap → GL texture ───────────────────

    private Bitmap createTextBitmap(String translated, String original) {
        int bmpW = 512, bmpH = 256;
        Bitmap bmp = Bitmap.createBitmap(bmpW, bmpH, Bitmap.Config.ARGB_8888);
        Canvas canvas = new Canvas(bmp);

        // Background
        Paint bgPaint = new Paint();
        bgPaint.setColor(Color.parseColor("#E6001F3F"));
        android.graphics.RectF bg = new android.graphics.RectF(0, 0, bmpW, bmpH);
        canvas.drawRoundRect(bg, 24f, 24f, bgPaint);

        // Border
        Paint borderPaint = new Paint();
        borderPaint.setStyle(Paint.Style.STROKE);
        borderPaint.setColor(Color.parseColor("#00E5FF"));
        borderPaint.setStrokeWidth(6f);
        canvas.drawRoundRect(bg, 24f, 24f, borderPaint);

        // Corner accents
        Paint cornerPaint = new Paint();
        cornerPaint.setStyle(Paint.Style.STROKE);
        cornerPaint.setColor(Color.parseColor("#00E5FF"));
        cornerPaint.setStrokeWidth(10f);
        cornerPaint.setStrokeCap(Paint.Cap.ROUND);
        float cl = 36f;
        canvas.drawLine(12, 12, 12 + cl, 12, cornerPaint);
        canvas.drawLine(12, 12, 12, 12 + cl, cornerPaint);
        canvas.drawLine(bmpW - 12, 12, bmpW - 12 - cl, 12, cornerPaint);
        canvas.drawLine(bmpW - 12, 12, bmpW - 12, 12 + cl, cornerPaint);
        canvas.drawLine(12, bmpH - 12, 12 + cl, bmpH - 12, cornerPaint);
        canvas.drawLine(12, bmpH - 12, 12, bmpH - 12 - cl, cornerPaint);
        canvas.drawLine(bmpW - 12, bmpH - 12, bmpW - 12 - cl, bmpH - 12, cornerPaint);
        canvas.drawLine(bmpW - 12, bmpH - 12, bmpW - 12, bmpH - 12 - cl, cornerPaint);

        // Translated text (large, cyan)
        Paint textPaint = new Paint();
        textPaint.setColor(Color.parseColor("#00E5FF"));
        textPaint.setTextSize(64f);
        textPaint.setTypeface(Typeface.create(Typeface.DEFAULT, Typeface.BOLD));
        textPaint.setAntiAlias(true);

        // Wrap translated text
        drawWrappedText(canvas, translated, 24f, 80f, bmpW - 48f, 130f, textPaint);

        // Original text (small, dimmed)
        Paint origPaint = new Paint();
        origPaint.setColor(Color.parseColor("#99FFFFFF"));
        origPaint.setTextSize(32f);
        origPaint.setAntiAlias(true);
        String origLabel = original.replace("\n", " ");
        if (origPaint.measureText(origLabel) > bmpW - 48f) {
            origLabel = origLabel.substring(0, Math.min(origLabel.length(), 28)) + "…";
        }
        canvas.drawText(origLabel, 24f, bmpH - 24f, origPaint);

        return bmp;
    }

    private void drawWrappedText(Canvas canvas, String text,
                                  float x, float y,
                                  float maxW, float maxH,
                                  Paint paint) {
        String[] words = text.split(" ");
        StringBuilder line = new StringBuilder();
        float lineH  = paint.getTextSize() * 1.2f;
        float currY  = y;

        for (String word : words) {
            String test = line.length() == 0 ? word : line + " " + word;
            if (paint.measureText(test) > maxW) {
                if (currY - y + lineH > maxH) break;
                canvas.drawText(line.toString(), x, currY, paint);
                currY += lineH;
                line  = new StringBuilder(word);
            } else {
                line = new StringBuilder(test);
            }
        }
        if (line.length() > 0 && currY - y <= maxH)
            canvas.drawText(line.toString(), x, currY, paint);
    }

    private void uploadTexture(int texId, Bitmap bmp) {
        GLES20.glBindTexture(GLES20.GL_TEXTURE_2D, texId);
        GLES20.glTexParameteri(GLES20.GL_TEXTURE_2D,
            GLES20.GL_TEXTURE_MIN_FILTER, GLES20.GL_LINEAR);
        GLES20.glTexParameteri(GLES20.GL_TEXTURE_2D,
            GLES20.GL_TEXTURE_MAG_FILTER, GLES20.GL_LINEAR);
        GLUtils.texImage2D(GLES20.GL_TEXTURE_2D, 0, bmp, 0);
    }

    // ── Shader compilation ─────────────────────────────────────────────────

    private int buildShaderProgram() {
        int vs = compileShader(GLES20.GL_VERTEX_SHADER,   VERTEX_SHADER);
        int fs = compileShader(GLES20.GL_FRAGMENT_SHADER, FRAGMENT_SHADER);
        int prog = GLES20.glCreateProgram();
        GLES20.glAttachShader(prog, vs);
        GLES20.glAttachShader(prog, fs);
        GLES20.glLinkProgram(prog);
        return prog;
    }

    private int compileShader(int type, String src) {
        int shader = GLES20.glCreateShader(type);
        GLES20.glShaderSource(shader, src);
        GLES20.glCompileShader(shader);
        return shader;
    }

    public void clearAnchors() {
        synchronized (anchorLock) {
            for (AnchoredTextBlock b : anchoredBlocks) b.detach();
            anchoredBlocks.clear();
            blockTextures.clear();
            pendingAnchors.clear();
        }
        planeFound = false;
    }
}
