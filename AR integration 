```java
package com.yourapp;

import com.google.ar.core.Anchor;

/**
 * Holds one translated text block + its ARCore world anchor.
 * The anchor is what makes the text "stick" to the surface in 3D.
 */
public class AnchoredTextBlock {

    public final Anchor anchor;          // ARCore world-space anchor
    public final String originalText;
    public final String translatedText;
    public final float  blockWidthMeters; // estimated real-world width

    public AnchoredTextBlock(Anchor anchor,
                             String originalText,
                             String translatedText,
                             float blockWidthMeters) {
        this.anchor           = anchor;
        this.originalText     = originalText;
        this.translatedText   = translatedText;
        this.blockWidthMeters = blockWidthMeters;
    }

    public void detach() {
        anchor.detach();
    }
}
