## `MainActivity.java` — The coordinator. Gets frame from ARCore, runs ML Kit, maps coordinates correctly, submits to renderer.
```java
package com.yourapp;

import android.Manifest;
import android.content.pm.PackageManager;
import android.graphics.Bitmap;
import android.graphics.Color;
import android.graphics.ImageFormat;
import android.graphics.Rect;
import android.graphics.RectF;
import android.graphics.YuvImage;
import android.media.Image;
import android.opengl.GLSurfaceView;
import android.os.Bundle;
import android.os.Handler;
import android.os.Looper;
import android.util.Log;
import android.view.View;
import android.widget.*;

import androidx.annotation.NonNull;
import androidx.appcompat.app.AppCompatActivity;
import androidx.core.app.ActivityCompat;
import androidx.core.content.ContextCompat;

import com.google.ar.core.*;
import com.google.ar.core.exceptions.*;
import com.google.mlkit.vision.common.InputImage;
import com.google.mlkit.vision.text.Text;
import com.google.mlkit.vision.text.TextRecognition;
import com.google.mlkit.vision.text.TextRecognizer;
import com.google.mlkit.vision.text.latin.TextRecognizerOptions;

import java.io.ByteArrayOutputStream;
import java.nio.ByteBuffer;
import java.util.ArrayList;
import java.util.List;

public class MainActivity extends AppCompatActivity
        implements OverlayRenderer.Callback {

    private static final String TAG     = "Main";
    private static final int    CAM_REQ = 100;

    private GLSurfaceView    glView;
    private TextView         statusTv;
    private Button           btnScan, btnClear;
    private Spinner          spnSrc, spnTgt;

    private Session          arSession;
    private OverlayRenderer  renderer;
    private TextRecognizer   ocr;
    private TranslationProcessor translator;

    private boolean busy        = false;
    private boolean sessionPaused = true;

    // Screen dimensions — set in onWindowFocusChanged
    private int screenW = 0, screenH = 0;

    @Override
    protected void onCreate(Bundle s) {
        super.onCreate(s);
        setContentView(R.layout.activity_main);

        glView   = findViewById(R.id.gl_view);
        statusTv = findViewById(R.id.status);
        btnScan  = findViewById(R.id.btn_scan);
        btnClear = findViewById(R.id.btn_clear);
        spnSrc   = findViewById(R.id.spn_src);
        spnTgt   = findViewById(R.id.spn_tgt);

        setupSpinners();

        ocr        = TextRecognition.getClient(TextRecognizerOptions.DEFAULT_OPTIONS);
        translator = new TranslationProcessor();

        btnScan.setOnClickListener(v -> scan());
        btnClear.setOnClickListener(v -> {
            renderer.clear();
            btnClear.setVisibility(View.GONE);
            btnScan.setEnabled(true);
            status("Point at text and tap SCAN");
        });

        if (hasPerm()) initAR();
        else ActivityCompat.requestPermissions(this,
            new String[]{Manifest.permission.CAMERA}, CAM_REQ);
    }

    @Override
    public void onWindowFocusChanged(boolean focus) {
        super.onWindowFocusChanged(focus);
        screenW = glView.getWidth();
        screenH = glView.getHeight();
        Log.d(TAG, "Screen size: " + screenW + "x" + screenH);
    }

    private void setupSpinners() {
        String[] names = LanguageManager.getDisplayNames();
        ArrayAdapter<String> a = new ArrayAdapter<>(
            this, android.R.layout.simple_spinner_item, names);
        a.setDropDownViewResource(
            android.R.layout.simple_spinner_dropdown_item);
        spnSrc.setAdapter(a); spnTgt.setAdapter(a);
        spnSrc.setSelection(0);
        spnTgt.setSelection(1);
    }

    private void initAR() {
        try {
            arSession = new Session(this);
            Config cfg = new Config(arSession);
            cfg.setFocusMode(Config.FocusMode.AUTO);
            cfg.setUpdateMode(Config.UpdateMode.LATEST_CAMERA_IMAGE);
            cfg.setPlaneFindingMode(
                Config.PlaneFindingMode.HORIZONTAL_AND_VERTICAL);
            cfg.setLightEstimationMode(Config.LightEstimationMode.DISABLED);
            arSession.configure(cfg);
        } catch (UnavailableException e) {
            Log.e(TAG, "ARCore unavailable: " + e);
            status("ARCore unavailable"); return;
        }

        glView.setPreserveEGLContextOnPause(true);
        glView.setEGLContextClientVersion(2);
        renderer = new OverlayRenderer(this, this);
        renderer.setSession(arSession);
        glView.setRenderer(renderer);
        glView.setRenderMode(GLSurfaceView.RENDERMODE_CONTINUOUSLY);

        status("Point at text and tap SCAN");
    }

    @Override protected void onResume() {
        super.onResume();
        if (arSession != null) {
            try {
                arSession.resume();
                sessionPaused = false;
                glView.onResume();
            } catch (CameraNotAvailableException e) {
                status("Camera unavailable");
            }
        }
    }

    @Override protected void onPause() {
        super.onPause();
        if (!sessionPaused && arSession != null) {
            glView.onPause();
            arSession.pause();
            sessionPaused = true;
        }
    }

    @Override protected void onDestroy() {
        super.onDestroy();
        if (arSession != null) arSession.close();
        ocr.close();
        translator.close();
    }

    // ── SCAN ───────────────────────────────────────────────────────────────

    private void scan() {
        if (busy) return;
        if (spnTgt.getSelectedItemPosition() == 0) {
            Toast.makeText(this, "Select a target language",
                Toast.LENGTH_SHORT).show();
            return;
        }

        busy = true;
        btnScan.setEnabled(false);
        status("Capturing frame…");

        // Grab camera image from ARCore on background thread
        new Thread(() -> {
            try {
                // Get a fresh frame from ARCore
                Frame frame = arSession.update();

                if (frame.getCamera().getTrackingState()
                        != TrackingState.TRACKING) {
                    runOnUiThread(() -> {
                        status("Not tracking yet — try again"); reset();
                    });
                    return;
                }

                // Acquire camera image from ARCore
                // ARCore gives us YUV_420_888
                Image cameraImage = frame.acquireCameraImage();
                int   imgW        = cameraImage.getWidth();
                int   imgH        = cameraImage.getHeight();

                // Convert YUV → Bitmap
                Bitmap yuv = yuvToBitmap(cameraImage);
                cameraImage.close();

                if (yuv == null) {
                    runOnUiThread(() -> { status("Frame error"); reset(); });
                    return;
                }

                // ── THIS IS THE KEY ────────────────────────────────────────
                // ARCore camera image in portrait mode:
                //   - Image is LANDSCAPE (wider than tall)
                //   - It needs to be rotated 90° to match the screen
                //
                // We rotate the bitmap 90° so ML Kit sees it UPRIGHT.
                // Then ML Kit bounding boxes are in UPRIGHT image coordinates.
                //
                // To convert upright image coords → screen coords:
                //   screenX = imageX * (screenW / uprightImageW)
                //   screenY = imageY * (screenH / uprightImageH)
                //
                // That's it. Simple scale. No rotation math needed because
                // the bitmap is already rotated to match screen orientation.

                android.graphics.Matrix rotMatrix =
                    new android.graphics.Matrix();
                rotMatrix.postRotate(90); // portrait = 90° rotation
                Bitmap upright = Bitmap.createBitmap(
                    yuv, 0, 0, yuv.getWidth(), yuv.getHeight(),
                    rotMatrix, true);
                yuv.recycle();

                int uprightW = upright.getWidth();  // now matches screen portrait
                int uprightH = upright.getHeight();

                Log.d(TAG, "ARCore image: " + imgW + "x" + imgH
                    + " → upright: " + uprightW + "x" + uprightH
                    + " screen: " + screenW + "x" + screenH);

                runOnUiThread(() -> status("Detecting text…"));

                // Feed upright bitmap to ML Kit with rotation=0
                InputImage input = InputImage.fromBitmap(upright, 0);

                ocr.process(input)
                    .addOnSuccessListener(result -> {

                        Log.d(TAG, "OCR: " + result.getTextBlocks().size()
                            + " blocks");

                        if (result.getTextBlocks().isEmpty()) {
                            upright.recycle();
                            runOnUiThread(() -> {
                                status("No text found — try again"); reset();
                            });
                            return;
                        }

                        List<TextOverlay> overlays  = new ArrayList<>();
                        List<String>      originals = new ArrayList<>();

                        for (Text.TextBlock tb : result.getTextBlocks()) {
                            if (tb.getBoundingBox() == null) continue;
                            if (tb.getText().trim().isEmpty()) continue;

                            Rect r = tb.getBoundingBox();

                            // ── Scale from upright image → screen ──────────
                            // Both are portrait orientation now so this is
                            // a straightforward scale
                            float scaleX = (float) screenW / uprightW;
                            float scaleY = (float) screenH / uprightH;

                            float left   = r.left   * scaleX;
                            float top    = r.top    * scaleY;
                            float right  = r.right  * scaleX;
                            float bottom = r.bottom * scaleY;

                            Log.d(TAG, "Block '"
                                + tb.getText().trim().substring(0,
                                    Math.min(20, tb.getText().trim().length()))
                                + "' imageBox=(" + r.left + "," + r.top
                                + "," + r.right + "," + r.bottom + ")"
                                + " screenBox=(" + left + "," + top
                                + "," + right + "," + bottom + ")");

                            TextOverlay ov = new TextOverlay();
                            ov.original     = tb.getText().trim();
                            ov.screenBounds = new RectF(left, top, right, bottom);

                            // Sample colours from upright bitmap
                            sampleColours(upright, r, ov);

                            originals.add(ov.original);
                            overlays.add(ov);
                        }

                        upright.recycle();

                        if (overlays.isEmpty()) {
                            runOnUiThread(() -> { status("No valid blocks"); reset(); });
                            return;
                        }

                        runOnUiThread(() -> status("Translating…"));

                        String src = LanguageManager.getCode(
                            spnSrc.getSelectedItem().toString());
                        String tgt = LanguageManager.getCode(
                            spnTgt.getSelectedItem().toString());

                        // ── ML Kit Translate ───────────────────────────────
                        translator.translate(originals, src, tgt,
                            new TranslationProcessor.Callback() {

                            @Override
                            public void onDone(List<String> results) {
                                for (int i = 0; i < results.size()
                                        && i < overlays.size(); i++) {
                                    overlays.get(i).translated = results.get(i);
                                    Log.d(TAG, "Translated [" + i + "]: '"
                                        + originals.get(i) + "' → '"
                                        + results.get(i) + "'");
                                }

                                // Submit to renderer on GL thread
                                glView.queueEvent(() -> {
                                    try {
                                        Frame f = arSession.update();
                                        renderer.submitOverlays(overlays);
                                        // Trigger placement by re-submitting
                                        // (renderer picks it up next frame)
                                    } catch (Exception e) {
                                        Log.e(TAG, "AR submit error: " + e);
                                    }
                                });

                                runOnUiThread(() -> {
                                    status("✅ " + overlays.size()
                                        + " block(s) placed");
                                    btnClear.setVisibility(View.VISIBLE);
                                    busy = false;
                                });
                            }

                            @Override public void onError(String msg) {
                                runOnUiThread(() -> {
                                    status("Translation error: " + msg);
                                    reset();
                                });
                            }

                            @Override public void onStatus(String msg) {
                                runOnUiThread(() -> status(msg));
                            }
                        });
                    })
                    .addOnFailureListener(e -> {
                        upright.recycle();
                        runOnUiThread(() -> {
                            status("OCR failed: " + e.getMessage()); reset();
                        });
                    });

            } catch (NotYetAvailableException e) {
                Log.w(TAG, "Frame not available yet");
                runOnUiThread(() -> { status("Not ready — try again"); reset(); });
            } catch (Exception e) {
                Log.e(TAG, "Scan error: " + e);
                runOnUiThread(() -> { status("Error: " + e.getMessage()); reset(); });
            }
        }).start();
    }

    // ── YUV → Bitmap ───────────────────────────────────────────────────────

    private Bitmap yuvToBitmap(Image image) {
        try {
            Image.Plane[] planes = image.getPlanes();
            ByteBuffer yBuf  = planes[0].getBuffer();
            ByteBuffer uBuf  = planes[1].getBuffer();
            ByteBuffer vBuf  = planes[2].getBuffer();

            int ySize = yBuf.remaining();
            int uSize = uBuf.remaining();
            int vSize = vBuf.remaining();

            byte[] nv21 = new byte[ySize + uSize + vSize];
            yBuf.get(nv21, 0, ySize);
            vBuf.get(nv21, ySize, vSize);
            uBuf.get(nv21, ySize + vSize, uSize);

            YuvImage yuvImage = new YuvImage(
                nv21, ImageFormat.NV21,
                image.getWidth(), image.getHeight(), null);
            ByteArrayOutputStream out = new ByteArrayOutputStream();
            yuvImage.compressToJpeg(
                new Rect(0, 0, image.getWidth(), image.getHeight()),
                90, out);
            byte[] jpg = out.toByteArray();
            return android.graphics.BitmapFactory
                .decodeByteArray(jpg, 0, jpg.length);
        } catch (Exception e) {
            Log.e(TAG, "YUV convert failed: " + e);
            return null;
        }
    }

    // ── Colour sampling ────────────────────────────────────────────────────

    private void sampleColours(Bitmap bmp, Rect r, TextOverlay ov) {
        int l = Math.max(0, r.left);
        int t = Math.max(0, r.top);
        int ri = Math.min(bmp.getWidth()  - 1, r.right);
        int b  = Math.min(bmp.getHeight() - 1, r.bottom);

        if (ri <= l || b <= t) {
            ov.bgColor   = Color.WHITE;
            ov.textColor = Color.BLACK;
            ov.fontSizePx= 32f;
            return;
        }

        // Sample outer border for background
        long rS=0,gS=0,bS=0,n=0;
        int border = Math.min(6, Math.min(r.width(), r.height()) / 4);
        border = Math.max(1, border);

        for (int x = l; x <= ri; x++) {
            if (t < bmp.getHeight()) {
                int px = bmp.getPixel(x, t);
                rS+=Color.red(px); gS+=Color.green(px); bS+=Color.blue(px); n++;
            }
            if (b < bmp.getHeight()) {
                int px = bmp.getPixel(x, b);
                rS+=Color.red(px); gS+=Color.green(px); bS+=Color.blue(px); n++;
            }
        }
        for (int y = t; y <= b; y++) {
            if (l < bmp.getWidth()) {
                int px = bmp.getPixel(l, y);
                rS+=Color.red(px); gS+=Color.green(px); bS+=Color.blue(px); n++;
            }
            if (ri < bmp.getWidth()) {
                int px = bmp.getPixel(ri, y);
                rS+=Color.red(px); gS+=Color.green(px); bS+=Color.blue(px); n++;
            }
        }

        ov.bgColor = n > 0
            ? Color.rgb((int)(rS/n), (int)(gS/n), (int)(bS/n))
            : Color.WHITE;

        float bgLum = 0.299f * Color.red(ov.bgColor)
                    + 0.587f * Color.green(ov.bgColor)
                    + 0.114f * Color.blue(ov.bgColor);
        ov.textColor  = bgLum > 128 ? Color.BLACK : Color.WHITE;
        ov.fontSizePx = Math.max(16f, r.height() /
            (float) Math.max(1, Math.max(1,
                ov.original.split("\n").length)) * 0.75f);
    }

    // ── Callbacks ──────────────────────────────────────────────────────────

    @Override public void onPlaneFound() {
        status("Surface found — tap SCAN");
    }

    @Override public void onLocked(int count) {
        status("🔒 " + count + " block(s) locked");
    }

    // ── Helpers ────────────────────────────────────────────────────────────

    private void status(String m) { statusTv.setText(m); }

    private void reset() {
        busy = false;
        btnScan.setEnabled(true);
    }

    private boolean hasPerm() {
        return ContextCompat.checkSelfPermission(this,
            Manifest.permission.CAMERA) == PackageManager.PERMISSION_GRANTED;
    }

    @Override
    public void onRequestPermissionsResult(int code,
            @NonNull String[] p, @NonNull int[] g) {
        super.onRequestPermissionsResult(code, p, g);
        if (code == CAM_REQ && g.length > 0
                && g[0] == PackageManager.PERMISSION_GRANTED) initAR();
    }
