## `TranslationProcessor.java`
```java
package com.yourapp;

import com.google.mlkit.common.model.DownloadConditions;
import com.google.mlkit.nl.languageid.LanguageIdentification;
import com.google.mlkit.nl.languageid.LanguageIdentifier;
import com.google.mlkit.nl.translate.TranslateLanguage;
import com.google.mlkit.nl.translate.Translation;
import com.google.mlkit.nl.translate.Translator;
import com.google.mlkit.nl.translate.TranslatorOptions;

import java.util.ArrayList;
import java.util.List;
import java.util.concurrent.atomic.AtomicInteger;

public class TranslationProcessor {

    public interface Callback {
        void onDone(List<String> results);
        void onError(String msg);
        void onStatus(String msg);
    }

    private Translator       translator;
    private final LanguageIdentifier identifier =
        LanguageIdentification.getClient();

    public void translate(List<String> texts,
                          String src, String tgt,
                          Callback cb) {

        if (texts == null || texts.isEmpty()) {
            cb.onError("No text"); return;
        }

        if ("auto".equals(src)) {
            identifier.identifyLanguage(String.join(" ", texts))
                .addOnSuccessListener(lang -> doTranslate(texts,
                    "und".equals(lang) ? TranslateLanguage.ENGLISH : lang,
                    tgt, cb))
                .addOnFailureListener(e -> doTranslate(texts,
                    TranslateLanguage.ENGLISH, tgt, cb));
        } else {
            doTranslate(texts, src, tgt, cb);
        }
    }

    private void doTranslate(List<String> texts,
                              String src, String tgt, Callback cb) {
        if (src.equals(tgt)) { cb.onDone(texts); return; }
        if (translator != null) translator.close();

        translator = Translation.getClient(
            new TranslatorOptions.Builder()
                .setSourceLanguage(src)
                .setTargetLanguage(tgt)
                .build());

        cb.onStatus("Downloading model…");

        translator.downloadModelIfNeeded(
                new DownloadConditions.Builder().requireWifi().build())
            .addOnSuccessListener(v -> {
                List<String> results = new ArrayList<>();
                for (int i = 0; i < texts.size(); i++) results.add("");
                AtomicInteger left = new AtomicInteger(texts.size());

                for (int i = 0; i < texts.size(); i++) {
                    final int idx = i;
                    translator.translate(texts.get(i))
                        .addOnSuccessListener(t -> {
                            results.set(idx, t);
                            if (left.decrementAndGet() == 0) cb.onDone(results);
                        })
                        .addOnFailureListener(e -> {
                            results.set(idx, texts.get(idx));
                            if (left.decrementAndGet() == 0) cb.onDone(results);
                        });
                }
            })
            .addOnFailureListener(e -> cb.onError("Download failed: " + e.getMessage()));
    }

    public void close() {
        if (translator != null) translator.close();
        identifier.close();
    }
}
