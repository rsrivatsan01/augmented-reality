## `OverlayRenderer.java` — Draws translated text quads locked to surface
```java
package com.yourapp;

import android.content.Context;
import android.graphics.Bitmap;
import android.graphics.Canvas;
import android.graphics.Color;
import android.graphics.Paint;
import android.graphics.RectF;
import android.graphics.Typeface;
import android.opengl.GLES20;
import android.opengl.GLSurfaceView;
import android.opengl.GLUtils;
import android.opengl.Matrix;
import android.util.Log;

import com.google.ar.core.Anchor;
import com.google.ar.core.Camera;
import com.google.ar.core.Frame;
import com.google.ar.core.HitResult;
import com.google.ar.core.Plane;
import com.google.ar.core.Pose;
import com.google.ar.core.Session;
import com.google.ar.core.TrackingState;

import java.io.IOException;
import java.nio.ByteBuffer;
import java.nio.ByteOrder;
import java.nio.FloatBuffer;
import java.nio.ShortBuffer;
import java.util.ArrayList;
import java.util.List;

import javax.microedition.khronos.egl.EGLConfig;
import javax.microedition.khronos.opengles.GL10;

public class OverlayRenderer implements GLSurfaceView.Renderer {

    private static final String TAG = "OverlayRenderer";

    // ── Shader ─────────────────────────────────────────────────────────────
    private static final String VS =
        "uniform mat4 u_MVP;\n" +
        "attribute vec4 a_Pos;\n" +
        "attribute vec2 a_UV;\n" +
        "varying vec2 v_UV;\n" +
        "void main(){\n" +
        "  gl_Position = u_MVP * a_Pos;\n" +
        "  v_UV = a_UV;\n" +
        "}\n";

    private static final String FS =
        "precision mediump float;\n" +
        "uniform sampler2D u_Tex;\n" +
        "uniform float u_Alpha;\n" +
        "varying vec2 v_UV;\n" +
        "void main(){\n" +
        "  vec4 c = texture2D(u_Tex, v_UV);\n" +
        "  if (c.a * u_Alpha < 0.05) discard;\n" +
        "  gl_FragColor = vec4(c.rgb, c.a * u_Alpha);\n" +
        "}\n";

    // Flat quad in XZ plane (lies ON a horizontal surface)
    // For vertical surfaces we rotate in buildModelMatrix()
    private static final float[] QUAD = {
        -0.5f, 0f, -0.5f,  0f, 0f,
        -0.5f, 0f,  0.5f,  0f, 1f,
         0.5f, 0f,  0.5f,  1f, 1f,
         0.5f, 0f, -0.5f,  1f, 0f,
    };
    private static final short[] IDX = {0,1,2, 0,2,3};

    private final Context context;
    private Session       session;

    // GL
    private int          prog, uMVP, uTex, uAlpha, aPos, aUV;
    private FloatBuffer  vBuf;
    private ShortBuffer  iBuf;
    private BackgroundRenderer bgRenderer;

    // Overlays
    private final List<TextOverlay>  overlays    = new ArrayList<>();
    private volatile List<TextOverlay> pending   = null;
    private volatile boolean          doClear    = false;

    // Camera matrices
    private final float[] proj = new float[16];
    private final float[] view = new float[16];

    // Lock params
    private static final float FADE_SPEED   = 0.06f;
    private static final int   LOCK_FRAMES  = 30;
    private static final float LOCK_DRIFT   = 0.005f; // 5mm

    public interface Callback {
        void onPlaneFound();
        void onLocked(int count);
    }
    private final Callback  cb;
    private       boolean   planeSeen = false;

    public OverlayRenderer(Context ctx, Callback cb) {
        this.context = ctx;
        this.cb      = cb;
    }

    public void setSession(Session s) { this.session = s; }

    // Called from main thread
    public void submitOverlays(List<TextOverlay> list) { pending = list; }
    public void clear()                                { doClear = true;  }

    // ── GL lifecycle ───────────────────────────────────────────────────────

    @Override
    public void onSurfaceCreated(GL10 gl, EGLConfig cfg) {
        GLES20.glClearColor(0f, 0f, 0f, 1f);
        bgRenderer = new BackgroundRenderer();
        try { bgRenderer.createOnGlThread(context); }
        catch (IOException e) { Log.e(TAG, "BG fail: " + e); }

        int vs = compileShader(GLES20.GL_VERTEX_SHADER, VS);
        int fs = compileShader(GLES20.GL_FRAGMENT_SHADER, FS);
        prog   = GLES20.glCreateProgram();
        GLES20.glAttachShader(prog, vs);
        GLES20.glAttachShader(prog, fs);
        GLES20.glLinkProgram(prog);

        uMVP  = GLES20.glGetUniformLocation(prog, "u_MVP");
        uTex  = GLES20.glGetUniformLocation(prog, "u_Tex");
        uAlpha= GLES20.glGetUniformLocation(prog, "u_Alpha");
        aPos  = GLES20.glGetAttribLocation(prog,  "a_Pos");
        aUV   = GLES20.glGetAttribLocation(prog,  "a_UV");

        ByteBuffer v = ByteBuffer.allocateDirect(QUAD.length * 4);
        v.order(ByteOrder.nativeOrder());
        vBuf = v.asFloatBuffer();
        vBuf.put(QUAD).position(0);

        ByteBuffer i = ByteBuffer.allocateDirect(IDX.length * 2);
        i.order(ByteOrder.nativeOrder());
        iBuf = i.asShortBuffer();
        iBuf.put(IDX).position(0);
    }

    @Override
    public void onSurfaceChanged(GL10 gl, int w, int h) {
        GLES20.glViewport(0, 0, w, h);
        if (session != null) {
            int rot = ((android.app.Activity) context)
                .getWindowManager().getDefaultDisplay().getRotation();
            session.setDisplayGeometry(rot, w, h);
        }
    }

    @Override
    public void onDrawFrame(GL10 gl) {
        GLES20.glClear(
            GLES20.GL_COLOR_BUFFER_BIT | GLES20.GL_DEPTH_BUFFER_BIT);
        if (session == null) return;

        try {
            session.setCameraTextureName(bgRenderer.getTextureId());
            Frame  frame  = session.update();
            Camera camera = frame.getCamera();

            // Always draw camera feed first
            bgRenderer.draw(frame);

            if (camera.getTrackingState() != TrackingState.TRACKING) return;

            camera.getProjectionMatrix(proj, 0, 0.01f, 100f);
            camera.getViewMatrix(view, 0);

            // Detect planes
            if (!planeSeen) {
                for (Plane p : session.getAllTrackables(Plane.class)) {
                    if (p.getTrackingState() == TrackingState.TRACKING) {
                        planeSeen = true;
                        ((android.app.Activity) context)
                            .runOnUiThread(cb::onPlaneFound);
                        break;
                    }
                }
            }

            // Clear
            if (doClear) {
                doClear = false;
                freeAll();
            }

            // Upload pending overlays
            List<TextOverlay> p = pending;
            if (p != null) {
                pending = null;
                placeOverlays(p, frame);
            }

            if (overlays.isEmpty()) return;

            // Draw
            GLES20.glEnable(GLES20.GL_BLEND);
            GLES20.glBlendFunc(GLES20.GL_SRC_ALPHA,
                GLES20.GL_ONE_MINUS_SRC_ALPHA);
            GLES20.glDepthMask(false);
            GLES20.glUseProgram(prog);

            int locked = 0;
            for (TextOverlay ov : overlays) {
                if (ov.textureId < 0) continue;

                float[] mat = getMatrix(ov);
                if (mat == null) continue;

                if (!ov.locked) tryLock(ov, mat);
                if (ov.locked)  locked++;

                ov.alpha = Math.min(1f, ov.alpha + FADE_SPEED);

                float[] model = buildModelMatrix(mat, ov.widthM, ov.heightM);
                float[] mv    = new float[16];
                float[] mvp   = new float[16];
                Matrix.multiplyMM(mv,  0, view,  0, model, 0);
                Matrix.multiplyMM(mvp, 0, proj,  0, mv,    0);

                GLES20.glUniformMatrix4fv(uMVP, 1, false, mvp, 0);
                GLES20.glUniform1f(uAlpha, ov.alpha);
                GLES20.glActiveTexture(GLES20.GL_TEXTURE0);
                GLES20.glBindTexture(GLES20.GL_TEXTURE_2D, ov.textureId);
                GLES20.glUniform1i(uTex, 0);

                drawQuad();
            }

            GLES20.glDepthMask(true);
            GLES20.glDisable(GLES20.GL_BLEND);

            if (locked == overlays.size() && !overlays.isEmpty()) {
                final int n = locked;
                ((android.app.Activity) context)
                    .runOnUiThread(() -> cb.onLocked(n));
            }

        } catch (Exception e) {
            Log.e(TAG, "Frame error: " + e);
        }
    }

    // ── Placement ──────────────────────────────────────────────────────────

    private void placeOverlays(List<TextOverlay> list, Frame frame) {
        freeAll();

        int viewW = ((android.app.Activity) context)
            .findViewById(android.R.id.content).getWidth();
        int viewH = ((android.app.Activity) context)
            .findViewById(android.R.id.content).getHeight();

        for (TextOverlay ov : list) {
            if (ov.translated == null || ov.translated.isEmpty()) continue;

            // screenBounds are already correct screen coords
            float sx = ov.screenBounds.centerX();
            float sy = ov.screenBounds.centerY();

            Log.d(TAG, "Placing overlay at screen (" + sx + "," + sy + ")"
                + " translated='" + ov.translated + "'");

            // ARCore hit-test at screen centre of text block
            Anchor anchor   = null;
            float  depth    = 0.6f;
            float[] planeMat = null;

            try {
                List<HitResult> hits = frame.hitTest(sx, sy);
                for (HitResult hit : hits) {
                    if (!(hit.getTrackable() instanceof Plane)) continue;
                    Plane plane = (Plane) hit.getTrackable();
                    if (plane.getTrackingState() != TrackingState.TRACKING) continue;
                    if (plane.getSubsumedBy() != null) continue;

                    anchor  = hit.createAnchor();
                    depth   = hit.getDistance();

                    // Rotation from PLANE, not camera — this is the key
                    planeMat = new float[16];
                    plane.getCenterPose().toMatrix(planeMat, 0);

                    float[] hitMat = new float[16];
                    hit.getHitPose().toMatrix(hitMat, 0);

                    // Use plane rotation, hit-test translation
                    planeMat[12] = hitMat[12];
                    planeMat[13] = hitMat[13];
                    planeMat[14] = hitMat[14];

                    Log.d(TAG, "Hit plane at depth=" + depth);
                    break;
                }
            } catch (Exception e) {
                Log.e(TAG, "Hit-test error: " + e);
            }

            // Fallback: place in front of camera if no plane found
            if (anchor == null) {
                Log.w(TAG, "No plane hit, using fallback anchor");
                try {
                    Pose cam   = frame.getCamera().getPose();
                    float[] t  = cam.getTranslation();
                    float[] fwd= cam.getZAxis();
                    Pose pose  = Pose.makeTranslation(
                        t[0] - fwd[0] * depth,
                        t[1] - fwd[1] * depth,
                        t[2] - fwd[2] * depth);
                    anchor   = session.createAnchor(pose);
                    planeMat = new float[16];
                    pose.toMatrix(planeMat, 0);
                } catch (Exception e) {
                    Log.e(TAG, "Fallback anchor failed: " + e);
                    continue;
                }
            }

            // Real-world size from depth + screen fraction
            float fov       = 0.6f; // tan(~31°), typical phone FOV
            float fracW     = ov.screenBounds.width()  / viewW;
            float fracH     = ov.screenBounds.height() / viewH;
            ov.widthM  = Math.max(0.05f, Math.min(2f, 2f * depth * fov * fracW));
            ov.heightM = Math.max(0.02f, Math.min(1f, 2f * depth * fov * fracH));

            // Build texture from translated text
            ov.textureId = uploadTexture(
                buildBitmap(ov.translated, ov.bgColor, ov.textColor,
                    ov.fontSizePx, ov.widthM, ov.heightM));

            ov.anchor       = anchor;
            ov.lockedMatrix = planeMat.clone();
            overlays.add(ov);
        }
    }

    // ── Matrix ─────────────────────────────────────────────────────────────

    private float[] getMatrix(TextOverlay ov) {
        if (ov.locked) return ov.lockedMatrix;

        if (ov.anchor == null ||
            ov.anchor.getTrackingState() != TrackingState.TRACKING) {
            return ov.lockedMatrix;
        }

        float[] anchorMat = new float[16];
        ov.anchor.getPose().toMatrix(anchorMat, 0);

        // Rotation from plane (stored in lockedMatrix), translation from anchor
        float[] m = ov.lockedMatrix.clone();
        m[12] = anchorMat[12];
        m[13] = anchorMat[13];
        m[14] = anchorMat[14];
        return m;
    }

    private void tryLock(TextOverlay ov, float[] current) {
        if (ov.locked) return;

        float dx = current[12] - ov.lockedMatrix[12];
        float dy = current[13] - ov.lockedMatrix[13];
        float dz = current[14] - ov.lockedMatrix[14];
        float drift = (float) Math.sqrt(dx*dx + dy*dy + dz*dz);

        if (drift < LOCK_DRIFT) {
            ov.stableFrames++;
            // Blend toward current position smoothly
            ov.lockedMatrix[12] += dx * 0.1f;
            ov.lockedMatrix[13] += dy * 0.1f;
            ov.lockedMatrix[14] += dz * 0.1f;
        } else {
            ov.stableFrames = 0;
        }

        if (ov.stableFrames >= LOCK_FRAMES) {
            ov.locked = true;
            if (ov.anchor != null) {
                ov.anchor.detach();
                ov.anchor = null;
            }
            Log.d(TAG, "Overlay locked at ("
                + ov.lockedMatrix[12] + ","
                + ov.lockedMatrix[13] + ","
                + ov.lockedMatrix[14] + ")");
        }
    }

    /**
     * Builds model matrix that places quad flush on the detected plane.
     * Uses plane normal as Y-up so quad lies flat on the surface.
     */
    private float[] buildModelMatrix(float[] planeMat,
                                      float widthM, float heightM) {
        float[] scale = new float[16];
        Matrix.setIdentityM(scale, 0);
        Matrix.scaleM(scale, 0, widthM, 1f, heightM);

        float[] model = new float[16];
        Matrix.multiplyMM(model, 0, planeMat, 0, scale, 0);

        // 1mm nudge toward camera to avoid z-fighting
        float[] invView = new float[16];
        Matrix.invertM(invView, 0, view, 0);
        float camX = invView[12], camY = invView[13], camZ = invView[14];
        float dx = camX - model[12];
        float dy = camY - model[13];
        float dz = camZ - model[14];
        float len = (float) Math.sqrt(dx*dx + dy*dy + dz*dz);
        if (len > 0) {
            model[12] += (dx/len) * 0.001f;
            model[13] += (dy/len) * 0.001f;
            model[14] += (dz/len) * 0.001f;
        }
        return model;
    }

    // ── Bitmap → GL texture ────────────────────────────────────────────────

    private Bitmap buildBitmap(String text, int bgColor, int textColor,
                                float fontSizePx,
                                float widthM, float heightM) {
        // Bitmap aspect matches real-world block aspect
        int bmpW = 512;
        int bmpH = Math.max(64,
            (int)(512f * (heightM / Math.max(0.001f, widthM))));
        bmpH = Math.min(bmpH, 512);

        Bitmap bmp = Bitmap.createBitmap(bmpW, bmpH, Bitmap.Config.ARGB_8888);
        Canvas c   = new Canvas(bmp);

        // Background
        c.drawColor(bgColor);

        // Text
        Paint tp = new Paint();
        tp.setAntiAlias(true);
        tp.setColor(textColor);
        tp.setTextSize(Math.max(32f, Math.min(bmpH * 0.7f, fontSizePx * 2.5f)));
        tp.setTypeface(Typeface.DEFAULT_BOLD);

        // Outline for contrast
        Paint op = new Paint(tp);
        op.setStyle(Paint.Style.STROKE);
        op.setStrokeWidth(tp.getTextSize() * 0.07f);
        float lum = 0.299f * Color.red(textColor)
                  + 0.587f * Color.green(textColor)
                  + 0.114f * Color.blue(textColor);
        op.setColor(lum > 128 ? Color.BLACK : Color.WHITE);

        // Word wrap + draw centred
        float maxW  = bmpW * 0.9f;
        float lineH = tp.getTextSize() * 1.2f;
        List<String> lines = new ArrayList<>();
        StringBuilder cur  = new StringBuilder();

        for (String w : text.split(" ")) {
            if (w.isEmpty()) continue;
            String test = cur.length() == 0 ? w : cur + " " + w;
            if (tp.measureText(test) > maxW && cur.length() > 0) {
                lines.add(cur.toString());
                cur = new StringBuilder(w);
            } else {
                cur = new StringBuilder(test);
            }
        }
        if (cur.length() > 0) lines.add(cur.toString());

        float y = (bmpH - lines.size() * lineH) / 2f + tp.getTextSize();
        for (String line : lines) {
            float x = (bmpW - tp.measureText(line)) / 2f;
            c.drawText(line, x, y, op);
            c.drawText(line, x, y, tp);
            y += lineH;
        }

        return bmp;
    }

    private int uploadTexture(Bitmap bmp) {
        int[] id = new int[1];
        GLES20.glGenTextures(1, id, 0);
        GLES20.glBindTexture(GLES20.GL_TEXTURE_2D, id[0]);
        GLES20.glTexParameteri(GLES20.GL_TEXTURE_2D,
            GLES20.GL_TEXTURE_MIN_FILTER, GLES20.GL_LINEAR_MIPMAP_LINEAR);
        GLES20.glTexParameteri(GLES20.GL_TEXTURE_2D,
            GLES20.GL_TEXTURE_MAG_FILTER, GLES20.GL_LINEAR);
        GLES20.glTexParameteri(GLES20.GL_TEXTURE_2D,
            GLES20.GL_TEXTURE_WRAP_S, GLES20.GL_CLAMP_TO_EDGE);
        GLES20.glTexParameteri(GLES20.GL_TEXTURE_2D,
            GLES20.GL_TEXTURE_WRAP_T, GLES20.GL_CLAMP_TO_EDGE);
        GLUtils.texImage2D(GLES20.GL_TEXTURE_2D, 0, bmp, 0);
        GLES20.glGenerateMipmap(GLES20.GL_TEXTURE_2D);
        bmp.recycle();
        return id[0];
    }

    // ── Draw quad ──────────────────────────────────────────────────────────

    private void drawQuad() {
        int stride = 5 * 4;
        vBuf.position(0);
        GLES20.glEnableVertexAttribArray(aPos);
        GLES20.glVertexAttribPointer(aPos, 3,
            GLES20.GL_FLOAT, false, stride, vBuf);
        vBuf.position(3);
        GLES20.glEnableVertexAttribArray(aUV);
        GLES20.glVertexAttribPointer(aUV, 2,
            GLES20.GL_FLOAT, false, stride, vBuf);
        iBuf.position(0);
        GLES20.glDrawElements(GLES20.GL_TRIANGLES, 6,
            GLES20.GL_UNSIGNED_SHORT, iBuf);
        GLES20.glDisableVertexAttribArray(aPos);
        GLES20.glDisableVertexAttribArray(aUV);
    }

    // ── Cleanup ────────────────────────────────────────────────────────────

    private void freeAll() {
        for (TextOverlay ov : overlays) {
            if (ov.anchor != null) ov.anchor.detach();
            if (ov.textureId >= 0) {
                int[] t = {ov.textureId};
                GLES20.glDeleteTextures(1, t, 0);
            }
        }
        overlays.clear();
        planeSeen = false;
    }

    private int compileShader(int type, String src) {
        int s = GLES20.glCreateShader(type);
        GLES20.glShaderSource(s, src);
        GLES20.glCompileShader(s);
        return s;
    }
}
