    public String  translated;

    // Colours sampled from the camera frame
    public int     bgColor;
    public int     textColor;
    public float   fontSizePx;

    // ARCore anchor placed at hit-test point
    public Anchor  anchor;

    // Real world size in metres
    public float   widthM;
    public float   heightM;

    // GL texture holding the translated text bitmap
    public int     textureId = -1;

    // Lock state
    public boolean locked       = false;
    public float[] lockedMatrix = null;
    public int     stableFrames = 0;
    public float   alpha        = 0f;
}
