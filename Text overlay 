private void runTextDetection(Bitmap bitmap, int viewW, int viewH) {
    InputImage image = InputImage.fromBitmap(bitmap, 0);

    textRecognizer.process(image)
        .addOnSuccessListener(result -> {
            if (result.getTextBlocks().isEmpty()) {
                runOnUiThread(() -> {
                    hideLoading();
                    showStatus("No text found. Try again.");
                    isProcessing = false;
                    btnCapture.setEnabled(true);
                });
                return;
            }

            List<String> texts  = new ArrayList<>();
            List<RectF>  bounds = new ArrayList<>();
            List<TextStyleAnalyzer.TextStyle> styles = new ArrayList<>(); // ← NEW

            for (Text.TextBlock block : result.getTextBlocks()) {
                if (block.getBoundingBox() == null) continue;
                texts.add(block.getText());

                android.graphics.Rect r = block.getBoundingBox();
                bounds.add(new RectF(r.left, r.top, r.right, r.bottom));

                // ── Analyse background + text colour + font size ──────────
                TextStyleAnalyzer.TextStyle style =
                    TextStyleAnalyzer.analyze(bitmap, block);
                styles.add(style);
            }

            runOnUiThread(() -> showLoading("Translating…"));

            String srcCode = LanguageManager.getCode(
                spinnerSource.getSelectedItem().toString());
            String tgtCode = LanguageManager.getCode(
                spinnerTarget.getSelectedItem().toString());

            translator.translate(texts, srcCode, tgtCode,
                new TranslationProcessor.TranslationCallback() {

                @Override
                public void onComplete(List<String> translated) {
                    runOnUiThread(() -> showLoading("Placing AR anchors…"));
                    try {
                        Frame frame = arSession.update();

                        // Pass styles alongside translations
                        glSurfaceView.queueEvent(() ->
                            arRenderer.placeAnchors(
                                frame, texts, translated,
                                bounds, styles,   // ← pass styles
                                viewW, viewH));

                        runOnUiThread(() -> {
                            hideLoading();
                            showStatus("✅ " + translated.size()
                                + " block(s) placed in AR");
                            btnReset.setVisibility(View.VISIBLE);
                            isProcessing = false;
                        });

                    } catch (Exception e) {
                        runOnUiThread(() -> {
                            hideLoading();
                            showStatus("Anchor error: " + e.getMessage());
                            isProcessing = false;
                            btnCapture.setEnabled(true);
                        });
                    }
                }

                @Override
                public void onError(String error) {
                    runOnUiThread(() -> {
                        hideLoading();
                        showStatus("Translation error: " + error);
                        isProcessing = false;
                        btnCapture.setEnabled(true);
                    });
                }

                @Override
                public void onProgress(String message) {
                    runOnUiThread(() -> showLoading(message));
                }
            });
        })
        .addOnFailureListener(e -> runOnUiThread(() -> {
            hideLoading();
            showStatus("Detection failed: " + e.getMessage());
            isProcessing = false;
            btnCapture.setEnabled(true);
        }));
}
