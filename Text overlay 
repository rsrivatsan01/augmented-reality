synchronized (anchorLock) {
    if (!pendingAnchors.isEmpty()) {
        for (int i = 0; i < pendingAnchors.size(); i++) {
            AnchoredTextBlock block = pendingAnchors.get(i);
            TextStyleAnalyzer.TextStyle style = pendingStyles.get(i);

            int[] texId = new int[1];
            GLES20.glGenTextures(1, texId, 0);

            // Compute aspect ratio of original block
            float aspect = style.blockHeightPx > 0
                ? style.blockWidthPx / style.blockHeightPx : 2f;

            // Create seamless replacement billboard
            Bitmap bmp = NaturalTextBillboard.create(
                block.translatedText, style, aspect);

            uploadTexture(texId[0], bmp);
            bmp.recycle();
            blockTextures.add(texId);
            blockStyles.add(style);
        }
        anchoredBlocks.addAll(pendingAnchors);
        pendingAnchors.clear();
        pendingStyles.clear();
    }
}
