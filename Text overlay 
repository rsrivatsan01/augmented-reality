## `TextStyleAnalyzer.java` — Extracts font size, text colour, background colour from each text block region
```java
package com.yourapp;

import android.graphics.Bitmap;
import android.graphics.Color;
import android.graphics.Rect;

import com.google.mlkit.vision.text.Text;

/**
 * Analyses the pixel region of each detected text block to extract:
 * - Dominant background colour (for erasing original text)
 * - Dominant text colour (for rendering translation)
 * - Estimated font size in pixels
 */
public class TextStyleAnalyzer {

    public static class TextStyle {
        public int   backgroundColor;  // ARGB colour to paint over original text
        public int   textColor;        // ARGB colour to use for translated text
        public float fontSizePx;       // estimated font size in pixels
        public float blockWidthPx;     // width of the text block on screen
        public float blockHeightPx;    // height of the text block on screen

        public TextStyle(int bgColor, int textColor,
                         float fontSize, float blockW, float blockH) {
            this.backgroundColor = bgColor;
            this.textColor       = textColor;
            this.fontSizePx      = fontSize;
            this.blockWidthPx    = blockW;
            this.blockHeightPx   = blockH;
        }
    }

    /**
     * Analyses a text block within the given bitmap.
     * Returns a TextStyle describing how to recreate that text.
     */
    public static TextStyle analyze(Bitmap bitmap, Text.TextBlock block) {
        Rect box = block.getBoundingBox();
        if (box == null) return defaultStyle();

        // Clamp to bitmap bounds
        int left   = Math.max(0, box.left);
        int top    = Math.max(0, box.top);
        int right  = Math.min(bitmap.getWidth()  - 1, box.right);
        int bottom = Math.min(bitmap.getHeight() - 1, box.bottom);

        if (right <= left || bottom <= top) return defaultStyle();

        int blockW = right - left;
        int blockH = bottom - top;

        // Sample pixels from the block region
        int[] pixels = new int[blockW * blockH];
        bitmap.getPixels(pixels, 0, blockW, left, top, blockW, blockH);

        // Split pixels into light vs dark clusters
        // Light pixels → background, Dark pixels → text (or vice versa)
        long sumLightR = 0, sumLightG = 0, sumLightB = 0, lightCount = 0;
        long sumDarkR  = 0, sumDarkG  = 0, sumDarkB  = 0, darkCount  = 0;

        for (int pixel : pixels) {
            int r = Color.red(pixel);
            int g = Color.green(pixel);
            int b = Color.blue(pixel);
            float luminance = 0.299f * r + 0.587f * g + 0.114f * b;

            if (luminance > 128f) {
                sumLightR += r; sumLightG += g; sumLightB += b;
                lightCount++;
            } else {
                sumDarkR += r; sumDarkG += g; sumDarkB += b;
                darkCount++;
            }
        }

        int bgColor, textColor;

        if (lightCount == 0 && darkCount == 0) return defaultStyle();

        if (lightCount >= darkCount) {
            // Light background, dark text
            bgColor   = lightCount > 0
                ? Color.rgb((int)(sumLightR/lightCount),
                            (int)(sumLightG/lightCount),
                            (int)(sumLightB/lightCount))
                : Color.WHITE;
            textColor = darkCount > 0
                ? Color.rgb((int)(sumDarkR/darkCount),
                            (int)(sumDarkG/darkCount),
                            (int)(sumDarkB/darkCount))
                : Color.BLACK;
        } else {
            // Dark background, light text
            bgColor   = darkCount > 0
                ? Color.rgb((int)(sumDarkR/darkCount),
                            (int)(sumDarkG/darkCount),
                            (int)(sumDarkB/darkCount))
                : Color.BLACK;
            textColor = lightCount > 0
                ? Color.rgb((int)(sumLightR/lightCount),
                            (int)(sumLightG/lightCount),
                            (int)(sumLightB/lightCount))
                : Color.WHITE;
        }

        // Estimate font size from block height and line count
        int lineCount = Math.max(1, block.getLines().size());
        float fontSizePx = (blockH / (float) lineCount) * 0.72f;
        fontSizePx = Math.max(16f, Math.min(fontSizePx, 120f));

        // Sample border strip for a cleaner background colour
        // (edges of box are most likely pure background)
        int borderBgColor = sampleBorderBackground(bitmap, left, top, right, bottom);
        if (borderBgColor != 0) bgColor = borderBgColor;

        return new TextStyle(bgColor, textColor, fontSizePx, blockW, blockH);
    }

    /**
     * Samples a thin strip around the outside edge of the bounding box
     * to get the purest background colour (avoids text pixels).
     */
    private static int sampleBorderBackground(Bitmap bmp,
                                               int left, int top,
                                               int right, int bottom) {
        int stripSize = 4;
        long r = 0, g = 0, b = 0, count = 0;

        // Top strip (above box)
        int sTop = Math.max(0, top - stripSize);
        for (int x = left; x < right && x < bmp.getWidth(); x++) {
            for (int y = sTop; y < top && y < bmp.getHeight(); y++) {
                int px = bmp.getPixel(x, y);
                r += Color.red(px);
                g += Color.green(px);
                b += Color.blue(px);
                count++;
            }
        }

        // Bottom strip
        int sBot = Math.min(bmp.getHeight() - 1, bottom + stripSize);
        for (int x = left; x < right && x < bmp.getWidth(); x++) {
            for (int y = bottom; y <= sBot && y < bmp.getHeight(); y++) {
                int px = bmp.getPixel(x, y);
                r += Color.red(px);
                g += Color.green(px);
                b += Color.blue(px);
                count++;
            }
        }

        if (count == 0) return 0;
        return Color.rgb((int)(r/count), (int)(g/count), (int)(b/count));
    }

    private static TextStyle defaultStyle() {
        return new TextStyle(Color.WHITE, Color.BLACK, 32f, 200f, 60f);
    }
}
