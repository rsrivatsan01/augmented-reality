## `NaturalTextBillboard.java` — Renders the seamless replacement billboard texture
```java
package com.yourapp;

import android.graphics.Bitmap;
import android.graphics.Canvas;
import android.graphics.Color;
import android.graphics.LinearGradient;
import android.graphics.Paint;
import android.graphics.RectF;
import android.graphics.Shader;
import android.graphics.Typeface;

/**
 * Creates a Bitmap that looks like the translated text
 * was always there — no AR box, no border, no badge.
 *
 * Steps:
 * 1. Fill with sampled background colour (erases original text visually)
 * 2. Add subtle gradient to blend with real surroundings
 * 3. Draw translated text in same colour + estimated size as original
 */
public class NaturalTextBillboard {

    private static final int BITMAP_W = 512;
    private static final int BITMAP_H = 256;

    /**
     * @param translatedText  The translated string to render
     * @param style           Analysed style from the original text block
     * @param blockAspect     Width/Height ratio of the original block
     *                        (used to size the bitmap correctly)
     */
    public static Bitmap create(String translatedText,
                                 TextStyleAnalyzer.TextStyle style,
                                 float blockAspect) {

        // Adapt bitmap dimensions to match original block aspect ratio
        int bmpH = BITMAP_H;
        int bmpW = Math.max(128, Math.min(1024, (int)(bmpH * blockAspect)));

        Bitmap bmp = Bitmap.createBitmap(bmpW, bmpH, Bitmap.Config.ARGB_8888);
        Canvas canvas = new Canvas(bmp);

        // ── Step 1: Paint background colour (erases original text) ─────────
        Paint bgPaint = new Paint();
        bgPaint.setColor(style.backgroundColor);
        bgPaint.setAntiAlias(true);
        canvas.drawRect(0, 0, bmpW, bmpH, bgPaint);

        // ── Step 2: Subtle edge fade to blend with real background ──────────
        // Horizontal fade: fully opaque in centre, transparent at edges
        int bgR = Color.red(style.backgroundColor);
        int bgG = Color.green(style.backgroundColor);
        int bgB = Color.blue(style.backgroundColor);

        int fadeColor     = Color.argb(180, bgR, bgG, bgB);
        int transparentBg = Color.argb(0,   bgR, bgG, bgB);

        Paint fadePaint = new Paint();

        // Left edge fade
        fadePaint.setShader(new LinearGradient(
            0, 0, bmpW * 0.12f, 0,
            fadeColor, transparentBg, Shader.TileMode.CLAMP));
        canvas.drawRect(0, 0, bmpW * 0.12f, bmpH, fadePaint);

        // Right edge fade
        fadePaint.setShader(new LinearGradient(
            bmpW * 0.88f, 0, bmpW, 0,
            transparentBg, fadeColor, Shader.TileMode.CLAMP));
        canvas.drawRect(bmpW * 0.88f, 0, bmpW, bmpH, fadePaint);

        // Top edge fade
        fadePaint.setShader(new LinearGradient(
            0, 0, 0, bmpH * 0.15f,
            fadeColor, transparentBg, Shader.TileMode.CLAMP));
        canvas.drawRect(0, 0, bmpW, bmpH * 0.15f, fadePaint);

        // Bottom edge fade
        fadePaint.setShader(new LinearGradient(
            0, bmpH * 0.85f, 0, bmpH,
            transparentBg, fadeColor, Shader.TileMode.CLAMP));
        canvas.drawRect(0, bmpH * 0.85f, bmpW, bmpH, fadePaint);

        // ── Step 3: Draw translated text ────────────────────────────────────
        Paint textPaint = new Paint();
        textPaint.setColor(style.textColor);
        textPaint.setAntiAlias(true);

        // Pick closest typeface based on detected style
        textPaint.setTypeface(pickTypeface(style));

        // Scale font size from pixel-space to bitmap-space
        // Original block height maps to BITMAP_H
        float scaledSize = style.fontSizePx * (bmpH / style.blockHeightPx);
        scaledSize = Math.max(24f, Math.min(scaledSize, bmpH * 0.7f));
        textPaint.setTextSize(scaledSize);

        // Draw wrapped text centred vertically in the bitmap
        drawCentredText(canvas, translatedText, bmpW, bmpH, textPaint);

        return bmp;
    }

    /**
     * Picks a Typeface that approximates the original.
     * Since we can't detect font family from pixels, we pick based on
     * text colour / background contrast ratio as a heuristic:
     * High contrast (print-like) → SERIF
     * Low contrast (screen UI)   → SANS_SERIF
     */
    private static Typeface pickTypeface(TextStyleAnalyzer.TextStyle style) {
        float contrast = colourContrast(style.textColor, style.backgroundColor);
        if (contrast > 7f) {
            return Typeface.create(Typeface.SERIF, Typeface.NORMAL);
        } else if (contrast > 4f) {
            return Typeface.create(Typeface.DEFAULT, Typeface.NORMAL);
        } else {
            return Typeface.create(Typeface.SANS_SERIF, Typeface.NORMAL);
        }
    }

    /** WCAG relative luminance contrast ratio */
    private static float colourContrast(int c1, int c2) {
        float l1 = relativeLuminance(c1);
        float l2 = relativeLuminance(c2);
        float lighter = Math.max(l1, l2);
        float darker  = Math.min(l1, l2);
        return (lighter + 0.05f) / (darker + 0.05f);
    }

    private static float relativeLuminance(int color) {
        float r = linearise(Color.red(color)   / 255f);
        float g = linearise(Color.green(color) / 255f);
        float b = linearise(Color.blue(color)  / 255f);
        return 0.2126f * r + 0.7152f * g + 0.0722f * b;
    }

    private static float linearise(float c) {
        return c <= 0.03928f ? c / 12.92f : (float) Math.pow((c + 0.055f) / 1.055f, 2.4);
    }

    /**
     * Draws text wrapped and centred inside the bitmap.
     */
    private static void drawCentredText(Canvas canvas, String text,
                                         int bmpW, int bmpH, Paint paint) {
        float maxW    = bmpW * 0.88f;
        float lineH   = paint.getTextSize() * 1.2f;
        float padding = bmpW * 0.06f;

        // Word-wrap
        String[] words = text.split(" ");
        java.util.List<String> lines = new java.util.ArrayList<>();
        StringBuilder current = new StringBuilder();

        for (String word : words) {
            String test = current.length() == 0 ? word : current + " " + word;
            if (paint.measureText(test) > maxW) {
                if (current.length() > 0) lines.add(current.toString());
                current = new StringBuilder(word);
            } else {
                current = new StringBuilder(test);
            }
        }
        if (current.length() > 0) lines.add(current.toString());

        // Vertically centre the block of lines
        float totalH  = lines.size() * lineH;
        float startY  = (bmpH - totalH) / 2f + paint.getTextSize();

        for (String line : lines) {
            // Horizontally centre each line
            float textW = paint.measureText(line);
            float startX = (bmpW - textW) / 2f;
            canvas.drawText(line, startX, startY, paint);
            startY += lineH;
        }
    }
}
